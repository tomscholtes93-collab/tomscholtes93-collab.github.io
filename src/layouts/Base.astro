---
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/components.css';
import '../styles/pages.css';
import { ClientRouter } from 'astro:transitions';
import JsonLdPerson from '../components/JsonLdPerson.astro';
import { LOCALES, getLocale, localizePath, t as translate, type Locale } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  jsonLd?: boolean;
  noindex?: boolean;
}

const {
  title,
  description,
  path = '/',
  jsonLd = false,
  noindex = false,
} = Astro.props;

const locale = (Astro.currentLocale ?? getLocale(Astro.url)) as Locale;
const t = (k: string, vars?: Record<string, string | number>) => translate(k, locale, vars);

const resolvedTitle = title ?? t('meta.home.title');
const resolvedDesc = description ?? t('meta.home.description');

const SITE = Astro.site ?? new URL('https://tomscholtes.com');
const canonical = new URL(localizePath(path, locale), SITE).toString();
const ogImage = 'https://tomscholtes.com/og/default.png';
const OG_LOCALE: Record<Locale, string> = {
  en: 'en_GB',
  de: 'de_DE',
  fr: 'fr_FR',
  ru: 'ru_RU',
};
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDesc} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    {LOCALES.map((l) => (
      <link rel="alternate" hreflang={l} href={new URL(localizePath(path, l), SITE).toString()} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(path, SITE).toString()} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Tom Scholtes" />
    <meta property="og:locale" content={OG_LOCALE[locale]} />
    {LOCALES.filter((l) => l !== locale).map((l) => (
      <meta property="og:locale:alternate" content={OG_LOCALE[l]} />
    ))}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDesc} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preload" href="/fonts/instrument-serif-regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-500.woff2" as="font" type="font/woff2" crossorigin />

    <script is:inline>
      (function () {
        // Mark JS as available so the tomOS desktop layer can opt in (>= 1200px).
        // Without JS this class never lands and the editorial layer is the fallback.
        document.documentElement.classList.add('js');
        // Lock the layer (desktop tomOS vs editorial) to the ENTRY viewport, ONCE, here in
        // the head before paint. A later width change (maximizing a window, a scrollbar
        // appearing, an orientation flip) must NOT swap layers mid-session: entered-desktop
        // stays desktop, entered-mobile stays mobile. Nothing updates this after load.
        if (window.matchMedia('(min-width: 1200px)').matches) {
          document.documentElement.classList.add('os-mode');
        }
        var ACC = {
          terracotta: { a: '#C4623A', i: '#8A3F1E' },
          ink:        { a: '#1B2B4B', i: '#0E1A2E' },
          forest:     { a: '#2F6B4F', i: '#1E4A35' },
          amber:      { a: '#C8902A', i: '#8A6217' },
          violet:     { a: '#6A4BA8', i: '#48327A' },
        };
        function applyDisplayPrefs() {
          try {
            var prefs = JSON.parse(localStorage.getItem('ts-display-prefs') || '{}');
            var theme = prefs.theme || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-theme', theme);
            var density = prefs.density || localStorage.getItem('density');
            if (density) document.documentElement.setAttribute('data-density', density);
            else document.documentElement.removeAttribute('data-density');
            var accent = prefs.accent || 'terracotta';
            var a = ACC[accent] || ACC.terracotta;
            document.documentElement.style.setProperty('--accent', a.a);
            document.documentElement.style.setProperty('--accent-ink', a.i);
          } catch (e) {
            document.documentElement.setAttribute('data-theme', 'light');
          }
        }
        applyDisplayPrefs();
        document.addEventListener('astro:after-swap', applyDisplayPrefs);
      })();
    </script>

    {jsonLd && <JsonLdPerson />}
    <ClientRouter />
  </head>
  <body>
    <slot />
    {/* Text justification retired 2026-06-23: prose is ragged-right (left-aligned). */}
  </body>
</html>
