---
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/components.css';
import '../styles/pages.css';
import { ClientRouter } from 'astro:transitions';
import JsonLdPerson from '../components/JsonLdPerson.astro';
import { LOCALES, DEFAULT_LOCALE, getLocale, localizePath, delocalizePath, t as translate, type Locale } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  jsonLd?: boolean;
  noindex?: boolean;
  ogType?: 'website' | 'article';
  publishedTime?: string;
}

const {
  title,
  description,
  path = '/',
  jsonLd = false,
  noindex = false,
  ogType = 'website',
  publishedTime,
} = Astro.props;

const locale = (Astro.currentLocale ?? getLocale(Astro.url)) as Locale;
const t = (k: string, vars?: Record<string, string | number>) => translate(k, locale, vars);

const resolvedTitle = title ?? t('meta.home.title');
const resolvedDesc = description ?? t('meta.home.description');

const SITE = Astro.site ?? new URL('https://tomscholtes.com');
// path is the unlocalized logical path; delocalize defensively so a
// pre-localized prop can never yield /de/de/... URLs again.
const logicalPath = delocalizePath(path);
const canonical = new URL(localizePath(logicalPath, locale), SITE).toString();
const ogImage = 'https://tomscholtes.com/og/default.png';
const ogImageAlt = 'Tom Scholtes. Six years, quietly automated.';
const OG_LOCALE: Record<Locale, string> = {
  en: 'en_GB',
  de: 'de_DE',
  fr: 'fr_FR',
  ru: 'ru_RU',
};
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDesc} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <link rel="canonical" href={canonical} />}
    {!noindex && LOCALES.map((l) => (
      <link rel="alternate" hreflang={l} href={new URL(localizePath(logicalPath, l), SITE).toString()} />
    ))}
    {!noindex && <link rel="alternate" hreflang="x-default" href={new URL(localizePath(logicalPath, DEFAULT_LOCALE), SITE).toString()} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:type" content={ogType} />
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content="Tom Scholtes" />
    <meta property="og:locale" content={OG_LOCALE[locale]} />
    {LOCALES.filter((l) => l !== locale).map((l) => (
      <meta property="og:locale:alternate" content={OG_LOCALE[l]} />
    ))}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDesc} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <link rel="preload" href="/fonts/instrument-serif-regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-500.woff2" as="font" type="font/woff2" crossorigin />

    <script is:inline>
      (function () {
        var ACC = {
          terracotta: { a: '#C4623A', i: '#8A3F1E' },
          ink:        { a: '#1B2B4B', i: '#0E1A2E' },
          forest:     { a: '#2F6B4F', i: '#1E4A35' },
          amber:      { a: '#C8902A', i: '#8A6217' },
          violet:     { a: '#6A4BA8', i: '#48327A' },
        };
        function applyDisplayPrefs() {
          try {
            var prefs = JSON.parse(localStorage.getItem('ts-display-prefs') || '{}');
            var theme = prefs.theme || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-theme', theme);
            var density = prefs.density || localStorage.getItem('density');
            if (density) document.documentElement.setAttribute('data-density', density);
            else document.documentElement.removeAttribute('data-density');
            var accent = prefs.accent || 'terracotta';
            var a = ACC[accent] || ACC.terracotta;
            document.documentElement.style.setProperty('--accent', a.a);
            document.documentElement.style.setProperty('--accent-ink', a.i);
          } catch (e) {
            document.documentElement.setAttribute('data-theme', 'light');
          }
        }
        applyDisplayPrefs();
        document.addEventListener('astro:after-swap', applyDisplayPrefs);
      })();
    </script>

    {jsonLd && <JsonLdPerson />}
    <ClientRouter />
  </head>
  <body>
    <slot />
    {/* Text justification retired 2026-06-23: prose is ragged-right (left-aligned). */}
  </body>
</html>
