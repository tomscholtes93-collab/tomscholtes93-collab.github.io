---
<svg class="arch-svg" viewBox="0 0 760 430" role="img" aria-label="Exocortex architecture: G2 glasses to phone over a private mesh to two Fedora workstations at home, one always-on node running the agent and one compute node for orchestrated jobs, with MCP endpoints fanned out">
  <!-- G2 glasses -->
  <g role="img" aria-label="Even Realities G2 glasses">
    <rect class="node-accent" x="20" y="20" width="150" height="56" rx="10" />
    <text class="label" x="95" y="46" text-anchor="middle">G2 glasses</text>
    <text class="sub"   x="95" y="64" text-anchor="middle">voice in · HUD out</text>
  </g>
  <path class="edge" d="M170 48 L 250 48" />
  <polygon class="edge" fill="currentColor" points="258,48 250,44 250,52" />

  <!-- Phone -->
  <g role="img" aria-label="Phone, companion and mesh node">
    <rect class="node" x="258" y="20" width="150" height="56" rx="10" />
    <text class="label" x="333" y="46" text-anchor="middle">Phone</text>
    <text class="sub"   x="333" y="64" text-anchor="middle">companion · mesh node</text>
  </g>
  <path class="edge" d="M333 76 L 333 122" />
  <polygon class="edge" fill="currentColor" points="333,130 329,122 337,122" />
  <text class="sub" x="345" y="104" text-anchor="start">private mesh · SSH</text>

  <!-- Home: two workstations on one mesh -->
  <g role="img" aria-label="Always-on node, holds memory and the glasses bridge, runs the agent">
    <rect class="node-accent" x="70" y="135" width="230" height="70" rx="10" />
    <text class="label" x="185" y="162" text-anchor="middle">Always-on node</text>
    <text class="sub"   x="185" y="180" text-anchor="middle">memory + glasses bridge</text>
    <text class="sub"   x="185" y="195" text-anchor="middle">runs Opus 4.8</text>
  </g>
  <g role="img" aria-label="Compute node, runs orchestrated heavy jobs as survivable workers">
    <rect class="node" x="420" y="135" width="220" height="70" rx="10" />
    <text class="label" x="530" y="162" text-anchor="middle">Compute node</text>
    <text class="sub"   x="530" y="180" text-anchor="middle">orchestrated heavy jobs</text>
    <text class="sub"   x="530" y="195" text-anchor="middle">survivable workers</text>
  </g>
  <path class="edge" stroke-dasharray="4 4" d="M300 170 L 420 170" />
  <text class="sub" x="360" y="162" text-anchor="middle">one mesh</text>

  <!-- Fan-out from the always-on node to MCP endpoints -->
  <path class="edge-accent" d="M185 205 C 185 240, 105 250, 95 288" />
  <path class="edge-accent" d="M185 205 C 185 240, 255 250, 265 288" />
  <path class="edge-accent" d="M185 205 C 185 240, 420 250, 425 288" />
  <path class="edge-accent" d="M185 205 C 185 240, 585 250, 585 288" />

  <!-- MCP endpoints -->
  <g role="img" aria-label="Knowledge base MCP endpoint">
    <rect class="node" x="30" y="292" width="130" height="56" rx="10" />
    <text class="label" x="95" y="318" text-anchor="middle">Knowledge base</text>
    <text class="sub"   x="95" y="336" text-anchor="middle">self-hosted</text>
  </g>
  <g role="img" aria-label="Notes MCP endpoint">
    <rect class="node" x="200" y="292" width="130" height="56" rx="10" />
    <text class="label" x="265" y="318" text-anchor="middle">Notes</text>
    <text class="sub"   x="265" y="336" text-anchor="middle">notes · journal</text>
  </g>
  <g role="img" aria-label="Calendar MCP endpoint">
    <rect class="node" x="360" y="292" width="130" height="56" rx="10" />
    <text class="label" x="425" y="318" text-anchor="middle">Calendar</text>
    <text class="sub"   x="425" y="336" text-anchor="middle">schedule</text>
  </g>
  <g role="img" aria-label="Mail MCP endpoint">
    <rect class="node" x="520" y="292" width="130" height="56" rx="10" />
    <text class="label" x="585" y="318" text-anchor="middle">Mail</text>
    <text class="sub"   x="585" y="336" text-anchor="middle">inbox</text>
  </g>

  <text class="sub" x="380" y="392" text-anchor="middle">All endpoints reached over MCP, scoped per query</text>
</svg>
