---
import Arr from './Arr.astro';
---
<section id="contact" class="reveal">
  <div class="container">
    <div class="cta-card">
      <div class="cta-bg">hi.</div>
      <div style="position:relative; z-index:1">
        <span class="eyebrow" style="color:inherit; opacity:.6">Contact</span>
        <h2 style="margin-top:16px">If any of this is <em>interesting</em>, say hi.</h2>
      </div>
      <div class="right" style="position:relative; z-index:1">
        <p>
          Always interested in conversations about data engineering, automation, applied AI,
          multi-agent systems, knowledge engineering, agent infrastructure, especially where
          they meet regulated workflows.
        </p>
        <a href="https://www.linkedin.com/messaging/compose/?recipient=tomscholtes93" target="_blank" rel="noopener" class="btn btn-primary">Message on LinkedIn <Arr /></a>
        <div style="display:flex; gap:12px; flex-wrap:wrap">
          <a href="https://www.linkedin.com/in/tomscholtes93/" target="_blank" rel="noopener" class="btn btn-ghost">View profile</a>
          <a href="mailto:tom@tomscholtes.com" class="btn btn-ghost">Email</a>
        </div>
      </div>
    </div>
  </div>
</section>
