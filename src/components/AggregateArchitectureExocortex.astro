  <text class="sub"   x="783" y="334" text-anchor="middle">same-model to Codex to Fable</text>
  <text class="label" x="548" y="374" text-anchor="middle">leakage-audit</text>
  <text class="sub"   x="548" y="386" text-anchor="middle">never skipped</text>
  <text class="label" x="680" y="374" text-anchor="middle">Composer</text>
  <text class="sub"   x="680" y="386" text-anchor="middle">schema-checked orders</text>
