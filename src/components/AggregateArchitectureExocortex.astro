  <text class="sub"   x="345" y="289" text-anchor="middle">inbox to profile · git-gated</text>
  <text class="label" x="90"  y="338" text-anchor="middle">KB</text>
  <text class="sub"   x="90"  y="351" text-anchor="middle">self-hosted</text>
  <text class="label" x="194" y="338" text-anchor="middle">Notes</text>
  <text class="sub"   x="194" y="351" text-anchor="middle">journal</text>
  <text class="label" x="298" y="338" text-anchor="middle">Calendar</text>
