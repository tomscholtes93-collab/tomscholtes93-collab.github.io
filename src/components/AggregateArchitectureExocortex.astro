---
// One aggregated, genericized view of the whole system: the wearables, the
// private mesh, the always-on node and the compute node with the mega-orchestrator
// and everything around it, the models used across every path, and the gated
// deploy. Emulates an Excalidraw sketch: the site's architecture-SVG vocabulary
// (so it themes and animates with the page) plus a light hand-drawn roughen filter
// on the shapes. The editable source lives at /media/exocortex-architecture.excalidraw.
// Labels are language-neutral, like the other diagrams on this page.
---
<svg class="arch-svg aggregate-arch" viewBox="0 0 920 624" role="img"
     aria-label="Aggregated exocortex architecture. Wearables (G2 glasses, phone, smart ring) reach a private mesh over an encrypted overlay and SSH. The mesh connects an always-on node (co-partner, model router on Claude Max OAuth, layered memory, glasses bridge, and MCP endpoints for knowledge base, notes, calendar and mail) and a compute node (the mega-orchestrator daemon, Memory-Master, Planner, admission gate, a survivable worker, a review gate that runs same-model then Codex then Fable, plus a leakage-audit gate, the Composer, carry, a mutual medic, watchers, and a cross-vendor watchdog still in validation). Models used across every path: Opus 4.8 by default, Fable 5 on the word fable, and Codex gpt-5.5 for cross-vendor review. Everything ends at a gated deploy to production.">
  <defs>
    <filter id="rough-agg" x="-2%" y="-2%" width="104%" height="104%">
      <feTurbulence type="fractalNoise" baseFrequency="0.011" numOctaves="2" seed="7" result="n" />
      <feDisplacementMap in="SourceGraphic" in2="n" scale="1.6" xChannelSelector="R" yChannelSelector="G" />
    </filter>
  </defs>

  <!-- ============ SHAPES (roughened) ============ -->
  <g filter="url(#rough-agg)">
    <!-- wearables -->
    <rect class="node-accent" x="235" y="26" width="130" height="46" rx="10" />
    <rect class="node" x="395" y="26" width="130" height="46" rx="10" />
    <rect class="node" x="555" y="26" width="130" height="46" rx="10" />
    <path class="edge" d="M300 72 L 415 90" />
    <path class="edge" d="M460 72 L 460 90" />
    <path class="edge" d="M620 72 L 505 90" />
    <!-- private mesh -->
    <rect class="node" x="300" y="90" width="320" height="34" rx="17" />
    <path class="edge" d="M400 124 L 255 140" />
    <polygon class="edge" fill="currentColor" points="248,141 257,137 258,145" />
    <path class="edge" d="M520 124 L 665 140" />
    <polygon class="edge" fill="currentColor" points="672,141 662,137 663,145" />

    <!-- containers -->
    <rect x="24" y="140" width="428" height="310" rx="16" fill="none" stroke="currentColor" stroke-opacity="0.28" />
    <rect x="468" y="140" width="428" height="310" rx="16" fill="none" stroke="currentColor" stroke-opacity="0.28" />

    <!-- always-on node inner -->
    <rect class="node-accent" x="44" y="192" width="194" height="46" rx="10" />
    <rect class="node" x="258" y="192" width="174" height="46" rx="10" />
    <rect class="node" x="44" y="252" width="194" height="44" rx="10" />
    <rect class="node" x="258" y="252" width="174" height="44" rx="10" />
    <rect class="node" x="44" y="316" width="92" height="40" rx="8" />
    <rect class="node" x="148" y="316" width="92" height="40" rx="8" />
    <rect class="node" x="252" y="316" width="92" height="40" rx="8" />
    <rect class="node" x="356" y="316" width="76" height="40" rx="8" />

    <!-- compute node inner -->
    <rect class="node-accent" x="488" y="192" width="388" height="44" rx="10" />
    <rect class="node" x="488" y="248" width="120" height="38" rx="8" />
    <rect class="node" x="620" y="248" width="120" height="38" rx="8" />
    <rect class="node" x="752" y="248" width="124" height="38" rx="8" />
    <rect class="node" x="488" y="298" width="186" height="40" rx="10" />
    <rect class="node-accent" x="690" y="298" width="186" height="40" rx="10" />
    <rect class="node" x="488" y="352" width="120" height="38" rx="8" />
    <rect class="node" x="620" y="352" width="120" height="38" rx="8" />
    <rect class="node" x="752" y="352" width="124" height="38" rx="8" />
    <rect class="node" x="488" y="400" width="120" height="38" rx="8" />
    <rect class="node" x="620" y="400" width="120" height="38" rx="8" />
    <rect class="node" x="752" y="400" width="124" height="38" rx="8" stroke-dasharray="5 4" />

    <!-- handoff between nodes -->
    <path class="edge" d="M452 214 L 464 214" />
    <polygon class="edge" fill="currentColor" points="470,214 462,210 462,218" />

    <!-- compute node to deploy -->
    <path class="edge-accent" d="M682 450 C 660 468, 630 470, 612 476" />
    <polygon class="edge" fill="currentColor" points="606,478 615,474 614,482" />
    <rect class="node-accent" x="460" y="476" width="220" height="46" rx="10" />

    <!-- models strip -->
    <rect class="node-accent" x="160" y="540" width="200" height="44" rx="10" />
    <rect class="node" x="380" y="540" width="200" height="44" rx="10" />
    <rect class="node" x="600" y="540" width="200" height="44" rx="10" />
  </g>

  <!-- ============ TEXT (crisp) ============ -->
  <text class="label" x="300" y="50" text-anchor="middle">G2 glasses</text>
  <text class="sub"   x="300" y="66" text-anchor="middle">voice in · HUD out</text>
  <text class="label" x="460" y="50" text-anchor="middle">Phone</text>
  <text class="sub"   x="460" y="66" text-anchor="middle">companion · mesh node</text>
  <text class="label" x="620" y="50" text-anchor="middle">Smart ring</text>
  <text class="sub"   x="620" y="66" text-anchor="middle">biometric capture</text>

  <text class="label" x="460" y="106" text-anchor="middle">private mesh</text>
  <text class="sub"   x="460" y="120" text-anchor="middle">encrypted overlay + SSH · ~6 ms</text>

