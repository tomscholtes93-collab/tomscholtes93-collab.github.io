  <text class="sub"   x="814" y="434" text-anchor="middle">in validation</text>

  <text class="sub"   x="459" y="206" text-anchor="middle">handoff</text>

  <text class="label" x="570" y="500" text-anchor="middle">deploy to production</text>
  <text class="sub"   x="570" y="515" text-anchor="middle">this site, gated</text>

  <text class="sub"   x="480" y="532" text-anchor="middle">models · used across every path</text>
