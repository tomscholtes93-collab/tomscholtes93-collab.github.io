---
import { NOW_IDS } from '../content/now.ts';
import { t as translate, getLocale, localizePath, type Locale } from '../i18n';

const locale = (Astro.currentLocale ?? getLocale(Astro.url)) as Locale;
const t = (k: string) => translate(k, locale);

// Items that carry a trailing inline CTA link. Language-agnostic for the
// static workflow page; localized for the exocortex project page.
const LINKS: Record<string, { href: string; label: string }> = {
  email: { href: '/workflow-automation/', label: t('home.now.cta.demo') },
  exocortex: { href: localizePath('/projects/exocortex', locale), label: t('home.now.cta.project') },
};
---
<section id="now" class="reveal">
  <div class="container">
    <div class="sec-head">
      <span class="eyebrow">{t('home.now.eyebrow')}</span>
      <div>
        <h2>{t('home.now.heading')}</h2>
        <p class="blurb">
          {t('home.now.blurb.pre')}
          <span style="font-style:italic">{t('home.now.blurb.em')}</span>{t('home.now.blurb.post')}
        </p>
      </div>
    </div>
    <div style="border-top:1px solid var(--rule)">
      {NOW_IDS.map((id) => (
        <div class="now-row">
          <div class="k">{t(`home.now.items.${id}.k`)}</div>
          <div class="v">
            {t(`home.now.items.${id}.v`)}
            {LINKS[id] && (
              <>
                {' '}
                <a class="link" href={LINKS[id].href}>{LINKS[id].label}</a>
              </>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
