---
// Concentric "onion" of the live layered review loops that gate a public deploy.
// Read from the center out: an artifact must pass each nested loop before it can
// ship. Same-model loop, then a cross-vendor Codex loop (capped), then a Fable 5
// loop (capped), then deploy. The leakage-audit gate sits outside every loop.
// Labels are language-neutral (component and model names), like the other
// architecture diagrams on this page.
---
<svg class="arch-svg loops-onion" viewBox="0 0 640 500" role="img"
     aria-label="Concentric review loops: at the center a diff, wrapped by a same-model loop, then a Codex gpt-5.5 loop capped at two rounds, then a Fable 5 loop capped at two rounds, then deploy on all-pass. A separate leakage-audit gate sits outside every loop and is never skipped.">
  <!-- rings, read from the outside in: Fable, Codex, same-model.
       pathLength normalizes each circumference into the site's 600-unit
       stroke-dasharray reveal budget (see pages.css), so the draw-in animation
       ends with fully closed rings instead of partial arcs. -->
  <circle class="edge-accent" cx="250" cy="230" r="190" pathLength="590" />
  <circle class="edge-accent" cx="250" cy="230" r="140" pathLength="590" />
  <circle class="edge-accent" cx="250" cy="230" r="92" pathLength="590" />

  <!-- core: the artifact under review -->
  <g role="img" aria-label="The diff under review">
    <circle class="node-accent" cx="250" cy="230" r="46" />
    <text class="label" x="250" y="227" text-anchor="middle">the diff</text>
    <text class="sub"   x="250" y="243" text-anchor="middle">produced by a worker</text>
  </g>

  <!-- band labels, placed in the gap at the top of each ring -->
  <text class="label" x="250" y="62"  text-anchor="middle">Fable 5 loop</text>
  <text class="sub"   x="250" y="78"  text-anchor="middle">premium judge · max 2 rounds</text>

  <text class="label" x="250" y="112" text-anchor="middle">Codex loop</text>
  <text class="sub"   x="250" y="128" text-anchor="middle">gpt-5.5 · cross-vendor · max 2</text>

  <text class="label" x="250" y="160" text-anchor="middle">same-model loop</text>
  <text class="sub"   x="250" y="176" text-anchor="middle">produce, then review, converge</text>

  <!-- pass, from the outside out to deploy -->
  <path class="edge-accent" d="M250 420 L 250 446" />
  <polygon class="edge" fill="currentColor" points="250,454 245,446 255,446" />
  <g role="img" aria-label="Deploy on all-pass">
    <rect class="node-accent" x="168" y="454" width="164" height="40" rx="10" />
    <text class="label" x="250" y="474" text-anchor="middle">DEPLOY</text>
    <text class="sub"   x="250" y="488" text-anchor="middle">only after every layer passes</text>
  </g>

  <!-- read-out column -->
  <g role="img" aria-label="How to read the loops">
    <text class="label" x="452" y="120" text-anchor="start">Read inside out.</text>
    <text class="sub"   x="452" y="146" text-anchor="start">Each layer must pass</text>
    <text class="sub"   x="452" y="162" text-anchor="start">before the next one runs.</text>
    <text class="sub"   x="452" y="192" text-anchor="start">The caps guard a premium</text>
    <text class="sub"   x="452" y="208" text-anchor="start">model that once ran away</text>
    <text class="sub"   x="452" y="224" text-anchor="start">on cost.</text>
    <text class="sub"   x="452" y="262" text-anchor="start">Fable only ever sees</text>
    <text class="sub"   x="452" y="278" text-anchor="start">near-final work, so it</text>
    <text class="sub"   x="452" y="294" text-anchor="start">stays cheap.</text>
  </g>

  <!-- leakage-audit gate: outside every loop -->
  <g role="img" aria-label="Leakage-audit gate, outside every loop">
    <rect class="node" x="452" y="332" width="176" height="58" rx="10" />
    <text class="label" x="540" y="356" text-anchor="middle">leakage-audit gate</text>
    <text class="sub"   x="540" y="372" text-anchor="middle">outside every loop</text>
    <text class="sub"   x="540" y="386" text-anchor="middle">never skipped</text>
  </g>
</svg>
