---
import Arr from './Arr.astro';

interface Props {
  active?: string;
}
const { active = 'home' } = Astro.props;
const base = active === 'home' ? '' : '/';
---
<header class="nav" id="site-nav" data-open="false">
  <div class="container nav-inner">
    <a href={active === 'home' ? '#' : '/'} class="brand">
      <span class="brand-mark">T</span>
      <span>Tom Scholtes</span>
    </a>
    <nav class="nav-links">
      <a href={base + '#now'}>Now</a>
      <a href={base + '#work'}>Work</a>
      <a href="/projects">Projects</a>
      <a href={base + '#cv'}>CV</a>
      <a href="/thesis">Thesis</a>
      <a href={base + '#reading'}>Reading</a>
      <a href={base + '#contact'}>Contact</a>
    </nav>
    <a href={base + '#contact'} class="nav-cta">Say hi <Arr /></a>
    <button type="button" class="nav-toggle" aria-label="Open menu" aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>
</header>

<script is:inline>
  (function () {
    var nav = document.getElementById('site-nav');
    if (!nav) return;
    var btn = nav.querySelector('.nav-toggle');
    var links = nav.querySelector('.nav-links');
    function setOpen(v) {
      nav.setAttribute('data-open', v ? 'true' : 'false');
      btn.setAttribute('aria-expanded', v ? 'true' : 'false');
      btn.setAttribute('aria-label', v ? 'Close menu' : 'Open menu');
      document.body.style.overflow = v ? 'hidden' : '';
    }
    btn.addEventListener('click', function () {
      setOpen(nav.getAttribute('data-open') !== 'true');
    });
    links.addEventListener('click', function (e) {
      if (e.target && e.target.tagName === 'A') setOpen(false);
    });
  })();
</script>
