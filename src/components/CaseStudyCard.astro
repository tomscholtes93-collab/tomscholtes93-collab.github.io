---
interface Props {
  n: string;
  title: string;
  metric: string;
  label: string;
  blurb: string;
  tags: string[];
  href?: string;
  className?: string;
  style?: string;
}
const { n, title, metric, label, blurb, tags, href, className, style } = Astro.props;
const Tag = href ? 'a' : 'article';
const classes = ['case', href ? 'case-link' : '', className ?? ''].filter(Boolean).join(' ');
const extra = {
  ...(href ? { href } : {}),
  class: classes,
  ...(style ? { style } : {}),
};
---
<Tag {...extra}>
  <div class="case-head">
    <span class="svc-num">Case {n}</span>
    <div class="case-metric">
      <div class="case-metric-num">{metric}</div>
      <div class="case-metric-lbl">{label}</div>
    </div>
  </div>
  <h3>{title}{href && <span class="case-arr">→</span>}</h3>
  <p>{blurb}</p>
  <div class="tags">
    {tags.map((t) => <span class="tag">{t}</span>)}
  </div>
</Tag>
