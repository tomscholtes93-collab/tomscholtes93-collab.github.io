---
import CaseStudyCard from './CaseStudyCard.astro';
import { CASE_IDS } from '../content/caseStudies.ts';
import { t as translate, getLocale, type Locale } from '../i18n';

const locale = (Astro.currentLocale ?? getLocale(Astro.url)) as Locale;
const t = (k: string) => translate(k, locale);
---
<section id="work" class="reveal">
  <div class="container">
    <div class="sec-head">
      <span class="eyebrow">{t('home.work.eyebrow')}</span>
      <div>
        <h2>{t('home.work.heading')}</h2>
        <p class="blurb" style="margin-top:18px">
          {t('home.work.blurb')}
        </p>
      </div>
    </div>
    <div class="cases">
      {CASE_IDS.map((n) => {
        const tags = [
          t(`home.work.case.${n}.tag.0`),
          t(`home.work.case.${n}.tag.1`),
          t(`home.work.case.${n}.tag.2`),
        ].filter((s) => s && s.length > 0);
        return (
          <CaseStudyCard
            n={n}
            title={t(`home.work.case.${n}.title`)}
            metric={t(`home.work.case.${n}.metric`)}
            label={t(`home.work.case.${n}.label`)}
            blurb={t(`home.work.case.${n}.blurb`)}
            tags={tags}
          />
        );
      })}
      <CaseStudyCard
        n="08"
        title="Investran ↔ Dealsplus composite-keys bridge"
        metric="Pattern"
        label="designed"
        blurb="Designed a composite-keys bridging architecture for Investran ↔ Dealsplus reconciliation while the instrument master was still being scoped. Proposed internally; not deployed."
        tags={['Data integration', 'Composite keys', 'Internal proposal']}
      />
    </div>
  </div>
</section>
