---
import CaseStudyCard from './CaseStudyCard.astro';
import { CASE_IDS, CASE_SLUG } from '../content/caseStudies.ts';
import { t as translate, getLocale, type Locale } from '../i18n';

const locale = (Astro.currentLocale ?? getLocale(Astro.url)) as Locale;
const t = (k: string) => translate(k, locale);
---
<section id="work" class="reveal">
  <div class="container">
    <div class="sec-head">
      <span class="eyebrow">{t('home.work.eyebrow')}</span>
      <div>
        <h2>{t('home.work.heading')}</h2>
        <p class="blurb">
          {t('home.work.blurb')}
        </p>
      </div>
    </div>
    <div class="cases" data-stagger>
      {CASE_IDS.map((n, i) => {
        const tags = [
          t(`home.work.case.${n}.tag.0`),
          t(`home.work.case.${n}.tag.1`),
          t(`home.work.case.${n}.tag.2`),
        ].filter((s) => s && s.length > 0);
        return (
          <CaseStudyCard
            n={n}
            title={t(`home.work.case.${n}.title`)}
            metric={t(`home.work.case.${n}.metric`)}
            label={t(`home.work.case.${n}.label`)}
            blurb={t(`home.work.case.${n}.blurb`)}
            tags={tags}
            href={`/case/${CASE_SLUG[n]}/`}
            className="reveal-item"
            style={`--i:${i}`}
          />
        );
      })}
      <CaseStudyCard
        n="08"
        title="Cross-system fund-data reconciliation architecture"
        metric="Pattern"
        label="designed"
        blurb="Designed a bridging architecture for reconciling two source-of-truth platforms in a fund-administration setting while the underlying master data model was still being scoped. Generic pattern. Proposed internally; not deployed."
        tags={['Data integration', 'Master data', 'Internal proposal']}
        href="/case/cross-system-reconciliation/"
        className="reveal-item"
        style={`--i:${CASE_IDS.length}`}
      />
      <CaseStudyCard
        n="09"
        title="End-to-end email automation"
        metric="Pattern"
        label="personal automation architecture"
        blurb="An incoming message triggers an agent that fetches attachments, reads them, searches across knowledge systems, delegates research, and once the answer is well grounded drafts a reply and proposes which attachments to attach. A self-review loop runs the draft through a second model until it has no further comments, then hands a clean output to a human reviewer who owns the decision."
        tags={['Agentic', 'Self-review loop', 'Human-in-the-loop']}
        href="/case/email-automation/"
        className="reveal-item"
        style={`--i:${CASE_IDS.length + 1}`}
      />
    </div>
  </div>
</section>
