---
import { t as translate, getLocale, type Locale } from '../i18n';

const locale = (Astro.currentLocale ?? getLocale(Astro.url)) as Locale;
const t = (k: string) => translate(k, locale);
---
<section class="reveal">
  <div class="container">
    <div class="colo-grid">
      <div>
        <span class="eyebrow">{t('home.colophon.eyebrow')}</span>
        <h2>{t('home.colophon.heading')}</h2>
      </div>
      <div class="body">
        <p>
          {t('home.colophon.body.0.lead')}
          <span style="font-family:'Instrument Serif', serif; font-style:italic">Instrument Serif</span> {t('home.colophon.body.0.afterSerif')}
          <span style="font-weight:500">Inter</span> {t('home.colophon.body.0.afterBody')}
          <span style="font-family:'JetBrains Mono', monospace">JetBrains Mono</span> {t('home.colophon.body.0.afterMono')}
        </p>
        <p>{t('home.colophon.body.1')}</p>
        <p>{t('home.colophon.body.2')}</p>
      </div>
    </div>
  </div>
</section>
