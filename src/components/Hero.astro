---
import Arr from './Arr.astro';
import HeroComposition from './HeroComposition.astro';
import { HEADLINES, DEFAULT_HEADLINE } from '../content/headlines.ts';

const headline = HEADLINES[DEFAULT_HEADLINE];
---
<section class="hero">
  <div class="container hero-grid">
    <div>
      <span class="eyebrow">Personal site · Luxembourg</span>
      <h1>{headline.pre}<em>{headline.em}</em>{headline.post}</h1>
      <p class="lead">
        I'm Tom. I work in controlling for alternative funds in Luxembourg.
        Six years in fund services across PE, Private Debt and Real Estate.
        Below is a CV that updates as the work does, a set of patterns I've worked through, and a place
        to put down what I'm figuring out about data engineering, automation and applied AI in regulated finance.
        Available from June 2026.
      </p>
      <div class="hero-actions">
        <a href="#work" class="btn btn-primary">See the work <Arr /></a>
        <a href="#contact" class="btn btn-ghost">Get in touch</a>
      </div>
      <div class="hero-meta">
        <div><strong>6 yrs</strong>in Lux fund services</div>
        <div><strong>7</strong>case studies on file</div>
        <div><strong>6</strong>languages spoken</div>
      </div>
    </div>
    <HeroComposition />
  </div>
</section>
