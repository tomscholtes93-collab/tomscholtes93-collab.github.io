---
import Arr from './Arr.astro';
import { DEFAULT_HEADLINE } from '../content/headlines.ts';
import { CASE_IDS, EXTRA_CASES } from '../content/caseStudies.ts';
import { t as translate, getLocale, type Locale } from '../i18n';

const locale = (Astro.currentLocale ?? getLocale(Astro.url)) as Locale;
const t = (k: string, vars?: Record<string, string | number>) => translate(k, locale, vars);
const h = DEFAULT_HEADLINE;
// Derived from the case collection so the hero meta can never drift from the
// number of cards actually rendered in the Work section.
const caseCount = CASE_IDS.length + EXTRA_CASES.length;
---
<section class="hero">
  <div class="container hero-grid">
    <div>
      <span class="eyebrow">{t('home.hero.eyebrow')}</span>
      <h1>{t(`home.hero.headlines.${h}.pre`)}<em>{t(`home.hero.headlines.${h}.em`)}</em>{t(`home.hero.headlines.${h}.post`)}</h1>
      <p class="lead">{t('home.hero.lead')}</p>
      <div class="hero-actions">
        <a href="#work" class="btn btn-primary">{t('home.hero.cta.work')} <Arr /></a>
        <a href="#contact" class="btn btn-ghost">{t('home.hero.cta.contact')}</a>
      </div>
      <div class="hero-meta">
        <div><strong>{t('home.hero.meta.years.value')}</strong>{t('home.hero.meta.years.label')}</div>
        <div><strong>{caseCount}</strong>{t('home.hero.meta.casestudies.label')}</div>
        <div><strong>{t('home.hero.meta.languages.value')}</strong>{t('home.hero.meta.languages.label')}</div>
      </div>
    </div>
    <figure class="hero-video">
      <video
        class="hero-video-el"
        controls
        preload="metadata"
        playsinline
        poster="/media/mega-orchestration-teaser-poster.jpg"
        aria-label={t('home.hero.video.cap')}
      >
        <source src="/media/mega-orchestration-teaser.mp4" type="video/mp4" />
      </video>
      <figcaption>{t('home.hero.video.cap')}</figcaption>
    </figure>
  </div>
</section>

<style>
  /* Hero video (replaces the rotating DevSwarm/accounts composition, Tom 2026-06-29).
     Click-to-play with the poster as the still; metadata-only preload keeps it light. */
  .hero-video { margin: 0; display: flex; flex-direction: column; gap: 10px; min-width: 0; }
  .hero-video-el {
    width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
    display: block;
    background: #000;
    border: 1px solid var(--rule);
    border-radius: 14px;
    box-shadow: 0 18px 44px -26px rgba(0, 0, 0, 0.5);
    object-fit: cover;
  }
  .hero-video figcaption {
    font-size: 13px;
    line-height: 1.4;
    color: var(--muted);
    text-align: left;
  }
</style>
