---
import { t as translate, getLocale, type Locale } from '../i18n';

const locale = (Astro.currentLocale ?? getLocale(Astro.url)) as Locale;
const t = (k: string) => translate(k, locale);
const langs = [
  { code: 'EN', name: 'English' },
  { code: 'DE', name: 'Deutsch' },
  { code: 'FR', name: 'Français' },
  { code: 'RU', name: 'Русский' },
  { code: 'LU', name: 'Lëtzebuergesch' },
  { code: 'UZ', name: 'Oʻzbekcha' },
];
---
<section class="reveal">
  <div class="container">
    <div class="sec-head">
      <span class="eyebrow">{t('home.languages.eyebrow')}</span>
      <div>
        <h2>{t('home.languages.heading')}</h2>
      </div>
    </div>
    <div class="lang-grid">
      {langs.map((l) => (
        <div class="lang-card">
          <div class="code">{l.code}</div>
          <div class="name">{l.name}</div>
        </div>
      ))}
    </div>
  </div>
</section>
