---
import type { CollectionEntry } from 'astro:content';
import { getLocale, localizePath, localeDateFmt, type Locale } from '../i18n';

interface Props { entry: CollectionEntry<'notes'>; }
const { entry } = Astro.props;
const locale = (Astro.currentLocale ?? getLocale(Astro.url)) as Locale;
const fmt = localeDateFmt(locale);
const displaySlug = entry.slug.replace(/^(en|de|fr|ru)\//, '');
const href = localizePath(`/notes/${displaySlug}/`, locale);
const firstTag = entry.data.tags[0];
const publishedDate = entry.data.publishDate.toISOString().slice(0, 10);
---
<a href={href} class="note-entry" data-astro-prefetch>
  <p class="note-entry-meta eyebrow">
    <time datetime={publishedDate}>{fmt.format(entry.data.publishDate)}</time>
    {firstTag && <><span aria-hidden="true">·</span><span>{firstTag}</span></>}
  </p>
  <h2 class="serif note-entry-title" transition:name={`note-title-${displaySlug}`}>
    {entry.data.title}
  </h2>
  <p class="note-entry-summary" transition:name={`note-summary-${displaySlug}`}>
    {entry.data.summary}
  </p>
</a>
