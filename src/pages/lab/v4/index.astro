  <!-- ===================== DOCK ===================== -->
  <nav class="dock" id="dock" aria-label="App launcher">
    {apps.map((a) => (
      <button class="dock-item" data-open={a.id} aria-label={`Open ${a.label}`}>
        <span class="dock-icon" aria-hidden="true">{a.glyph}</span>
        <span class="dock-label">{a.label}</span>
      </button>
    ))}
  </nav>

  <script>
    (function () {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ---- clock ----
      const clock = document.getElementById('clock');
      function tick() {
        if (!clock) return;
        const d = new Date();
        clock.textContent = d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      }
      tick();
      setInterval(tick, 15000);

      // Only run the windowing engine on the desktop canvas.
      const canvas = document.getElementById('canvas');
      const isDesktop = () => window.matchMedia('(min-width: 761px)').matches;

      let z = 100;
      const wins = Array.from(document.querySelectorAll('.canvas .win'));
      const dockItems = Array.from(document.querySelectorAll('.dock-item'));

      function winById(id) { return document.querySelector('.canvas .win[data-app="' + id + '"]'); }
      function dockById(id) { return document.querySelector('.dock-item[data-open="' + id + '"]'); }

      // initial placement from data attributes
      function place(w) {
        const x = parseInt(w.dataset.x || '40', 10);
        const y = parseInt(w.dataset.y || '60', 10);
        const ww = parseInt(w.dataset.w || '440', 10);
        w.style.left = x + 'px';
        w.style.top = y + 'px';
        w.style.width = ww + 'px';
      }

      function focusWin(w) {
        wins.forEach((o) => o.classList.remove('focused'));
        w.classList.add('focused');
        w.style.zIndex = String(++z);
        // titlebar menu app name reflect
      }

      function setDockState() {
        dockItems.forEach((di) => {
          const id = di.dataset.open;
          const w = winById(id);
          if (!w) return;
          const visible = !w.classList.contains('minimized') && w.style.display !== 'none';
          di.classList.toggle('open', visible);
        });
      }

      function openWin(id) {
        if (!isDesktop()) return;
        const w = winById(id);
        if (!w) return;
        w.classList.remove('minimized');
        w.style.display = 'flex';
        focusWin(w);
        setDockState();
      }
      function closeWin(w) {
        w.style.display = 'none';
        setDockState();
      }
      function minWin(w) {
        w.classList.add('minimized');
        setDockState();
      }
      function zoomWin(w) {
        // toggle a wider layout (no fullscreen takeover, keep playful)
        if (w.dataset.zoomed === '1') {
          place(w);
          w.dataset.zoomed = '0';
        } else {
          w.style.left = '24px';
          w.style.top = '52px';
          w.style.width = Math.min(window.innerWidth - 48, 760) + 'px';
          w.dataset.zoomed = '1';
        }
        focusWin(w);
      }

      // init windows
      if (canvas) {
        // keep default arrangement so all content is visible without fuss:
        // show the primary set, stash CV/Reading/Lang/Contact behind dock by default
        // BUT requirement: all content visible/openable without fuss.
        // We render all windows; default-open a clean subset, others reachable via dock.
        const defaultOpen = ['about', 'work', 'demo', 'now'];
        wins.forEach((w) => {
          place(w);
          const id = w.dataset.app;
          if (defaultOpen.indexOf(id) === -1) {
            w.style.display = 'none';
          } else {
            w.style.display = 'flex';
          }
          // focus interactions
          w.addEventListener('mousedown', () => focusWin(w));

          // traffic lights
          const c = w.querySelector('.light.c');
          const m = w.querySelector('.light.m');
          const zz = w.querySelector('.light.z');
          if (c) c.addEventListener('click', (e) => { e.stopPropagation(); closeWin(w); });
          if (m) m.addEventListener('click', (e) => { e.stopPropagation(); minWin(w); });
          if (zz) zz.addEventListener('click', (e) => { e.stopPropagation(); zoomWin(w); });

          // drag
          const bar = w.querySelector('.titlebar');
          if (bar) enableDrag(w, bar);
        });
        // initial z order for default-open
        defaultOpen.forEach((id) => { const w = winById(id); if (w) focusWin(w); });
        const aboutW = winById('about'); if (aboutW) focusWin(aboutW);
        setDockState();
      }

      // ---- drag engine ----
      function enableDrag(w, handle) {
        let sx = 0, sy = 0, ox = 0, oy = 0, dragging = false;

        function down(e) {
          if (e.target.closest('.light')) return;
          dragging = true;
          focusWin(w);
          const p = point(e);
          sx = p.x; sy = p.y;
          ox = w.offsetLeft; oy = w.offsetTop;
          document.body.style.userSelect = 'none';
          window.addEventListener('mousemove', move);
          window.addEventListener('mouseup', up);
          window.addEventListener('touchmove', move, { passive: false });
          window.addEventListener('touchend', up);
        }
        function move(e) {
          if (!dragging) return;
          if (e.cancelable) e.preventDefault();
          const p = point(e);
          let nx = ox + (p.x - sx);
          let ny = oy + (p.y - sy);
          // clamp within viewport-ish
          nx = Math.max(4, Math.min(nx, window.innerWidth - 80));
          ny = Math.max(38, Math.min(ny, window.innerHeight - 50));
          w.style.left = nx + 'px';
          w.style.top = ny + 'px';
        }
        function up() {
          dragging = false;
          document.body.style.userSelect = '';
          window.removeEventListener('mousemove', move);
          window.removeEventListener('mouseup', up);
          window.removeEventListener('touchmove', move);
          window.removeEventListener('touchend', up);
        }
        function point(e) {
          if (e.touches && e.touches[0]) return { x: e.touches[0].clientX, y: e.touches[0].clientY };
          return { x: e.clientX, y: e.clientY };
        }
        handle.addEventListener('mousedown', down);
        handle.addEventListener('touchstart', down, { passive: true });
      }

      // ---- openers: dock + menubar + in-window data-open ----
      document.querySelectorAll('[data-open]').forEach((el) => {
        if (el.classList.contains('light')) return;
        el.addEventListener('click', (e) => {
          const id = el.dataset.open;
          if (!id) return;
          if (isDesktop()) {
            e.preventDefault();
            openWin(id);
            const w = winById(id);
            if (w) {
              w.scrollIntoView({ block: 'nearest', behavior: reduce ? 'auto' : 'smooth' });
              w.focus({ preventScroll: true });
            }
          } else {
            // mobile: jump to the stacked section
            const map = { work: '#m-work', contact: '#m-contact' };
            const target = map[id];
            if (target) { e.preventDefault(); document.querySelector(target).scrollIntoView({ behavior: reduce ? 'auto' : 'smooth' }); }
          }
        });
      });

      // keyboard: Esc closes focused window
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          const f = document.querySelector('.canvas .win.focused');
          if (f && isDesktop()) closeWin(f);
        }
      });
    })();
  </script>
</body>
