        <div class="eyebrow" style="margin-top:18px;">Experience · 5 roles · 6+ years</div>
        {roles.map(r => (
          <div class="role">
            <div class="rh"><b>{r.title}</b><span class="dt">{r.dates}</span></div>
            <div class="rr">{r.role}</div>
