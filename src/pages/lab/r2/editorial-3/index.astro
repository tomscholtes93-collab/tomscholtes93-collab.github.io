  <script>
    // Mobile menu
    const toggle = document.getElementById('navToggle');
    const menu = document.getElementById('mobileMenu');
    const close = document.getElementById('mmClose');
    const openMenu = () => { if (menu) { menu.classList.add('open'); document.body.style.overflow = 'hidden'; } };
    const closeMenu = () => { if (menu) { menu.classList.remove('open'); document.body.style.overflow = ''; } };
    toggle && toggle.addEventListener('click', openMenu);
    close && close.addEventListener('click', closeMenu);
    menu && menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });

    // Scroll reveal, grouped per-section so content does not pop in piecemeal.
    const motionOK = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;
    const reveals = Array.from(document.querySelectorAll('.reveal'));
    if (motionOK && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -8% 0px' });
      reveals.forEach((el) => io.observe(el));
    } else {
      reveals.forEach((el) => el.classList.add('in'));
    }
  </script>
