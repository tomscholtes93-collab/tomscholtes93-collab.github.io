---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Tom Scholtes. Finance ops engineer who automates the work in reach.</title>
  <meta name="description" content="Personal site, live CV, and a portfolio of automation I've built for regulated finance operations. Six years in Luxembourg fund services, now designing the systems that do the work." />
  <style>
    :root {
      --paper: #f6f3ea;
      --paper-2: #efe9db;
      --ink: #181512;
      --ink-soft: #46403a;
      --ink-faint: #847b6e;
      --rule: #ded6c6;
      --rule-strong: #b7ac96;
      --accent: #98372a;
      --accent-soft: #bc6552;
      --accent-wash: rgba(152,55,42,0.07);
      --serif: 'Instrument Serif', Georgia, 'Times New Roman', serif;
      --sans: 'Inter', system-ui, -apple-system, sans-serif;
      --mono: 'JetBrains Mono', ui-monospace, 'SFMono-Regular', monospace;
      --gutter: clamp(20px, 5vw, 76px);
      /* baseline rhythm: a single line unit drives vertical spacing */
      --baseline: 8px;
      --space-1: var(--baseline);            /* 8 */
      --space-2: calc(var(--baseline) * 2);  /* 16 */
      --space-3: calc(var(--baseline) * 3);  /* 24 */
      --space-4: calc(var(--baseline) * 4);  /* 32 */
      --space-6: calc(var(--baseline) * 6);  /* 48 */
      --maxw: 1320px;
    }

    * { box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
    @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }

    body {
      margin: 0;
      background: var(--paper);
      color: var(--ink);
      font-family: var(--sans);
      font-size: 17px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      font-feature-settings: "kern" 1, "liga" 1, "calt" 1;
    }

    /* paper grain, very subtle */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      background-image:
        radial-gradient(circle at 18% 22%, rgba(0,0,0,0.016) 0.6px, transparent 0.6px),
        radial-gradient(circle at 72% 64%, rgba(0,0,0,0.013) 0.6px, transparent 0.6px);
      background-size: 4px 4px, 5px 5px;
      mix-blend-mode: multiply;
    }

    a { color: inherit; }
    ::selection { background: var(--accent); color: var(--paper); }

    .wrap {
      max-width: var(--maxw);
      margin: 0 auto;
      padding: 0 var(--gutter);
      position: relative;
      z-index: 2;
    }

    .serif-num { font-family: var(--serif); font-variant-numeric: oldstyle-nums; }

    /* ============ MASTHEAD ============ */
    /* Reframed from a named publication to a personal dossier folio.
       The name IS the masthead; the line beneath states what this is. */
    .masthead {
      border-bottom: 3px double var(--ink);
      padding-top: var(--space-3);
    }
    .masthead-top {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 16px;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--ink-soft);
      padding-bottom: var(--space-1);
      border-bottom: 1px solid var(--rule);
    }
    .masthead-top .iss { font-weight: 500; }
    .masthead-top .folio { color: var(--ink-faint); }
    .masthead-title {
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(56px, 14vw, 188px);
      line-height: 0.86;
      letter-spacing: -0.025em;
      margin: 0;
      text-align: center;
      padding: clamp(10px, 1.6vw, 22px) 0 clamp(6px, 1vw, 12px);
      text-indent: -0.02em;
    }
    .masthead-title .dot { color: var(--accent); }
    .masthead-sub {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 14px;
      flex-wrap: wrap;
      text-align: center;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--ink-faint);
      padding: var(--space-1) 0 var(--space-2);
      border-top: 1px solid var(--rule);
    }
    .masthead-sub b { color: var(--ink); font-weight: 500; }

    /* ============ NAV ============ */
    nav.editorial {
      position: sticky;
      top: 0;
      z-index: 30;
      background: rgba(246,243,234,0.93);
      backdrop-filter: saturate(120%) blur(6px);
      border-bottom: 1px solid var(--ink);
      box-shadow: 0 1px 0 var(--rule);
    }
    .nav-inner {
      max-width: var(--maxw);
      margin: 0 auto;
      padding: 0 var(--gutter);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      min-height: 48px;
    }
    .nav-brand {
      display: flex;
      align-items: center;
      gap: 9px;
      font-family: var(--serif);
      font-size: 22px;
      letter-spacing: 0.01em;
      white-space: nowrap;
      text-decoration: none;
    }
    .nav-brand .mark {
      width: 26px; height: 26px;
      display: grid; place-items: center;
      background: var(--ink);
      color: var(--paper);
      font-family: var(--serif);
      font-size: 16px;
      line-height: 1;
    }
    .nav-links {
      display: flex;
      gap: 17px;
      list-style: none;
      margin: 0; padding: 0;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .nav-links a {
      text-decoration: none;
      color: var(--ink-soft);
      white-space: nowrap;
      padding: 4px 0;
      border-bottom: 1px solid transparent;
    }
    .nav-links a:hover { color: var(--accent); border-bottom-color: var(--accent); }
    .nav-right { display: flex; align-items: center; gap: 14px; }
    .lang-switch {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      color: var(--ink-faint);
      white-space: nowrap;
    }
    .lang-switch b { color: var(--ink); font-weight: 700; }
    .nav-cta {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--paper);
      background: var(--accent);
      padding: 7px 14px;
      white-space: nowrap;
    }
    .nav-cta:hover { background: var(--ink); }
    .nav-toggle {
      display: none;
      font-family: var(--mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      background: none;
      border: 1px solid var(--ink);
      color: var(--ink);
      padding: 6px 11px;
      cursor: pointer;
    }

    /* ============ SECTION SHELL ============ */
    section { padding: clamp(52px, 7.5vw, 104px) 0; border-bottom: 1px solid var(--rule); }
    .kicker {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-bottom: var(--space-2);
    }
    .kicker::before {
      content: '';
      width: 30px; height: 1px;
      background: var(--accent);
    }
    h2.feature {
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(36px, 6.4vw, 76px);
      line-height: 0.96;
      letter-spacing: -0.018em;
      margin: 0 0 0.36em;
      text-wrap: balance;
    }
    .feature em { font-style: italic; color: var(--accent); }
    .deck {
      font-size: clamp(16px, 2vw, 19.5px);
      color: var(--ink-soft);
      max-width: 58ch;
      line-height: 1.56;
    }

    /* ============ HERO ============ */
    .hero { padding-top: clamp(38px, 5.5vw, 64px); }
    .hero-eyebrow {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink-faint);
      margin-bottom: var(--space-3);
      display: flex; gap: 14px; flex-wrap: wrap; align-items: center;
    }
    .hero-eyebrow .dash { width: 26px; height: 1px; background: var(--rule-strong); display: inline-block; }
    .hero-grid {
      display: grid;
      grid-template-columns: 1.62fr 1fr;
      gap: clamp(30px, 5vw, 72px);
      align-items: start;
    }
    .hero-headline {
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(50px, 9.6vw, 138px);
      line-height: 0.88;
      letter-spacing: -0.022em;
      margin: 0 0 0.3em;
      text-wrap: balance;
    }
    .hero-headline em { font-style: italic; color: var(--accent); }

    /* Drop cap + single measured column (not newspaper two-up). */
    .hero-lead {
      font-size: clamp(17px, 1.85vw, 20px);
      line-height: 1.62;
      color: var(--ink);
      max-width: 62ch;
    }
    .hero-lead::first-letter {
      font-family: var(--serif);
      font-size: 3.5em;
      line-height: 0.7;
      float: left;
      padding: 10px 14px 0 0;
      color: var(--accent);
    }
    .hero-cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: var(--space-4);
    }
    .btn {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 13px 21px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .btn .ar { transition: transform 0.2s ease; }
    .btn-solid { background: var(--ink); color: var(--paper); }
    .btn-solid:hover { background: var(--accent); }
    .btn-ghost { border: 1px solid var(--ink); color: var(--ink); }
    .btn-ghost:hover { background: var(--ink); color: var(--paper); }

    /* hero aside: the "instrument" card replaces the empty Fig.1 glyph */
    .hero-aside {
      border-left: 1px solid var(--rule-strong);
      padding-left: clamp(22px, 3vw, 40px);
    }
    .panel {
      border: 1px solid var(--ink);
      background:
        linear-gradient(180deg, var(--paper-2), var(--paper));
    }
    .panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      background: var(--ink);
      color: var(--paper);
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 7px 11px;
    }
    .panel-head .dotrow { display: inline-flex; gap: 5px; }
    .panel-head .dotrow i { width: 7px; height: 7px; border: 1px solid rgba(246,243,234,0.55); border-radius: 50%; display: inline-block; }
    .panel-head .dotrow i.live { background: var(--accent-soft); border-color: var(--accent-soft); }
    .panel-body { padding: 14px 14px 16px; }
    .panel-line {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 10px;
      font-family: var(--mono);
      font-size: 11.5px;
      line-height: 1.5;
      color: var(--ink-soft);
      padding: 6px 0;
      border-bottom: 1px dotted var(--rule-strong);
    }
    .panel-line:last-child { border-bottom: 0; }
    .panel-line .lk { color: var(--accent); white-space: nowrap; }
    .panel-line .lv b { color: var(--ink); font-weight: 500; }
    .panel-cap {
      font-family: var(--mono);
      font-size: 10.5px;
      letter-spacing: 0.04em;
      color: var(--ink-faint);
      margin-top: 10px;
      line-height: 1.45;
    }
    .stats {
      display: grid;
      grid-template-columns: 1fr;
      margin-top: var(--space-3);
      border-top: 1px solid var(--rule);
    }
    .stat {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 14px;
      padding: 13px 0;
      border-bottom: 1px solid var(--rule);
    }
    .stat-val {
      font-family: var(--serif);
      font-variant-numeric: oldstyle-nums;
      font-size: 40px;
      line-height: 1;
      color: var(--accent);
    }
    .stat-label {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--ink-soft);
      text-align: right;
      max-width: 18ch;
    }

    /* ============ WORKFLOW (pull-quote spread + marginalia) ============ */
    .wf-grid {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: clamp(30px, 5vw, 64px);
      align-items: start;
    }
    .marginal {
      font-family: var(--mono);
      font-size: 11px;
      line-height: 1.55;
      letter-spacing: 0.02em;
      color: var(--ink-faint);
      border-left: 2px solid var(--accent-soft);
      padding-left: 12px;
      margin: var(--space-3) 0 0;
      max-width: 34ch;
    }
    .marginal b { color: var(--ink-soft); font-weight: 600; }
    .pullquote {
      font-family: var(--serif);
      font-size: clamp(27px, 3.5vw, 42px);
      line-height: 1.14;
      color: var(--ink);
      border-top: 3px solid var(--accent);
      border-bottom: 1px solid var(--rule);
      padding: var(--space-3) 0;
      position: relative;
      text-wrap: balance;
    }
    .pullquote::before {
      content: '\201C';
      font-family: var(--serif);
      position: absolute;
      top: 2px; left: -0.5ch;
      color: var(--accent-soft);
      opacity: 0.4;
      font-size: 1.4em;
      line-height: 1;
    }
    .wf-stages {
      list-style: none;
      margin: var(--space-3) 0 0;
      padding: 0;
    }
    .wf-stages li {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 16px;
      padding: var(--space-2) 0;
      border-bottom: 1px solid var(--rule);
    }
    .wf-num {
      font-family: var(--serif);
      font-variant-numeric: oldstyle-nums;
      font-size: 32px;
      color: var(--accent-soft);
      line-height: 0.9;
    }
    .wf-stage-name {
      font-family: var(--sans);
      font-weight: 600;
      font-size: 15px;
      letter-spacing: 0.01em;
      margin-bottom: 3px;
    }
    .wf-stage-desc { font-size: 14.5px; color: var(--ink-soft); line-height: 1.5; }

    /* ============ CASE STUDIES (real 2-col grid; DOM = visual = numeric) ============ */
    .work-head { display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 20px; margin-bottom: var(--space-1); }
    .work-meta { font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-faint); }
    .cases {
      margin-top: var(--space-4);
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      column-gap: clamp(30px, 4vw, 60px);
      row-gap: 0;
      border-top: 1px solid var(--ink);
    }
    /* vertical hairline between the two columns, redrawn intentionally */
    .case {
      position: relative;
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      padding: var(--space-3) 0 var(--space-3);
      border-bottom: 1px solid var(--rule);
    }
    .case::after {
      content: '';
      position: absolute;
      top: 0; bottom: 0;
      right: calc(-1 * clamp(15px, 2vw, 30px));
      width: 1px;
      background: var(--rule);
    }
    .cases .case:nth-child(2n)::after { display: none; }
    .case-top {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 14px;
      margin-bottom: var(--space-1);
    }
    .case-no {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .case-metric { text-align: right; }
    /* fig: a real serif number. note: a labelled badge so category words
       no longer pose as a quantified metric. */
    .case-metric-val {
      font-family: var(--serif);
      font-variant-numeric: oldstyle-nums;
      font-size: 23px;
      line-height: 1;
      color: var(--ink);
    }
    .case-metric.note .case-metric-val {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink);
      background: var(--accent-wash);
      border: 1px solid var(--rule-strong);
      padding: 3px 8px;
      display: inline-block;
    }
    .case-metric-label {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      color: var(--ink-faint);
      max-width: 24ch;
      margin-left: auto;
      line-height: 1.4;
      margin-top: 5px;
    }
    .case-title {
      font-family: var(--serif);
      font-size: clamp(23px, 2.5vw, 31px);
      line-height: 1.02;
      margin: 0 0 var(--space-1);
      color: var(--ink);
    }
    .case:hover .case-title { color: var(--accent); }
    .case-title .arrow { font-family: var(--sans); font-size: 0.58em; vertical-align: middle; color: var(--accent); }
    .case-blurb { font-size: 14.5px; color: var(--ink-soft); line-height: 1.52; margin: 0 0 var(--space-2); flex: 1; }
    .case-tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .tag {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.03em;
      color: var(--ink-soft);
      border: 1px solid var(--rule-strong);
      padding: 3px 8px;
    }

    /* ============ NOW (changelog ledger) ============ */
    .now-lead { display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap; }
    .now-grid { display: grid; grid-template-columns: 1fr; margin-top: var(--space-4); }
    .now-row {
      display: grid;
      grid-template-columns: 190px 1fr;
      gap: clamp(16px, 3vw, 46px);
      padding: var(--space-3) 0;
      border-bottom: 1px solid var(--rule);
      align-items: baseline;
    }
    .now-row:first-of-type { border-top: 1px solid var(--ink); }
    .now-key {
      font-family: var(--serif);
      font-size: clamp(23px, 2.6vw, 31px);
      color: var(--accent);
      line-height: 1;
    }
    .now-val { font-size: 15.5px; color: var(--ink); line-height: 1.56; max-width: 66ch; }
    .now-val a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent-soft); white-space: nowrap; }
    .now-val a:hover { background: var(--accent); color: var(--paper); border-color: var(--accent); }

    /* ============ CV ============ */
    .cv-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: clamp(30px, 5vw, 66px);
      margin-top: var(--space-4);
      align-items: start;
    }
    .cv-subhead {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink);
      border-bottom: 2px solid var(--ink);
      padding-bottom: 6px;
      margin: 0 0 6px;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }
    .cv-subhead .count { color: var(--ink-faint); font-size: 10px; }
    .role { padding: var(--space-2) 0; border-bottom: 1px solid var(--rule); }
    .role-head { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: baseline; gap: 8px; }
    .role-title { font-family: var(--serif); font-size: clamp(21px, 2.2vw, 27px); line-height: 1.05; }
    .role-co { color: var(--ink-soft); }
    .role-dates { font-family: var(--mono); font-size: 11px; letter-spacing: 0.04em; color: var(--ink-faint); white-space: nowrap; }
    .role-points { margin: 10px 0 0; padding: 0; list-style: none; }
    .role-points li {
      font-size: 14.5px;
      color: var(--ink-soft);
      line-height: 1.52;
      padding-left: 20px;
      position: relative;
      margin-bottom: 7px;
    }
    /* engineer's marker, not an editorial section mark */
    .role-points li::before {
      content: '\2192';
      position: absolute;
      left: 0;
      top: 0.05em;
      color: var(--accent-soft);
      font-family: var(--sans);
      font-size: 0.9em;
    }
    .cv-aside > div { margin-bottom: var(--space-4); }
    .cv-aside > div:last-child { margin-bottom: 0; }
    .edu-item { padding: 12px 0; border-bottom: 1px solid var(--rule); }
    .edu-school { font-family: var(--serif); font-size: 20px; line-height: 1.1; }
    .edu-deg { font-size: 13.5px; color: var(--ink-soft); margin: 3px 0; }
    .edu-dates { font-family: var(--mono); font-size: 11px; color: var(--ink-faint); letter-spacing: 0.04em; }
    .skill-row { padding: 9px 0; border-bottom: 1px solid var(--rule); }
    .skill-k { font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent); margin-bottom: 3px; }
    .skill-v { font-size: 13px; color: var(--ink-soft); line-height: 1.46; }
    .pub {
      border: 1px solid var(--ink);
      padding: 18px;
      background: var(--paper-2);
    }
    .pub-title { font-family: var(--serif); font-size: 21px; line-height: 1.12; margin-bottom: 8px; }
    .pub-note { font-size: 13px; color: var(--ink-soft); line-height: 1.5; margin-bottom: 12px; }
    .pub-link { font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent); }
    .pub-link:hover { background: var(--accent); color: var(--paper); }

    /* ============ READING ============ */
    .reading-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      margin-top: var(--space-4);
      border-top: 1px solid var(--ink);
    }
    .shelf-item {
      padding: var(--space-3) 18px var(--space-3) 0;
      border-right: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
    }
    .shelf-item:last-child { border-right: 0; }
    .shelf-num { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.1em; color: var(--ink-faint); margin-bottom: var(--space-1); }
    .shelf-t { font-family: var(--serif); font-size: 24px; line-height: 1.06; margin-bottom: var(--space-1); }
    .shelf-n { font-size: 13.5px; color: var(--ink-soft); line-height: 1.5; }

    /* ============ LANGUAGES ============ */
    .lang-row { display: flex; flex-wrap: wrap; gap: 0; margin-top: var(--space-4); border: 1px solid var(--ink); }
    .lang {
      flex: 1 1 16%;
      min-width: 120px;
      padding: 20px 16px;
      border-right: 1px solid var(--rule);
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .lang:last-child { border-right: 0; }
    .lang-code { font-family: var(--mono); font-size: 12px; letter-spacing: 0.1em; color: var(--accent); }
    .lang-name { font-family: var(--serif); font-size: 27px; line-height: 1; }

    /* ============ CONTACT ============ */
    .contact { position: relative; overflow: hidden; }
    .contact-water {
      position: absolute;
      right: -2vw;
      top: 50%;
      transform: translateY(-50%);
      font-family: var(--serif);
      font-size: clamp(200px, 44vw, 560px);
      line-height: 0.8;
      color: var(--rule);
      opacity: 0.5;
      pointer-events: none;
      z-index: 0;
      user-select: none;
    }
    .contact-water .dot { color: var(--accent-soft); opacity: 0.6; }
    .contact-inner { position: relative; z-index: 1; max-width: 64ch; }
    .contact h2 { margin-bottom: 0.3em; }
    .contact-body { font-size: clamp(16px, 1.8vw, 19px); color: var(--ink-soft); line-height: 1.55; max-width: 56ch; }
    .contact-cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: var(--space-4); }

    /* ============ FOOTER ============ */
    footer {
      background: var(--ink);
      color: var(--paper);
      padding: clamp(44px, 6vw, 76px) 0 30px;
      position: relative;
      z-index: 2;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: 1.6fr 1fr 1fr 1fr;
      gap: 30px;
      padding-bottom: var(--space-4);
      border-bottom: 1px solid rgba(246,243,234,0.18);
    }
    .footer-brand { display: flex; align-items: center; gap: 10px; font-family: var(--serif); font-size: 27px; }
    .footer-brand .mark {
      width: 30px; height: 30px; display: grid; place-items: center;
      border: 1px solid var(--paper); font-size: 17px; font-family: var(--serif);
    }
    .footer-tag { font-size: 14px; color: rgba(246,243,234,0.7); margin-top: 14px; max-width: 34ch; line-height: 1.5; }
    .footer-col h4 { font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(246,243,234,0.55); margin: 0 0 14px; }
    .footer-col ul { list-style: none; margin: 0; padding: 0; }
    .footer-col li { margin-bottom: 9px; }
    .footer-col a { color: rgba(246,243,234,0.86); text-decoration: none; font-size: 14px; }
    .footer-col a:hover { color: var(--accent-soft); }
    .footer-bottom {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 10px;
      padding-top: var(--space-3);
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.04em;
      color: rgba(246,243,234,0.55);
    }

    /* ============ MOBILE MENU ============ */
    .mobile-menu {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 40;
      background: var(--paper);
      padding: 80px var(--gutter) 40px;
      overflow-y: auto;
    }
    .mobile-menu.open { display: block; }
    .mobile-menu a {
      display: block;
      font-family: var(--serif);
      font-size: 34px;
      text-decoration: none;
      color: var(--ink);
      padding: 12px 0;
      border-bottom: 1px solid var(--rule);
    }
    .mobile-menu a:hover { color: var(--accent); }
    .mm-close {
      position: absolute;
      top: 18px; right: var(--gutter);
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      background: none;
      border: 1px solid var(--ink);
      padding: 8px 12px;
      cursor: pointer;
    }

    /* ============ REVEAL (motion-gated) ============ */
    @media (prefers-reduced-motion: no-preference) {
      .reveal { opacity: 0; transform: translateY(16px); transition: opacity 0.7s ease, transform 0.7s ease; }
      .reveal.in { opacity: 1; transform: none; }
      .nav-links a, .btn, .case-title, .now-val a, .footer-col a { transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease; }
      .btn:hover .ar { transform: translateX(3px); }
    }

    /* ============ RESPONSIVE ============ */
    @media (max-width: 980px) {
      .hero-grid, .wf-grid, .cv-grid { grid-template-columns: 1fr; }
      .hero-aside { border-left: 0; padding-left: 0; border-top: 1px solid var(--rule-strong); padding-top: var(--space-3); }
      .reading-grid { grid-template-columns: repeat(2, 1fr); }
      .shelf-item:nth-child(2n) { border-right: 0; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 720px) {
      .nav-links, .lang-switch { display: none; }
      .nav-toggle { display: inline-block; }
      .cases { grid-template-columns: 1fr; }
      .case::after { display: none; }
      .now-row { grid-template-columns: 1fr; gap: 8px; }
      .reading-grid { grid-template-columns: 1fr; }
      .shelf-item { border-right: 0; }
      .footer-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      body { font-size: 16px; }
      .lang { flex: 1 1 100%; min-width: 0; border-right: 0; border-bottom: 1px solid var(--rule); }
      .lang:last-child { border-bottom: 0; }
    }
  </style>
</head>
<body>
  <!-- NAV -->
  <nav class="editorial">
    <div class="nav-inner">
      <a class="nav-brand" href="/#" aria-label="Tom Scholtes home">
        <span class="mark">T</span> Tom Scholtes
      </a>
      <ul class="nav-links">
        {navItems.map((it) => (<li><a href={it.href}>{it.label}</a></li>))}
      </ul>
      <div class="nav-right">
        <span class="lang-switch"><b>EN</b> / DE / FR / RU</span>
        <a class="nav-cta" href="/#contact">Say hi</a>
        <button class="nav-toggle" id="navToggle" aria-label="Open menu">Menu</button>
      </div>
    </div>
  </nav>

  <!-- MOBILE MENU -->
  <div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Navigation">
    <button class="mm-close" id="mmClose" aria-label="Close menu">Close</button>
    {navItems.map((it) => (<a href={it.href}>{it.label}</a>))}
    <a href="/#contact">Say hi</a>
  </div>

  <div class="wrap">
    <!-- MASTHEAD: the name is the masthead, not a publication title -->
    <header class="masthead">
      <div class="masthead-top">
        <span class="iss">Finance ops engineer</span>
        <span class="folio">Luxembourg &middot; {year}</span>
      </div>
      <h1 class="masthead-title">Tom Scholtes<span class="dot">.</span></h1>
      <div class="masthead-sub">
        <span>A live CV</span>
        <span>&middot;</span>
        <span>the <b>patterns</b> behind the work</span>
        <span>&middot;</span>
        <span>case studies of it shipping</span>
      </div>
    </header>

    <!-- HERO -->
    <section class="hero" id="top">
      <div class="hero-eyebrow reveal"><span>Personal site</span><span class="dash"></span><span>I build software that does finance operations</span></div>
      <div class="hero-grid">
        <div>
          <h2 class="hero-headline reveal">I build the automation behind <em>regulated finance</em> operations.</h2>
          <p class="hero-lead reveal">I'm Tom. I build AI-augmented automation for the operational work in regulated finance: regulatory notes, accounts quality review, document workflows, mailbox triage, and the reusable tooling that ties them together. Six years in Luxembourg fund services across PE, Private Debt and Real Estate, now spent designing the systems that do the work instead of doing it by hand. This site is the evidence: a live CV, the patterns behind the work, and case studies of it shipping.</p>
          <div class="hero-cta-row reveal">
            <a class="btn btn-solid" href="#work">See the work <span class="ar">&rarr;</span></a>
            <a class="btn btn-ghost" href="#contact">Get in touch</a>
          </div>
        </div>
        <aside class="hero-aside reveal">
          <!-- replaces empty Fig.1 glyph: a real, load-bearing status panel -->
          <div class="panel" aria-label="What is running now">
            <div class="panel-head">
              <span>Currently running</span>
              <span class="dotrow"><i></i><i></i><i class="live"></i></span>
            </div>
            <div class="panel-body">
              <div class="panel-line"><span class="lk">infra</span><span class="lv">an agentic memory system across <b>two machines</b> that talk to each other</span></div>
              <div class="panel-line"><span class="lk">voice</span><span class="lv">a voice-first assistant over <b>AR glasses</b>, memory consolidating during sleep</span></div>
              <div class="panel-line"><span class="lk">agents</span><span class="lv">end-to-end email automation with a <b>self-review loop</b> and a human sign-off</span></div>
            </div>
          </div>
          <p class="panel-cap">Finance ops engineer who automates the work in reach. Based in Luxembourg. The desk runs on the same systems this site describes.</p>
          <div class="stats">
            <div class="stat"><span class="stat-val">6 yrs</span><span class="stat-label">in Lux fund services</span></div>
            <div class="stat"><span class="stat-val">9</span><span class="stat-label">case studies on file</span></div>
            <div class="stat"><span class="stat-val">6</span><span class="stat-label">languages spoken</span></div>
          </div>
        </aside>
      </div>
    </section>

    <!-- WORKFLOW AUTOMATION -->
    <section id="workflow">
      <span class="kicker reveal">Live demo</span>
      <div class="wf-grid">
        <div>
          <h2 class="feature reveal">See the automation run, on synthetic data.</h2>
          <p class="deck reveal">Point AI at the manual workflows underneath a finance desk. It surfaces what is unbooked, mismatched, or missing, builds the upload template, and drafts the counterparty email. The operator reviews and signs off; the human owns the decision. Click through a before-and-after process map and run it live.</p>
          <p class="marginal reveal"><b>On the demo.</b> Runs on synthetic data only. No employer data, no entity names, no real figures. The interesting part is the shape of the workflow, not the numbers.</p>
          <div class="hero-cta-row reveal" style="margin-top:24px;">
            <a class="btn btn-solid" href="/workflow-automation/">Open the live demo <span class="ar">&rarr;</span></a>
          </div>
        </div>
        <div class="reveal">
          <blockquote class="pullquote">The operator reviews and signs off. The human owns the decision.</blockquote>
          <ol class="wf-stages">
            {stages.map((s) => (
              <li>
                <span class="wf-num serif-num">{s.n}</span>
                <div>
                  <div class="wf-stage-name">{s.name}</div>
                  <div class="wf-stage-desc">{s.desc}</div>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <!-- CASE STUDIES -->
    <section id="work">
      <span class="kicker reveal">Case studies</span>
      <div class="work-head">
        <h2 class="feature reveal" style="margin-bottom:0;">Patterns I've worked through.</h2>
        <span class="work-meta reveal">Nine features &middot; sanitised</span>
      </div>
      <p class="deck reveal" style="margin-top:14px;">Sanitised. Employer name, entity names and figures removed. Notes on how I think about this kind of work in fund services. Read in order, 01 through 09.</p>
      <div class="cases">
        {cases.map((c) => (
          <a class="case reveal" href={c.href}>
            <div class="case-top">
              <span class="case-no">Case {c.n}</span>
              <div class={c.metricKind === 'note' ? 'case-metric note' : 'case-metric'}>
                <div class="case-metric-val">{c.metric}</div>
                <div class="case-metric-label">{c.metricLabel}</div>
              </div>
            </div>
            <h3 class="case-title">{c.title} <span class="arrow">&rarr;</span></h3>
            <p class="case-blurb">{c.blurb}</p>
            <div class="case-tags">
              {c.tags.map((t) => (<span class="tag">{t}</span>))}
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- NOW -->
    <section id="now">
      <span class="kicker reveal">/ now &middot; June {year}</span>
      <h2 class="feature reveal">What I'm focused on this quarter.</h2>
      <p class="deck reveal">A public note of where my head is right now, in the spirit of <em>nownownow.com</em>. I update it when things change, not on a schedule. Think of it as the changelog of a working mind.</p>
      <div class="now-grid">
        {nowRows.map((r) => (
          <div class="now-row reveal">
            <div class="now-key">{r.k}</div>
            <div class="now-val">
              {r.v}{r.cta && (<>{' '}<a href={r.cta.href}>{r.cta.label} &rarr;</a></>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- CV -->
    <section id="cv">
