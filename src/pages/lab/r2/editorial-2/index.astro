---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Tom Scholtes. Finance ops engineer who automates the work in reach.</title>
  <meta name="description" content="Personal site, live CV, and a portfolio of automation built for regulated finance operations. Six years in Luxembourg fund services, now designing the systems that do the work." />
  <style>
    :root {
      --paper: #f7f4ec;
      --paper-2: #f1ece0;
      --ink: #1a1714;
      --ink-soft: #4a443c;
      --ink-faint: #8a8174;
      --rule: #d8d0c0;
      --rule-strong: #b8ad97;
      --accent: #9c3b2e;
      --accent-soft: #c06b56;
      --ok: #3d6b4a;
      --serif: 'Instrument Serif', Georgia, 'Times New Roman', serif;
      --sans: 'Inter', system-ui, -apple-system, sans-serif;
      --mono: 'JetBrains Mono', ui-monospace, 'SFMono-Regular', monospace;
      --gutter: clamp(20px, 5vw, 72px);
    }

    * { box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }

    body {
      margin: 0;
      background: var(--paper);
      color: var(--ink);
      font-family: var(--sans);
      font-size: 17px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    /* faint engineering grid: blueprint, not paper texture */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      background-image:
        linear-gradient(rgba(26,23,20,0.022) 1px, transparent 1px),
        linear-gradient(90deg, rgba(26,23,20,0.022) 1px, transparent 1px);
      background-size: 46px 46px, 46px 46px;
    }

    a { color: inherit; }

    .wrap {
      max-width: 1340px;
      margin: 0 auto;
      padding: 0 var(--gutter);
      position: relative;
      z-index: 2;
    }

    /* ============ NAV ============ */
    nav.editorial {
      position: sticky;
      top: 0;
      z-index: 30;
      background: var(--paper);
      border-bottom: 1px solid var(--ink);
    }
    .nav-inner {
      max-width: 1340px;
      margin: 0 auto;
      padding: 0 var(--gutter);
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 50px;
      gap: 16px;
    }
    .nav-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      font-family: var(--mono);
      font-weight: 500;
      font-size: 13px;
      letter-spacing: 0.02em;
      white-space: nowrap;
      text-decoration: none;
    }
    .nav-brand .mark {
      font-family: var(--mono);
      font-weight: 700;
      width: 26px; height: 26px;
      display: grid; place-items: center;
      border: 1px solid var(--ink);
      background: var(--ink);
      color: var(--paper);
      font-size: 13px;
      line-height: 1;
    }
    .nav-links {
      display: flex;
      gap: 20px;
      list-style: none;
      margin: 0; padding: 0;
      font-family: var(--mono);
      font-size: 11.5px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .nav-links a {
      text-decoration: none;
      color: var(--ink-soft);
      white-space: nowrap;
      padding: 4px 0;
      border-bottom: 1px solid transparent;
    }
    .nav-links a:hover { color: var(--accent); border-bottom-color: var(--accent); }
    .nav-right { display: flex; align-items: center; gap: 14px; }
    .lang-switch {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.1em;
      color: var(--ink-faint);
      white-space: nowrap;
    }
    .lang-switch b { color: var(--ink); font-weight: 700; }
    .nav-cta {
      font-family: var(--mono);
      font-size: 11.5px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--paper);
      background: var(--accent);
      padding: 8px 14px;
      white-space: nowrap;
    }
    .nav-cta:hover { background: var(--ink); }
    .nav-toggle {
      display: none;
      font-family: var(--mono);
      font-size: 11.5px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      background: none;
      border: 1px solid var(--ink);
      color: var(--ink);
      padding: 7px 11px;
      cursor: pointer;
    }

    /* ============ SPEC HEADER (reframed masthead) ============ */
    .spec {
      border-bottom: 2px solid var(--ink);
      padding: 22px 0 0;
    }
    .spec-bar {
      display: flex;
      flex-wrap: wrap;
      gap: 0;
      border: 1px solid var(--rule-strong);
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.04em;
      margin-bottom: 18px;
    }
    .spec-cell {
      flex: 1 1 auto;
      min-width: 130px;
      padding: 8px 12px;
      border-right: 1px solid var(--rule);
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .spec-cell:last-child { border-right: 0; }
    .spec-cell .sk { color: var(--ink-faint); text-transform: uppercase; letter-spacing: 0.12em; }
    .spec-cell .sv { color: var(--ink); font-weight: 500; }
    .spec-cell .sv.live { color: var(--ok); display: inline-flex; align-items: center; gap: 7px; }
    .spec-cell .sv.live::before {
      content: '';
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--ok);
    }
    .spec-title {
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(34px, 7.5vw, 96px);
      line-height: 0.94;
      letter-spacing: -0.012em;
      margin: 6px 0 14px;
    }
    .spec-title em { font-style: italic; color: var(--accent); }
    .spec-sub {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.04em;
      color: var(--ink-soft);
      padding-bottom: 16px;
    }

    /* ============ SECTION SHELL ============ */
    section { padding: clamp(48px, 7vw, 96px) 0; border-bottom: 1px solid var(--rule); }
    .kicker {
      font-family: var(--mono);
      font-size: 11.5px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent);
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 18px;
    }
    .kicker::before {
      content: '';
      width: 26px; height: 1px;
      background: var(--accent);
    }
    h2.feature {
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(34px, 6vw, 66px);
      line-height: 0.98;
      letter-spacing: -0.01em;
      margin: 0 0 0.4em;
    }
    .feature em { font-style: italic; color: var(--accent); }
    .deck {
      font-size: clamp(16px, 2vw, 19px);
      color: var(--ink-soft);
      max-width: 60ch;
      line-height: 1.55;
    }

    /* ============ HERO ============ */
    .hero { padding-top: clamp(30px, 5vw, 52px); }
    .hero-grid {
      display: grid;
      grid-template-columns: 1.65fr 1fr;
      gap: clamp(28px, 5vw, 60px);
      align-items: start;
    }
    .hero-headline {
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(44px, 8.4vw, 116px);
      line-height: 0.9;
      letter-spacing: -0.015em;
      margin: 0 0 0.34em;
    }
    .hero-headline em { font-style: italic; color: var(--accent); }
    .hero-lead {
      font-size: clamp(16px, 1.7vw, 19px);
      line-height: 1.62;
      color: var(--ink);
      max-width: 62ch;
    }
    .hero-cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: 28px;
    }
    .btn {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 12px 20px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .btn-solid { background: var(--ink); color: var(--paper); }
    .btn-solid:hover { background: var(--accent); }
    .btn-ghost { border: 1px solid var(--ink); color: var(--ink); }
    .btn-ghost:hover { background: var(--ink); color: var(--paper); }

    /* hero sidebar: a real system diagram, not an empty glyph */
    .hero-aside {
      border-left: 1px solid var(--rule-strong);
      padding-left: clamp(20px, 3vw, 36px);
    }
    .diagram {
      border: 1px solid var(--ink);
      background: var(--paper-2);
      position: relative;
    }
    .diagram-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink-soft);
      padding: 9px 12px;
      border-bottom: 1px solid var(--rule-strong);
    }
    .diagram-svg { display: block; width: 100%; height: auto; }
    .diagram-svg text {
      font-family: var(--mono);
      fill: var(--ink);
    }
    .diagram-svg .dlabel { font-size: 10px; letter-spacing: 0.04em; }
    .diagram-svg .dsub { font-size: 8px; fill: var(--ink-faint); }
    .diagram-svg .dnode { fill: var(--paper); stroke: var(--ink); stroke-width: 1; }
    .diagram-svg .dnode.acc { fill: #efe2dd; stroke: var(--accent); }
    .diagram-svg .dflow { stroke: var(--rule-strong); stroke-width: 1; fill: none; }
    .diagram-svg .dflow.acc { stroke: var(--accent); stroke-dasharray: 3 3; }
    .figcaption {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.02em;
      color: var(--ink-faint);
      margin-top: 10px;
      line-height: 1.45;
    }

    /* stats as a mono data table */
    .stats {
      margin-top: 22px;
      border-top: 1px solid var(--ink);
    }
    .stat {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 14px;
      padding: 11px 0;
      border-bottom: 1px solid var(--rule);
    }
    .stat-val {
      font-family: var(--serif);
      font-size: 36px;
      line-height: 1;
      color: var(--accent);
    }
    .stat-label {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      color: var(--ink-soft);
      text-align: right;
      max-width: 18ch;
    }

    /* ============ WORKFLOW ============ */
    .wf-grid {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: clamp(28px, 5vw, 56px);
      align-items: start;
    }
    .pullquote {
      font-family: var(--serif);
      font-size: clamp(25px, 3.2vw, 38px);
      line-height: 1.16;
      color: var(--ink);
      border-top: 3px solid var(--accent);
      border-bottom: 1px solid var(--rule);
      padding: 22px 0;
    }
    .wf-stages {
      list-style: none;
      margin: 26px 0 0;
      padding: 0;
    }
    .wf-stages li {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 16px;
      padding: 16px 0;
      border-bottom: 1px solid var(--rule);
    }
    .wf-num {
      font-family: var(--mono);
      font-weight: 700;
      font-size: 14px;
      color: var(--accent);
      line-height: 1;
      padding-top: 3px;
      width: 2.4ch;
    }
    .wf-num::before { content: 'S'; color: var(--ink-faint); }
    .wf-stage-name {
      font-family: var(--sans);
      font-weight: 600;
      font-size: 15px;
      letter-spacing: 0.02em;
      margin-bottom: 3px;
    }
    .wf-stage-desc { font-size: 14.5px; color: var(--ink-soft); line-height: 1.5; }

    /* ============ CASE STUDIES (true 2-col grid; DOM order = numeric order) ============ */
    .work-head { display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 20px; margin-bottom: 8px; }
    .work-meta { font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-faint); }
    .cases {
      margin-top: 30px;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      column-gap: clamp(28px, 4vw, 56px);
      row-gap: 0;
      border-top: 1px solid var(--ink);
    }
    .case {
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      padding: 22px 0 24px;
      border-bottom: 1px solid var(--rule);
    }
    /* close the bottom rule on the final row */
    .case:nth-last-child(1), .case:nth-last-child(2):nth-child(odd) { border-bottom: 0; }
    .case-top {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 14px;
      margin-bottom: 12px;
    }
    .case-id {
      display: inline-flex;
      align-items: baseline;
      gap: 8px;
      font-family: var(--mono);
      font-size: 11.5px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .case-kind {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--ink-faint);
      border: 1px solid var(--rule-strong);
      padding: 1px 7px;
    }
    .case-metric { text-align: right; min-width: 0; }
    .case-metric-val {
      font-family: var(--mono);
      font-weight: 500;
      font-size: 13px;
      letter-spacing: 0.02em;
      line-height: 1;
      color: var(--ink);
    }
    .case-metric-label {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.02em;
      color: var(--ink-faint);
      max-width: 24ch;
      margin-left: auto;
      line-height: 1.4;
      margin-top: 5px;
    }
    .case-title {
      font-family: var(--serif);
      font-size: clamp(22px, 2.4vw, 30px);
      line-height: 1.05;
      margin: 0 0 9px;
      color: var(--ink);
    }
    .case:hover .case-title { color: var(--accent); }
    .case-title .arrow { font-family: var(--sans); font-size: 0.58em; vertical-align: middle; }
    .case-blurb { font-size: 14.5px; color: var(--ink-soft); line-height: 1.52; margin: 0 0 14px; flex: 1 1 auto; }
    .case-tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .tag {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.02em;
      color: var(--ink-soft);
      border: 1px solid var(--rule-strong);
      padding: 3px 8px;
    }

    /* ============ NOW (changelog ledger) ============ */
    .now-grid { display: grid; grid-template-columns: 1fr; border-top: 1px solid var(--ink); }
    .now-row {
      display: grid;
      grid-template-columns: 170px 1fr;
      gap: clamp(16px, 3vw, 40px);
      padding: 20px 0;
      border-bottom: 1px solid var(--rule);
      align-items: baseline;
    }
    .now-key {
      font-family: var(--mono);
      font-weight: 500;
      font-size: 13px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--accent);
      line-height: 1.4;
    }
    .now-key::before { content: '> '; color: var(--ink-faint); }
    .now-val { font-size: 15.5px; color: var(--ink); line-height: 1.55; max-width: 66ch; }
    .now-val a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent-soft); white-space: nowrap; }
    .now-val a:hover { background: var(--accent); color: var(--paper); border-color: var(--accent); }

    /* ============ CV (spec sheet) ============ */
    .cv-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: clamp(28px, 5vw, 60px);
      margin-top: 32px;
      align-items: start;
    }
    .cv-subhead {
      font-family: var(--mono);
      font-size: 11.5px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink);
      border-bottom: 2px solid var(--ink);
      padding-bottom: 6px;
      margin: 0 0 4px;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }
    .cv-subhead .count { color: var(--ink-faint); font-size: 11px; letter-spacing: 0.04em; }
    .role { padding: 18px 0; border-bottom: 1px solid var(--rule); }
    .role-head { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: baseline; gap: 8px; }
    .role-title { font-family: var(--serif); font-size: clamp(20px, 2.2vw, 26px); line-height: 1.05; }
    .role-co { color: var(--ink-soft); }
    .role-dates { font-family: var(--mono); font-size: 11px; letter-spacing: 0.03em; color: var(--ink-faint); white-space: nowrap; }
    .role-points { margin: 10px 0 0; padding: 0; list-style: none; }
    .role-points li {
      font-size: 14.5px;
      color: var(--ink-soft);
      line-height: 1.52;
      padding-left: 20px;
      position: relative;
      margin-bottom: 7px;
    }
    .role-points li::before {
      content: '·';
      position: absolute;
      left: 4px;
      top: -0.05em;
      color: var(--accent);
      font-family: var(--mono);
      font-weight: 700;
    }
    .cv-aside > div { margin-bottom: 30px; }

    /* skills as a real mono key/value table */
    .skill-table { border-top: 1px solid var(--ink); }
    .skill-row {
      display: grid;
      grid-template-columns: minmax(0,0.9fr) minmax(0,1.6fr);
      gap: 12px;
      padding: 9px 0;
      border-bottom: 1px solid var(--rule);
      align-items: baseline;
    }
    .skill-k { font-family: var(--mono); font-size: 11px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--accent); }
    .skill-v { font-size: 13px; color: var(--ink-soft); line-height: 1.45; }
    .edu-item { padding: 12px 0; border-bottom: 1px solid var(--rule); }
    .edu-school { font-family: var(--serif); font-size: 19px; line-height: 1.1; }
    .edu-deg { font-size: 13.5px; color: var(--ink-soft); margin: 3px 0; }
    .edu-dates { font-family: var(--mono); font-size: 11px; color: var(--ink-faint); letter-spacing: 0.03em; }
    .pub {
      border: 1px solid var(--ink);
      padding: 18px;
      background: var(--paper-2);
    }
    .pub-title { font-family: var(--serif); font-size: 20px; line-height: 1.12; margin-bottom: 8px; }
    .pub-note { font-size: 13px; color: var(--ink-soft); line-height: 1.5; margin-bottom: 12px; }
    .pub-link { font-family: var(--mono); font-size: 11.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent); }
    .pub-link:hover { background: var(--accent); color: var(--paper); }

    /* ============ READING ============ */
    .reading-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      margin-top: 32px;
      border-top: 1px solid var(--ink);
    }
    .shelf-item {
      padding: 22px 18px 22px 0;
      border-right: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
    }
    .shelf-item:last-child { border-right: 0; }
    .shelf-num { font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; color: var(--ink-faint); margin-bottom: 8px; }
    .shelf-t { font-family: var(--serif); font-size: 23px; line-height: 1.06; margin-bottom: 8px; }
    .shelf-n { font-size: 13.5px; color: var(--ink-soft); line-height: 1.5; }

    /* ============ LANGUAGES ============ */
    .lang-row { display: flex; flex-wrap: wrap; gap: 0; margin-top: 30px; border: 1px solid var(--ink); }
    .lang {
      flex: 1 1 16%;
      min-width: 120px;
      padding: 20px 16px;
      border-right: 1px solid var(--rule);
      display: flex;
      flex-direction: column;
      gap: 5px;
    }
    .lang:last-child { border-right: 0; }
    .lang-code { font-family: var(--mono); font-size: 12px; letter-spacing: 0.08em; color: var(--accent); }
    .lang-name { font-family: var(--serif); font-size: 26px; line-height: 1; }

    /* ============ CONTACT ============ */
    .contact { position: relative; overflow: hidden; }
    .contact-water {
      position: absolute;
      right: -1vw;
      top: 50%;
      transform: translateY(-50%);
      font-family: var(--serif);
      font-size: clamp(180px, 40vw, 520px);
      line-height: 0.8;
      color: var(--rule);
      opacity: 0.5;
      pointer-events: none;
      z-index: 0;
      user-select: none;
    }
    .contact-inner { position: relative; z-index: 1; max-width: 64ch; }
    .contact h2 { margin-bottom: 0.3em; }
    .contact-body { font-size: clamp(16px, 1.8vw, 19px); color: var(--ink-soft); line-height: 1.55; max-width: 58ch; }
    .contact-cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 30px; }

    /* ============ FOOTER ============ */
    footer {
      background: var(--ink);
      color: var(--paper);
      padding: clamp(40px, 6vw, 72px) 0 30px;
      position: relative;
      z-index: 2;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: 1.6fr 1fr 1fr 1fr;
      gap: 30px;
      padding-bottom: 36px;
      border-bottom: 1px solid rgba(247,244,236,0.18);
    }
    .footer-brand { display: flex; align-items: center; gap: 10px; font-family: var(--mono); font-weight: 500; font-size: 15px; }
    .footer-brand .mark {
      width: 28px; height: 28px; display: grid; place-items: center;
      border: 1px solid var(--paper); font-size: 13px; font-weight: 700;
    }
    .footer-tag { font-size: 14px; color: rgba(247,244,236,0.7); margin-top: 14px; max-width: 34ch; line-height: 1.5; }
    .footer-col h4 { font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(247,244,236,0.55); margin: 0 0 14px; }
    .footer-col ul { list-style: none; margin: 0; padding: 0; }
    .footer-col li { margin-bottom: 9px; }
    .footer-col a { color: rgba(247,244,236,0.86); text-decoration: none; font-size: 14px; }
    .footer-col a:hover { color: var(--accent-soft); }
    .footer-bottom {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 10px;
      padding-top: 22px;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.03em;
      color: rgba(247,244,236,0.55);
    }

    /* ============ MOBILE MENU ============ */
    .mobile-menu {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 40;
      background: var(--paper);
      padding: 80px var(--gutter) 40px;
      overflow-y: auto;
    }
    .mobile-menu.open { display: block; }
    .mobile-menu a {
      display: block;
      font-family: var(--serif);
      font-size: 34px;
      text-decoration: none;
      color: var(--ink);
      padding: 12px 0;
      border-bottom: 1px solid var(--rule);
    }
    .mobile-menu a:hover { color: var(--accent); }
    .mm-close {
      position: absolute;
      top: 18px; right: var(--gutter);
      font-family: var(--mono);
      font-size: 11.5px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      background: none;
      border: 1px solid var(--ink);
      padding: 8px 12px;
      cursor: pointer;
    }

    /* ============ REVEAL ============ */
    @media (prefers-reduced-motion: no-preference) {
      .reveal { opacity: 0; transform: translateY(14px); transition: opacity 0.6s ease, transform 0.6s ease; }
      .reveal.in { opacity: 1; transform: none; }
      .nav-links a, .btn, .case-title, .now-val a, .footer-col a, .spec-cell .sv.live::before {
        transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
      }
    }

    /* ============ RESPONSIVE ============ */
    @media (max-width: 980px) {
      .hero-grid, .wf-grid, .cv-grid { grid-template-columns: 1fr; }
      .hero-aside { border-left: 0; padding-left: 0; border-top: 1px solid var(--rule-strong); padding-top: 24px; }
      .reading-grid { grid-template-columns: repeat(2, 1fr); }
      .shelf-item:nth-child(2n) { border-right: 0; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 720px) {
      .nav-links, .lang-switch { display: none; }
      .nav-toggle { display: inline-block; }
      .cases { grid-template-columns: 1fr; }
      .case { border-bottom: 1px solid var(--rule); }
      .case:last-child { border-bottom: 0; }
      .now-row { grid-template-columns: 1fr; gap: 6px; }
      .skill-row { grid-template-columns: 1fr; gap: 2px; }
      .reading-grid { grid-template-columns: 1fr; }
      .shelf-item { border-right: 0; }
      .footer-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      body { font-size: 16px; }
      .spec-cell { min-width: 50%; border-bottom: 1px solid var(--rule); }
      .lang { flex: 1 1 100%; min-width: 0; border-right: 0; border-bottom: 1px solid var(--rule); }
      .lang:last-child { border-bottom: 0; }
    }
  </style>
</head>
<body>
  <!-- NAV -->
  <nav class="editorial">
    <div class="nav-inner">
      <a class="nav-brand" href="/#top" aria-label="Tom Scholtes home">
        <span class="mark">T</span> tomscholtes.com
      </a>
      <ul class="nav-links">
        {navItems.map((it) => (<li><a href={it.href}>{it.label}</a></li>))}
      </ul>
      <div class="nav-right">
        <span class="lang-switch"><b>EN</b> / DE / FR / RU</span>
        <a class="nav-cta" href="/#contact">Say hi</a>
        <button class="nav-toggle" id="navToggle" aria-label="Open menu">Menu</button>
      </div>
    </div>
  </nav>

  <!-- MOBILE MENU -->
  <div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Navigation">
    <button class="mm-close" id="mmClose" aria-label="Close menu">Close</button>
    {navItems.map((it) => (<a href={it.href}>{it.label}</a>))}
    <a href="/#contact">Say hi</a>
  </div>

  <div class="wrap">
    <!-- SPEC HEADER -->
    <header class="spec" id="top">
      <div class="spec-bar">
        {specFields.map((f) => (
          <div class="spec-cell">
            <span class="sk">{f.k}</span>
            <span class={f.k === 'status' ? 'sv live' : 'sv'}>{f.v}</span>
          </div>
        ))}
      </div>
      <h1 class="spec-title">Finance ops <em>engineer</em>.</h1>
      <div class="spec-sub">A live CV, the patterns behind the work, and case studies of it shipping.</div>
    </header>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-grid">
        <div>
          <h2 class="hero-headline reveal">I build the automation behind <em>regulated finance</em> operations.</h2>
          <p class="hero-lead reveal">I'm Tom. I build AI-augmented automation for the operational work in regulated finance: regulatory notes, accounts quality review, document workflows, mailbox triage, and the reusable tooling that ties them together. Six years in Luxembourg fund services across PE, Private Debt and Real Estate, now spent designing the systems that do the work instead of doing it by hand. This site is the evidence: a live CV, the patterns behind the work, and case studies of it shipping.</p>
          <div class="hero-cta-row reveal">
            <a class="btn btn-solid" href="#work">See the work</a>
            <a class="btn btn-ghost" href="#contact">Get in touch</a>
          </div>
        </div>
        <aside class="hero-aside reveal">
          <figure class="diagram" aria-label="Schematic of the human-in-the-loop automation pattern: find, build, sign off, scale.">
            <div class="diagram-head"><span>fig.01 / pattern</span><span>v.{year}</span></div>
            <svg class="diagram-svg" viewBox="0 0 260 230" role="img" aria-hidden="true">
              <!-- flows -->
              <path class="dflow" d="M130 46 L130 70" />
              <path class="dflow" d="M130 106 L130 130" />
              <path class="dflow acc" d="M130 166 L130 190" />
              <!-- node: source -->
              <rect class="dnode" x="60" y="20" width="140" height="26" />
              <text class="dlabel" x="130" y="37" text-anchor="middle">source files</text>
              <!-- node: find -->
              <rect class="dnode" x="40" y="70" width="180" height="36" />
              <text class="dlabel" x="130" y="86" text-anchor="middle">find . build</text>
              <text class="dsub" x="130" y="98" text-anchor="middle">agent reads, surfaces, drafts</text>
              <!-- node: sign off (human) -->
              <rect class="dnode acc" x="40" y="130" width="180" height="36" />
              <text class="dlabel" x="130" y="146" text-anchor="middle">sign off</text>
              <text class="dsub" x="130" y="158" text-anchor="middle">human owns the decision</text>
              <!-- node: scale -->
              <rect class="dnode" x="60" y="190" width="140" height="26" />
              <text class="dlabel" x="130" y="207" text-anchor="middle">scale</text>
            </svg>
          </figure>
          <p class="figcaption">The pattern under every case: the agent does the reaching; a human signs off and owns the decision.</p>
          <div class="stats">
            <div class="stat"><span class="stat-val">6 yrs</span><span class="stat-label">in Lux fund services</span></div>
            <div class="stat"><span class="stat-val">9</span><span class="stat-label">case studies on file</span></div>
            <div class="stat"><span class="stat-val">6</span><span class="stat-label">languages spoken</span></div>
          </div>
        </aside>
      </div>
    </section>

    <!-- WORKFLOW AUTOMATION -->
    <section id="workflow">
      <span class="kicker reveal">Live demo</span>
      <div class="wf-grid">
        <div>
          <h2 class="feature reveal">See the automation run, on synthetic data.</h2>
          <p class="deck reveal">Point AI at the manual workflows underneath a finance desk. It surfaces what is unbooked, mismatched, or missing, builds the upload template, and drafts the counterparty email. The operator reviews and signs off; the human owns the decision. Click through a before-and-after process map and run it live.</p>
          <div class="hero-cta-row reveal" style="margin-top:22px;">
            <a class="btn btn-solid" href="/workflow-automation/">Open the live demo</a>
          </div>
        </div>
        <div class="reveal">
          <blockquote class="pullquote">The operator reviews and signs off. The human owns the decision.</blockquote>
          <ol class="wf-stages">
            {stages.map((s) => (
              <li>
                <span class="wf-num">{s.n}</span>
                <div>
                  <div class="wf-stage-name">{s.name}</div>
                  <div class="wf-stage-desc">{s.desc}</div>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <!-- CASE STUDIES -->
    <section id="work">
      <span class="kicker reveal">Case studies</span>
      <div class="work-head">
        <h2 class="feature reveal" style="margin-bottom:0;">Patterns I've worked through.</h2>
        <span class="work-meta reveal">Nine features &middot; sanitised</span>
      </div>
      <p class="deck reveal" style="margin-top:14px;">Sanitised. Employer name, entity names and figures removed. Notes on how I think about this kind of work in fund services.</p>
      <div class="cases">
        {cases.map((c) => (
          <a class="case reveal" href={c.href}>
            <div class="case-top">
              <span class="case-id">
                <span>{c.n}</span>
                <span class="case-kind">{c.kind}</span>
              </span>
              <div class="case-metric">
                <div class="case-metric-val">{c.metric}</div>
                <div class="case-metric-label">{c.metricLabel}</div>
              </div>
            </div>
            <h3 class="case-title">{c.title} <span class="arrow">&rarr;</span></h3>
            <p class="case-blurb">{c.blurb}</p>
            <div class="case-tags">
              {c.tags.map((t) => (<span class="tag">{t}</span>))}
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- NOW -->
    <section id="now">
      <span class="kicker reveal">/ now &middot; June 2026</span>
      <h2 class="feature reveal">What I'm focused on this quarter.</h2>
      <p class="deck reveal">A public note of where my head is right now, in the spirit of <em>nownownow.com</em>. I update it when things change, not on a schedule.</p>
      <div class="now-grid" style="margin-top:30px;">
        {nowRows.map((r) => (
          <div class="now-row reveal">
            <div class="now-key">{r.k}</div>
            <div class="now-val">
              {r.v}{r.cta && (<>{' '}<a href={r.cta.href}>{r.cta.label} &rarr;</a></>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- CV -->
    <section id="cv">
      <span class="kicker reveal">Live CV / spec sheet</span>
      <h2 class="feature reveal">Six years in Luxembourg fund services.</h2>
      <p class="deck reveal">Updated as roles, projects and credentials change. The condensed PDF version is on request.</p>
      <div class="cv-grid">
        <div class="cv-main">
          <div class="cv-subhead reveal">Experience <span class="count">5 roles &middot; 6+ years</span></div>
          {roles.map((r) => (
            <div class="role reveal">
              <div class="role-head">
                <div class="role-title">{r.role} <span class="role-co">/ {r.title}</span></div>
                <span class="role-dates">{r.dates}</span>
              </div>
              <ul class="role-points">
                {r.points.map((p) => (<li>{p}</li>))}
              </ul>
            </div>
          ))}
        </div>
        <aside class="cv-aside">
          <div class="reveal">
            <div class="cv-subhead">Education</div>
            {education.map((e) => (
              <div class="edu-item">
                <div class="edu-school">{e.school}</div>
                <div class="edu-deg">{e.deg}</div>
                <div class="edu-dates">{e.dates}</div>
              </div>
            ))}
          </div>
          <div class="reveal">
            <div class="cv-subhead">Skills <span class="count">key / value</span></div>
            <div class="skill-table">
              {skills.map((s) => (
                <div class="skill-row">
                  <div class="skill-k">{s.k}</div>
                  <div class="skill-v">{s.v}</div>
                </div>
              ))}
            </div>
          </div>
          <div class="reveal">
            <div class="cv-subhead">Publication</div>
            <div class="pub">
              <div class="pub-title">Augmented gravity model: Institutions, Infrastructure and Globalization impact on bilateral exports among OECD countries</div>
              <div class="pub-note">MSc thesis &middot; Erasmus University Rotterdam &middot; panel econometrics over 36 OECD economies, 1995 to 2018</div>
              <a class="pub-link" href="/thesis">Read &rarr;</a>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <!-- READING -->
    <section id="reading">
      <span class="kicker reveal">Reading</span>
      <h2 class="feature reveal">Mostly non-fiction.</h2>
      <p class="deck reveal">Themes I keep coming back to. A proper bookshelf with titles will go here once I've trimmed the list.</p>
      <div class="reading-grid">
        {readingThemes.map((r, i) => (
          <div class="shelf-item reveal">
            <div class="shelf-num">{String(i + 1).padStart(2, '0')} / shelf</div>
            <div class="shelf-t">{r.t}</div>
            <div class="shelf-n">{r.n}</div>
          </div>
        ))}
      </div>
    </section>

