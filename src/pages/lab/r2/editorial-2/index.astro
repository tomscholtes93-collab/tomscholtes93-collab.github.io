  { c: 'EN', n: 'English' },
  { c: 'DE', n: 'Deutsch' },
  { c: 'FR', n: 'Français' },
  { c: 'RU', n: 'Русский' },
  { c: 'LU', n: 'Lëtzebuergesch' },
  { c: 'UZ', n: 'Oʼzbekcha' },
];

const navItems = [
  { label: 'Now', href: '/#now' },
  { label: 'Work', href: '/#work' },
  { label: 'Projects', href: '/projects/' },
  { label: 'Notes', href: '/notes/' },
