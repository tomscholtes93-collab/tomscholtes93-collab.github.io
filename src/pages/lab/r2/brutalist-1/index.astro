---
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/instrument-serif/400.css';

const year = new Date().getFullYear();

// ---- DATA (verbatim from parent) ----
// The index is the spine of this page. Each entry carries:
//   no    = canonical two-digit index numeral (the promise of the "index" concept)
//   name  = label
//   href  = where a click goes
//   key   = single keystroke that jumps here
//   mode  = 'scroll' (in-page anchor) | 'route' (separate page)
//   target= element id for scroll mode, or route for route mode
// Every numeral 00..08 resolves to something truthful. Nothing no-ops.
const nav = [
  { no: '00', name: 'Now',                 href: '#now',                    key: '0', mode: 'scroll', target: 'now' },
  { no: '01', name: 'Work',                href: '#work',                   key: '1', mode: 'scroll', target: 'work' },
  { no: '02', name: 'Projects',            href: '/projects/',              key: '2', mode: 'route',  target: '/projects/' },
  { no: '03', name: 'Notes',               href: '/notes/',                 key: '3', mode: 'route',  target: '/notes/' },
  { no: '04', name: 'Workflow Automation', href: '#workflow',               key: '4', mode: 'scroll', target: 'workflow' },
  { no: '05', name: 'CV',                  href: '#cv',                     key: '5', mode: 'scroll', target: 'cv' },
  { no: '06', name: 'Thesis',              href: '/thesis/',                key: '6', mode: 'route',  target: '/thesis/' },
  { no: '07', name: 'Reading',            href: '#reading',                key: '7', mode: 'scroll', target: 'reading' },
  { no: '08', name: 'Contact',            href: '#contact',                key: '8', mode: 'scroll', target: 'contact' },
];
// Quick lookups so each in-page section can fetch its own canonical numeral
// from the index instead of carrying a hand-typed number that can drift.
const ixOf = Object.fromEntries(nav.map((e) => [e.target, e.no]));

const stages = [
  ['Find', 'Reads the source files and surfaces what is unbooked, mismatched, or missing.'],
  ['Build', 'Generates the upload template for the accounting system and drafts the counterparty email.'],
  ['Sign off', 'The operator reviews and approves. The human owns the decision.'],
  ['Scale', 'The same approach maps every other workflow in the company, from the existing mailbox.'],
];

const cases = [
  {
    no: '01', metric: 'Indicative', mlabel: 'order of magnitude time savings on this pattern',
    title: 'Automated Regulatory Notes Generation',
    blurb: 'A pattern for how a Claude skill can read a trial balance, identify entity type, and generate disclosure notes in a firm’s chosen style. Tables, movement schedules, narrative.',
    tags: ['Claude skills', 'Word generation', 'LuxGAAP'], href: '/case/automated-regulatory-notes/', shipped: true,
  },
  {
    no: '02', metric: 'Pre-audit', mlabel: 'automated cross-checker',
    title: 'Annual Accounts Quality Review',
    blurb: 'How I think about pre-audit cross-checking. A pattern that takes annual accounts (PDF) and source reconciliation (Excel), checks every cross-reference between primary statements and notes, and flags inconsistencies before the auditor finds them.',
    tags: ['PDF parsing', 'Excel', 'QA automation'], href: '/case/annual-accounts-quality-review/', shipped: true,
  },
  {
    no: '03', metric: 'Hours to minutes', mlabel: 'share registers for KYC/AML reviews',
    title: 'Confidential Document Anonymisation',
    blurb: 'A pattern for aggregating raw transactional share-register data into net positions per shareholder per share class, applying rule-based redaction for non-strategic shareholders, and producing print-ready Excel and PDF.',
    tags: ['Data aggregation', 'Compliance', 'Multi-format'], href: '/case/confidential-document-anonymisation/', shipped: true,
  },
  {
    no: '04', metric: 'Daily', mlabel: 'morning briefing automation',
    title: 'Cross-Platform Mailbox Intelligence',
    blurb: 'A pattern for triaging email and meeting-transcript backlogs into prioritised morning briefings. Surfaces unanswered messages, follow-ups, and half-finished commitments, organised by priority and workstream.',
    tags: ['M365', 'Outlook', 'Triage'], href: '/case/cross-platform-mailbox-intelligence/', shipped: true,
  },
  {
    no: '05', metric: 'Onboarding', mlabel: 'structured payment and accounting guide',
    title: 'Process Documentation & Knowledge Transfer',
    blurb: 'Patterns for documenting payment and accounting workflows in a way new joiners can self-serve. Payment flow, exception handling, approval routing, recharge and intercompany cases.',
    tags: ['Technical writing', 'Process mapping'], href: '/case/process-documentation/', shipped: true,
  },
  {
    no: '06', metric: 'Implementation', mlabel: 'contribution to platform rollout',
    title: 'Fund Accounting Platform Integration',
    blurb: 'Patterns I’ve worked through during fund-accounting platform rollouts. Pref-share reconciliation logic, waterfall validation approaches, edge-case discovery.',
    tags: ['Reconciliation', 'Vendor collab', 'Validation'], href: '/case/fund-accounting-platform-integration/', shipped: true,
  },
  {
    no: '07', metric: 'Library', mlabel: 'of reusable Claude skill patterns',
    title: 'AI Skill Architecture & Reusable Tooling',
    blurb: 'A library of small, opinionated AI skill patterns. Notes generation, quality review, anonymisation, mailbox triage, classification. Each with deterministic inputs and outputs. From single-purpose skills to five-persona orchestration, see Projects.',
    tags: ['Skill design', 'Knowledge eng.', 'Infrastructure'], href: '/case/ai-skill-architecture/', shipped: true,
  },
  {
    no: '08', metric: 'Pattern', mlabel: 'designed',
    title: 'Cross-system fund-data reconciliation architecture',
    blurb: 'Designed a bridging architecture for reconciling two source-of-truth platforms in a fund-administration setting while the underlying master data model was still being scoped. Generic pattern. Proposed internally; not deployed.',
    tags: ['Data integration', 'Master data', 'Internal proposal'], href: '/case/cross-system-reconciliation/', shipped: false,
  },
  {
    no: '09', metric: 'Pattern', mlabel: 'personal automation architecture',
    title: 'End-to-end email automation',
    blurb: 'An incoming message triggers an agent that fetches attachments, reads them, searches across knowledge systems, delegates research, and once the answer is well grounded drafts a reply and proposes which attachments to attach. A self-review loop runs the draft through a second model until it has no further comments, then hands a clean output to a human reviewer who owns the decision.',
    tags: ['Agentic', 'Self-review loop', 'Human-in-the-loop'], href: '/case/email-automation/', shipped: false,
  },
];

const nowRows = [
  { k: 'Building', v: 'End-to-end email automation as a personal architecture. An incoming message triggers an agent that fetches attachments, reads them, searches across knowledge systems, delegates research, and once the answer is well grounded drafts the reply and proposes which attachments to include. A self-review loop runs the draft through a second model until it has no further comments, then hands a clean output to a human reviewer who owns the decision.', cta: ['See the demo', '/workflow-automation/'] },
  { k: 'Testing', v: 'Frontier models on large, long-context files. How far the current generation holds up running real workflows over very large inputs.' },
  { k: 'Orchestrating', v: 'Workflow orchestration with n8n, extending the automation surface beyond a single agent.' },
  { k: 'Running', v: 'An agentic memory system on my own infrastructure. A voice-first assistant over AR glasses with a memory that consolidates during sleep, running across two machines that talk to each other, turning ideas into video journals or music within hours.', cta: ['See the project', '/projects/exocortex'] },
  { k: 'Learning', v: 'Cloud computing and GPU inference, to serve models faster and at lower marginal cost.' },
  { k: 'Throughline', v: 'Applied research on frontier models and frontier technologies. Curiosity is the throughline across all of it.' },
];

const experience = [
  ['Mar 2025 · Present', 'Working in Controlling', 'SPV Controller', [
    'End-to-end SPV finance, statutory reporting, cash flows and investor distributions. Hands-on in fund-administration platforms. Construction and maintenance of waterfall models. LuxGAAP / eCDF annual accounts and BCL Annex IV filings.',
    'Payment automation across the SPV book: batch generation, exception routing, recharge / intercompany cases.',
    'Cross-system fund-data integration architecture.',
    'Task management workstream via MCP: Outlook + Monday.com wired into Claude Code through MCP.',
  ]],
  ['Feb 2023 · Mar 2025', 'Alter Domus', 'Fund & Corporate Services Officer', [
    'Full-cycle accounting for management companies, funds, SPVs and GPs. NAVs, financial statements, CSSF/BCL regulatory filings. Drove process improvements through technology and structured methodologies.',
  ]],
  ['Sep 2022 · Jan 2023', 'Waystone Administration Solutions', 'Junior Associate Fund Accountant', [
    'Capital calls, distributions, OPEX payments. LuxGAAP financial statements. Audit coordination. Fund-administration platform import automation.',
  ]],
  ['Feb 2021 · Aug 2022', 'Aztec Group', 'Junior Depositary Analyst', [
    'Asset confirmation and reconciliation for alternative investment funds. Depositary obligations and oversight duties. eFront reporting.',
  ]],
  ['Nov 2019 · Nov 2020', 'European Fund Administration', 'Intern Fund Accountant', [
    'NAV calculations, financial-statement preparation, first-level controls and reconciliations. Year-end audit support.',
  ]],
];

const education = [
  ['2017 · 2020', 'Erasmus School of Economics, University of Rotterdam', 'MSc Economics & Business, International Economics'],
  ['2014 · 2017', 'University of Luxembourg', 'BSc Economics, Law & Management'],
];

const skills = [
  ['Data analysis', 'Panel econometrics · fixed-effects OLS · large multi-source datasets · Python · advanced Excel'],
  ['Accounting systems', 'eFront · BOB50 · SAP · alternative-investment platforms'],
  ['IT / scripting', 'VBA · Python · Microsoft Power Automate'],
  ['Office', 'Advanced Excel · Word · PowerPoint'],
  ['Fund types', 'Private Equity · Private Debt · Real Estate'],
  ['AI tooling', 'Claude · Claude Code · ChatGPT · Glean · Even Realities G2 SDK (assembled stack)'],
  ['AI infra', 'MCP servers · Multi-agent orchestration · Knowledge bases · Local model serving'],
  ['Dev', 'TypeScript · Astro · React · GitHub Actions · Tailscale'],
  ['Frameworks', 'LuxGAAP · eCDF · CSSF / BCL filings'],
];

const reading = [
  ['Systems & ops quality', 'How operational excellence actually gets built and kept. Applies to finance ops as much as to engineering.'],
  ['Knowledge engineering', 'Encoding expertise into tools other people can use without becoming experts themselves.'],
  ['AI & cognition', 'Practical books on what current AI can and cannot do, and where it changes the work.'],
  ['Economics & finance', 'Continuing the line my degrees started. International economics, capital markets, regulation.'],
];

const languages = [
  ['EN', 'English'],
  ['DE', 'Deutsch'],
  ['FR', 'Français'],
  ['RU', 'Русский'],
  ['LU', 'Lëtzebuergesch'],
  ['UZ', 'Oʻzbekcha'],
];

// ---- DERIVED COUNTS (never hand-typed; cannot drift) ----
const yrsExperience = '6 yrs';
const caseCount = String(cases.length);          // 9, was hardcoded '7' in parent
const langCount = String(languages.length);      // 6
const shippedCount = cases.filter((c) => c.shipped).length;
const proposedCount = cases.length - shippedCount;

const stats = [
  [yrsExperience, 'in Lux fund services'],
  [caseCount, 'case studies on file'],
  [langCount, 'languages spoken'],
];

const roleCount = String(experience.length);     // 5
const degreeCount = String(education.length);     // 2
const skillCount = String(skills.length);         // 9
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Tom Scholtes. Finance ops engineer who automates the work in reach.</title>
  <style>
    :root{
      --ink:#0b0b0b;
      --paper:#f3f1ea;
      --line:#0b0b0b;
      --accent:#ff3b00;
      --live:#0a7d4f;        /* second functional colour: shipped vs proposed */
      --mut:#6a6a64;
      --hair:1px;
      --pad:clamp(14px,3.2vw,28px);
    }
    *{box-sizing:border-box;}
    html{-webkit-text-size-adjust:100%;scroll-behavior:smooth;scroll-padding-top:96px;}
    @media (prefers-reduced-motion: reduce){html{scroll-behavior:auto;}}
    body{
      margin:0;
      background:var(--paper);
      color:var(--ink);
      font-family:"JetBrains Mono",ui-monospace,SFMono-Regular,Menlo,monospace;
      font-size:13px;
      line-height:1.45;
      -webkit-font-smoothing:antialiased;
    }
    a{color:inherit;text-decoration:none;}
    ::selection{background:var(--accent);color:var(--paper);}

    .wrap{max-width:1320px;margin:0 auto;border-left:var(--hair) solid var(--line);border-right:var(--hair) solid var(--line);}

    /* ---- generic row primitives ---- */
    .row{display:grid;border-bottom:var(--hair) solid var(--line);}
    .mono-cap{font-weight:700;text-transform:uppercase;letter-spacing:.14em;font-size:10px;}
    .mut{color:var(--mut);}

    /* ---- TOP BAR ---- */
    .topbar{
      display:grid;grid-template-columns:1fr auto;align-items:stretch;
      border-bottom:2px solid var(--line);position:sticky;top:0;z-index:30;background:var(--paper);
    }
    .brand{display:flex;align-items:center;gap:12px;padding:10px var(--pad);min-width:0;}
    .tmark{
      width:26px;height:26px;display:grid;place-items:center;background:var(--ink);color:var(--paper);
      font-weight:700;font-size:14px;flex:none;
    }
    .brand b{font-weight:700;letter-spacing:.04em;}
    /* "You are here" running index readout in the sticky bar. */
    .here{
      display:inline-flex;align-items:center;gap:8px;margin-left:6px;padding:3px 8px;
      border:var(--hair) solid var(--line);font-size:10px;letter-spacing:.1em;text-transform:uppercase;
      white-space:nowrap;overflow:hidden;
    }
    .here .hno{font-weight:700;color:var(--accent);font-variant-numeric:tabular-nums;}
    .here .hnm{font-weight:500;}
    .topbar-meta{display:flex;align-items:center;gap:12px;padding:10px var(--pad);border-left:var(--hair) solid var(--line);}
    .langset{font-size:10px;letter-spacing:.14em;font-weight:500;}
    /* Discoverability chip: tells visitors the keyboard index exists. */
    .keyhint{
      display:inline-flex;align-items:center;gap:7px;font-size:9px;letter-spacing:.12em;
      text-transform:uppercase;color:var(--mut);
    }
    .keyhint kbd{
      font-family:inherit;font-weight:700;font-size:10px;color:var(--ink);background:var(--paper);
      border:var(--hair) solid var(--line);border-bottom-width:2px;border-radius:2px;
      padding:1px 6px;line-height:1.4;
    }
    .saychip{
      background:var(--accent);color:var(--paper);padding:6px 12px;font-weight:700;font-size:10px;
      letter-spacing:.14em;text-transform:uppercase;
    }
    @media (prefers-reduced-motion: no-preference){.saychip{transition:transform .12s ease;}}
    .saychip:hover{transform:translate(-2px,-2px);box-shadow:3px 3px 0 var(--ink);}

    /* ---- MARQUEE (now carries live status, not decorative loop texture) ---- */
    .statusbar{
      display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:0;
      border-bottom:2px solid var(--line);background:var(--ink);color:var(--paper);
    }
    .statusbar .seg{padding:8px var(--pad);font-size:10px;letter-spacing:.16em;text-transform:uppercase;font-weight:500;}
    .statusbar .seg.mid{border-left:var(--hair) solid #444;border-right:var(--hair) solid #444;color:#cfcdc6;}
    .statusbar .live{color:var(--live);font-weight:700;}
    .statusbar .dot{display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--live);margin-right:7px;vertical-align:middle;}
    @media (prefers-reduced-motion: no-preference){.statusbar .dot{animation:pulse 2.4s ease-in-out infinite;}}
    @keyframes pulse{0%,100%{opacity:1;}50%{opacity:.35;}}

    /* ---- INDEX NAV (table of contents) ---- */
    .toc .row{grid-template-columns:64px 1fr 64px 130px;align-items:center;}
    .toc .row > *{padding:11px var(--pad);}
    .toc .ix{font-weight:700;color:var(--accent);border-right:var(--hair) solid var(--line);font-variant-numeric:tabular-nums;}
    .toc .nm{font-size:clamp(15px,2.6vw,22px);font-weight:500;letter-spacing:-.01em;}
    .toc .keycol{font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--mut);border-left:var(--hair) solid var(--line);border-right:var(--hair) solid var(--line);text-align:center;}
    .toc .keycol kbd{
      font-family:inherit;font-weight:700;font-size:11px;color:var(--ink);background:var(--paper);
      border:var(--hair) solid var(--line);border-bottom-width:2px;border-radius:2px;padding:1px 7px;
    }
    .toc .go{text-align:right;font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--mut);}
    @media (prefers-reduced-motion: no-preference){.toc .row{transition:background .1s;}}
    .toc .row:hover,.toc .row:focus-visible{background:var(--ink);color:var(--paper);outline:none;}
    .toc .row:hover .go,.toc .row:focus-visible .go{color:var(--accent);}
    .toc .row:hover .ix,.toc .row:focus-visible .ix{color:var(--accent);}
    .toc .row:hover .keycol kbd,.toc .row:focus-visible .keycol kbd{background:var(--ink);color:var(--paper);}
    /* Current-section state: the index reads as live navigable state. */
    .toc .row[data-current="true"]{background:#e7e4da;}
    .toc .row[data-current="true"] .ix{color:var(--ink);}
    .toc .row[data-current="true"] .ix::after{content:" \2190 here";color:var(--accent);font-size:9px;letter-spacing:.06em;}

    /* ---- SECTION HEADER ---- */
    .sec-head{
      display:grid;grid-template-columns:96px 1fr;border-bottom:2px solid var(--line);
      background:var(--ink);color:var(--paper);scroll-margin-top:96px;
    }
    .sec-head .big{
      font-size:clamp(40px,9vw,86px);font-weight:700;line-height:.9;text-align:center;
      border-right:var(--hair) solid #444;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;
      font-variant-numeric:tabular-nums;
    }
    .sec-head .big .fig{font-size:8px;letter-spacing:.22em;text-transform:uppercase;color:var(--mut);font-weight:700;}
    .sec-head .htxt{padding:14px var(--pad);display:flex;flex-direction:column;justify-content:center;gap:6px;}
    .sec-head .eyebrow{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);font-weight:700;}
    .sec-head h2{margin:0;font-family:"Instrument Serif",Georgia,serif;font-weight:400;font-size:clamp(22px,4.4vw,38px);line-height:1.05;letter-spacing:.005em;}
    .sec-head h2 em{font-style:italic;color:var(--accent);}
    .sec-head .blurb{font-size:11.5px;color:#cfcdc6;max-width:62ch;}
    .sec-head .blurb i{font-style:italic;color:#fff;}

    /* ---- HERO ---- */
    .hero{display:grid;grid-template-columns:1.55fr 1fr;border-bottom:2px solid var(--line);scroll-margin-top:96px;}
    .hero-l{padding:var(--pad);border-right:var(--hair) solid var(--line);}
    .hero-eyebrow{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);font-weight:700;margin-bottom:18px;}
    .hero-name{font-family:"Instrument Serif",Georgia,serif;font-weight:400;font-size:clamp(34px,7vw,82px);line-height:.94;letter-spacing:-.01em;margin:0 0 6px;}
    .hero-role{font-size:11px;letter-spacing:.04em;color:var(--mut);max-width:60ch;margin-bottom:22px;}
    .hero-head{font-family:"Instrument Serif",Georgia,serif;font-weight:400;font-size:clamp(24px,4.6vw,46px);line-height:1.04;margin:0 0 18px;}
    .hero-head em{font-style:italic;color:var(--accent);}
    .hero-lead{font-size:12.5px;line-height:1.65;max-width:64ch;margin:0 0 24px;}
    .hero-cta{display:flex;gap:0;border:var(--hair) solid var(--line);width:fit-content;max-width:100%;flex-wrap:wrap;}
    .btn{padding:12px 20px;font-weight:700;font-size:11px;letter-spacing:.12em;text-transform:uppercase;}
    .btn.p{background:var(--accent);color:var(--paper);}
    .btn.g{border-left:var(--hair) solid var(--line);}
    @media (prefers-reduced-motion: no-preference){.btn{transition:background .12s,color .12s;}}
    .btn.g:hover{background:var(--ink);color:var(--paper);}

    .hero-r{display:grid;grid-template-rows:auto 1fr;}
    .hero-stats{display:grid;}
    .stat{padding:var(--pad);border-bottom:var(--hair) solid var(--line);}
    .stat .v{font-size:clamp(34px,5vw,56px);font-weight:700;line-height:1;letter-spacing:-.02em;font-variant-numeric:tabular-nums;}
    .stat .l{font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--mut);margin-top:6px;}
    .glyph{
      flex:1;display:grid;place-items:center;overflow:hidden;position:relative;
      background:
        repeating-linear-gradient(0deg, transparent 0 13px, rgba(11,11,11,.07) 13px 14px),
        repeating-linear-gradient(90deg, transparent 0 13px, rgba(11,11,11,.07) 13px 14px);
    }
    .glyph .ts{font-family:"Instrument Serif",Georgia,serif;font-size:clamp(120px,24vw,260px);line-height:.8;color:var(--ink);opacity:.96;}
    .glyph .sub{position:absolute;bottom:10px;left:0;right:0;text-align:center;font-size:9px;letter-spacing:.3em;text-transform:uppercase;color:var(--mut);}

    /* ---- WORKFLOW STAGES ---- */
    .stages{display:grid;grid-template-columns:repeat(4,1fr);border-bottom:var(--hair) solid var(--line);}
    .stage{padding:var(--pad);border-right:var(--hair) solid var(--line);}
    .stage:last-child{border-right:0;}
    .stage .n{font-size:10px;font-weight:700;color:var(--accent);letter-spacing:.14em;}
    .stage h4{margin:6px 0 8px;font-size:15px;font-weight:700;}
    .stage p{margin:0;font-size:11px;color:var(--mut);line-height:1.55;}
    .wf-blurb{padding:var(--pad);border-bottom:var(--hair) solid var(--line);font-size:12px;line-height:1.6;max-width:80ch;}
    .wf-cta{padding:14px var(--pad);border-bottom:2px solid var(--line);}

    /* ---- CASES ---- */
    .case{
      display:grid;grid-template-columns:80px 200px 1fr;border-bottom:var(--hair) solid var(--line);align-items:stretch;
    }
    .case > *{padding:16px var(--pad);}
    .case .c-no{font-size:clamp(28px,5vw,52px);font-weight:700;line-height:.9;color:var(--ink);border-right:var(--hair) solid var(--line);display:flex;align-items:flex-start;font-variant-numeric:tabular-nums;}
    .case .c-metric{border-right:var(--hair) solid var(--line);display:flex;flex-direction:column;gap:6px;}
    .case .c-metric .mv{font-family:"Instrument Serif",Georgia,serif;font-size:22px;line-height:1;color:var(--accent);}
    .case .c-metric .ml{font-size:10px;color:var(--mut);letter-spacing:.04em;line-height:1.4;text-transform:uppercase;}
    .case .c-body{display:flex;flex-direction:column;gap:10px;}
    .case .c-title{font-size:clamp(15px,2.4vw,20px);font-weight:700;display:flex;justify-content:space-between;gap:14px;align-items:baseline;}
    .case .c-title .arr{color:var(--accent);font-weight:700;}
    .case .c-blurb{font-size:11.5px;color:#2a2a26;line-height:1.6;max-width:78ch;}
    .case .c-tags{display:flex;flex-wrap:wrap;gap:6px;align-items:center;}
    .tag{border:var(--hair) solid var(--line);padding:3px 8px;font-size:9.5px;letter-spacing:.06em;text-transform:uppercase;font-weight:500;}
    /* Status pill: shipped vs proposed, using the second functional colour. */
    .status{font-size:9px;letter-spacing:.1em;text-transform:uppercase;font-weight:700;padding:3px 8px;border:var(--hair) solid var(--line);}
    .status.shipped{color:var(--live);border-color:var(--live);}
    .status.proposed{color:var(--mut);}
    @media (prefers-reduced-motion: no-preference){.case{transition:background .1s;}}
    .case:hover{background:#e7e4da;}
    .case:hover .c-no{color:var(--accent);}

    /* ---- KEY/VALUE rows (Now) ---- */
    .kv{display:grid;grid-template-columns:200px 1fr;border-bottom:var(--hair) solid var(--line);}
    .kv .k{padding:16px var(--pad);font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:.06em;border-right:var(--hair) solid var(--line);color:var(--accent);}
    .kv .v{padding:16px var(--pad);font-size:11.5px;line-height:1.65;}
    .kv .v a{color:var(--ink);font-weight:700;border-bottom:2px solid var(--accent);}
    .kv .v a:hover{background:var(--accent);color:var(--paper);}

    /* ---- CV ---- */
    .cv-sub{display:grid;grid-template-columns:200px 1fr;border-bottom:2px solid var(--line);background:#e7e4da;}
    .cv-sub .lbl{padding:10px var(--pad);font-weight:700;text-transform:uppercase;letter-spacing:.16em;font-size:11px;border-right:var(--hair) solid var(--line);}
    .cv-sub .sum{padding:10px var(--pad);font-size:11px;color:var(--mut);letter-spacing:.04em;display:flex;align-items:center;}
    .job{display:grid;grid-template-columns:200px 1fr;border-bottom:var(--hair) solid var(--line);}
    .job .when{padding:16px var(--pad);font-size:11px;color:var(--mut);border-right:var(--hair) solid var(--line);font-weight:500;}
    .job .det{padding:16px var(--pad);}
    .job .org{font-size:16px;font-weight:700;}
    .job .title{font-size:12px;color:var(--accent);font-weight:500;margin:2px 0 10px;letter-spacing:.02em;}
    .job ul{margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:7px;}
    .job li{font-size:11.5px;line-height:1.55;padding-left:16px;position:relative;}
    .job li::before{content:"/";position:absolute;left:0;color:var(--accent);font-weight:700;}
    .pub .det .org{font-family:"Instrument Serif",Georgia,serif;font-weight:400;font-size:18px;line-height:1.2;}
    .pub-cta{display:inline-block;margin-top:10px;font-weight:700;font-size:11px;letter-spacing:.12em;text-transform:uppercase;border-bottom:2px solid var(--accent);}

    /* ---- READING / LANGUAGES grids ---- */
    .grid2{display:grid;grid-template-columns:1fr 1fr;}
    .gcell{padding:var(--pad);border-bottom:var(--hair) solid var(--line);border-right:var(--hair) solid var(--line);}
    .grid2 .gcell:nth-child(2n){border-right:0;}
    .gcell h4{margin:0 0 8px;font-size:15px;font-weight:700;}
    .gcell p{margin:0;font-size:11.5px;color:var(--mut);line-height:1.6;}

    .langs{display:grid;grid-template-columns:repeat(6,1fr);}
    .lang{padding:var(--pad);border-right:var(--hair) solid var(--line);text-align:center;}
    .lang:last-child{border-right:0;}
    .lang .code{font-size:clamp(28px,4vw,46px);font-weight:700;letter-spacing:-.02em;line-height:1;}
    .lang .nm{font-size:10px;margin-top:8px;color:var(--mut);letter-spacing:.06em;}

    /* ---- OFF-PAGE INDEX ROW (Projects / Notes / Thesis live as routes) ---- */
    .offpage{display:grid;grid-template-columns:repeat(3,1fr);border-bottom:2px solid var(--line);}
    .offpage a{padding:var(--pad);border-right:var(--hair) solid var(--line);display:flex;flex-direction:column;gap:8px;}
    .offpage a:last-child{border-right:0;}
    @media (prefers-reduced-motion: no-preference){.offpage a{transition:background .1s;}}
    .offpage a:hover{background:var(--ink);color:var(--paper);}
    .offpage a:hover .op-arr{color:var(--accent);}
    .offpage .op-ix{font-size:10px;font-weight:700;letter-spacing:.14em;color:var(--accent);font-variant-numeric:tabular-nums;}
    .offpage .op-nm{font-size:clamp(16px,2.6vw,22px);font-weight:700;display:flex;justify-content:space-between;gap:10px;}
    .offpage .op-arr{color:var(--accent);font-weight:700;}
    .offpage .op-d{font-size:10.5px;color:var(--mut);letter-spacing:.02em;}

    /* ---- CONTACT ---- */
    .contact{position:relative;border-bottom:2px solid var(--line);overflow:hidden;background:var(--ink);color:var(--paper);scroll-margin-top:96px;}
    .contact .wm{position:absolute;right:-2vw;top:50%;transform:translateY(-50%);font-family:"Instrument Serif",Georgia,serif;font-size:clamp(160px,34vw,420px);line-height:.7;color:rgba(255,255,255,.06);pointer-events:none;user-select:none;}
    .contact-inner{position:relative;padding:var(--pad);z-index:2;}
    .contact .eyebrow{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);font-weight:700;}
    .contact h2{font-family:"Instrument Serif",Georgia,serif;font-weight:400;font-size:clamp(28px,6vw,60px);line-height:1.02;margin:12px 0;}
    .contact h2 em{font-style:italic;color:var(--accent);}
    .contact p{font-size:12.5px;line-height:1.65;max-width:64ch;color:#cfcdc6;margin:0 0 22px;}
    .contact-cta{display:flex;border:var(--hair) solid #555;width:fit-content;max-width:100%;flex-wrap:wrap;}
    .contact-cta a{padding:13px 20px;font-weight:700;font-size:11px;letter-spacing:.12em;text-transform:uppercase;border-left:var(--hair) solid #555;}
    .contact-cta a:first-child{border-left:0;background:var(--accent);color:var(--paper);}
    @media (prefers-reduced-motion: no-preference){.contact-cta a{transition:background .12s,color .12s;}}
    .contact-cta a:not(:first-child):hover{background:var(--paper);color:var(--ink);}

    /* ---- FOOTER ---- */
    footer{background:var(--ink);color:var(--paper);}
    .foot-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;border-bottom:var(--hair) solid #333;}
    .foot-grid > div{padding:var(--pad);border-right:var(--hair) solid #333;}
    .foot-grid > div:last-child{border-right:0;}
    .foot-brand b{font-weight:700;}
    .foot-brand .tag{font-size:11px;color:#aaa;margin-top:10px;line-height:1.5;max-width:34ch;}
    .foot-col h5{margin:0 0 12px;font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);font-weight:700;}
    .foot-col a{display:block;font-size:11px;color:#ddd;padding:4px 0;}
    .foot-col a:hover{color:var(--accent);}
    .foot-bot{display:flex;justify-content:space-between;gap:14px;flex-wrap:wrap;padding:12px var(--pad);font-size:10px;color:#888;letter-spacing:.06em;}

    /* ---- KEYBOARD INDEX OVERLAY (the discoverable signature) ---- */
    .kbtoggle{
      position:fixed;right:14px;bottom:14px;z-index:40;
      display:inline-flex;align-items:center;gap:8px;
      background:var(--ink);color:var(--paper);border:var(--hair) solid var(--ink);
      padding:9px 13px;font-family:inherit;font-size:10px;font-weight:700;letter-spacing:.12em;
      text-transform:uppercase;cursor:pointer;
    }
    .kbtoggle kbd{font-family:inherit;background:var(--paper);color:var(--ink);border-radius:2px;padding:0 6px;font-size:11px;}
    @media (prefers-reduced-motion: no-preference){.kbtoggle{transition:transform .12s ease;}}
    .kbtoggle:hover{transform:translate(-2px,-2px);box-shadow:3px 3px 0 var(--accent);}
    .kbtoggle:focus-visible{outline:2px solid var(--accent);outline-offset:2px;}

    .palette{
      position:fixed;inset:0;z-index:50;display:none;align-items:center;justify-content:center;
      background:rgba(11,11,11,.55);padding:18px;
    }
    .palette[data-open="true"]{display:flex;}
    .palette-card{
      width:min(520px,100%);background:var(--paper);border:2px solid var(--ink);
      max-height:88vh;overflow:auto;
    }
    .palette-head{
      display:flex;justify-content:space-between;align-items:center;gap:10px;
      padding:12px var(--pad);border-bottom:2px solid var(--line);
    }
    .palette-head h3{margin:0;font-size:12px;letter-spacing:.16em;text-transform:uppercase;font-weight:700;}
    .palette-head .x{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--mut);cursor:pointer;background:none;border:none;font-family:inherit;}
    .palette-row{
      display:grid;grid-template-columns:56px 1fr auto;align-items:center;gap:0;width:100%;text-align:left;
      border-bottom:var(--hair) solid var(--line);background:none;border-left:0;border-right:0;border-top:0;
      font-family:inherit;cursor:pointer;color:inherit;
    }
    .palette-row > *{padding:11px var(--pad);}
    .palette-row .pk kbd{font-family:inherit;font-weight:700;font-size:12px;color:var(--ink);background:var(--paper);border:var(--hair) solid var(--line);border-bottom-width:2px;border-radius:2px;padding:1px 8px;}
    .palette-row .pn{font-size:14px;font-weight:500;}
    .palette-row .pt{font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--mut);text-align:right;}
    @media (prefers-reduced-motion: no-preference){.palette-row{transition:background .1s;}}
    .palette-row:hover,.palette-row:focus-visible{background:var(--ink);color:var(--paper);outline:none;}
    .palette-row:hover .pk kbd,.palette-row:focus-visible .pk kbd{background:var(--ink);color:var(--paper);}
    .palette-foot{padding:10px var(--pad);font-size:9.5px;color:var(--mut);letter-spacing:.06em;line-height:1.6;}
    .palette-foot kbd{font-family:inherit;color:var(--ink);font-weight:700;}

    .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;}

    /* ---- RESPONSIVE ---- */
    @media (max-width:820px){
      .hero{grid-template-columns:1fr;}
      .hero-l{border-right:0;border-bottom:var(--hair) solid var(--line);}
      .hero-stats{grid-template-columns:repeat(3,1fr);}
      .stat{border-right:var(--hair) solid var(--line);}
      .stat:last-child{border-right:0;}
      .glyph{min-height:200px;}
      .stages{grid-template-columns:repeat(2,1fr);}
      .stage:nth-child(2n){border-right:0;}
      .offpage{grid-template-columns:1fr;}
      .offpage a{border-right:0;border-bottom:var(--hair) solid var(--line);}
      .offpage a:last-child{border-bottom:0;}
      .foot-grid{grid-template-columns:1fr 1fr;}
      .here{display:none;}
    }
    @media (max-width:600px){
      body{font-size:13px;}
      .topbar{grid-template-columns:1fr;}
      .topbar-meta{border-left:0;border-top:var(--hair) solid var(--line);justify-content:space-between;flex-wrap:wrap;}
      .keyhint{display:none;}
      .statusbar{grid-template-columns:1fr;}
      .statusbar .seg.mid{border-left:0;border-right:0;border-top:var(--hair) solid #444;border-bottom:var(--hair) solid #444;}
      .toc .row{grid-template-columns:44px 1fr 44px;}
      .toc .go{display:none;}
      .toc .keycol{display:none;}
      .sec-head{grid-template-columns:60px 1fr;}
      .sec-head .big{font-size:clamp(30px,8vw,52px);}
      .case{grid-template-columns:1fr;}
      .case .c-no{border-right:0;border-bottom:var(--hair) solid var(--line);}
      .case .c-metric{border-right:0;border-bottom:var(--hair) solid var(--line);flex-direction:row;flex-wrap:wrap;align-items:baseline;}
      .kv{grid-template-columns:1fr;}
      .kv .k{border-right:0;border-bottom:var(--hair) solid var(--line);}
      .cv-sub{grid-template-columns:1fr;}
      .cv-sub .lbl{border-right:0;border-bottom:var(--hair) solid var(--line);}
      .job{grid-template-columns:1fr;}
      .job .when{border-right:0;border-bottom:var(--hair) solid var(--line);}
      .grid2{grid-template-columns:1fr;}
      .grid2 .gcell{border-right:0;}
      .langs{grid-template-columns:repeat(3,1fr);}
      .lang:nth-child(3n){border-right:0;}
      .lang:nth-child(n+4){border-top:var(--hair) solid var(--line);}
      .stages{grid-template-columns:1fr;}
      .stage{border-right:0;}
      .foot-grid{grid-template-columns:1fr;}
      .foot-grid > div{border-right:0;border-bottom:var(--hair) solid #333;}
      .kbtoggle{right:10px;bottom:10px;}
    }
  </style>
</head>
<body>
  <div class="wrap">

    <!-- TOP BAR -->
    <div class="topbar">
      <div class="brand">
        <span class="tmark">T</span>
        <b>Tom Scholtes</b>
        <span class="mut mono-cap" style="margin-left:8px;">Index / Luxembourg</span>
        <span class="here" id="here" aria-hidden="true">
          <span class="hno" id="here-no">00</span>
          <span class="hnm" id="here-nm">Now</span>
        </span>
      </div>
      <div class="topbar-meta">
        <span class="langset mut">EN / DE / FR / RU</span>
        <span class="keyhint" aria-hidden="true">Press <kbd>0</kbd>&ndash;<kbd>8</kbd> to jump</span>
        <a class="saychip" href="#contact">Say hi</a>
      </div>
    </div>

    <!-- STATUS BAR (was decorative marquee; now carries live, dated state) -->
    <div class="statusbar" role="status">
      <div class="seg"><span class="dot" aria-hidden="true"></span><span class="live">Open to conversations</span></div>
      <div class="seg mid">{caseCount} case studies on file &middot; {shippedCount} shipped &middot; {proposedCount} proposed</div>
      <div class="seg">Index updated June 2026 &middot; Luxembourg</div>
    </div>

    <!-- INDEX / TABLE OF CONTENTS -->
    <nav class="toc" id="toc" aria-label="Site index">
      {nav.map((e) => (
        <a
          class="row"
          href={e.href}
          data-key={e.key}
          data-mode={e.mode}
          data-target={e.target}
          data-name={e.name}
        >
          <div class="ix">{e.no}</div>
          <div class="nm">{e.name}</div>
          <div class="keycol"><kbd>{e.key}</kbd></div>
          <div class="go">{e.mode === 'route' ? 'open page →' : 'jump →'}</div>
        </a>
      ))}
    </nav>

    <!-- HERO -->
    <section class="hero" id="top">
      <div class="hero-l">
        <div class="hero-eyebrow">Personal site &middot; Luxembourg</div>
        <h1 class="hero-name">Tom Scholtes</h1>
        <div class="hero-role">Finance ops engineer who automates the work in reach. Builds AI-augmented automation for the operational work in regulated finance. Six years in Luxembourg fund services across PE, Private Debt and Real Estate.</div>
        <p class="hero-head">I build the automation behind <em>regulated finance</em> operations.</p>
        <p class="hero-lead">I'm Tom. I build AI-augmented automation for the operational work in regulated finance: regulatory notes, accounts quality review, document workflows, mailbox triage, and the reusable tooling that ties them together. Six years in Luxembourg fund services across PE, Private Debt and Real Estate, now spent designing the systems that do the work instead of doing it by hand. This site is the evidence: a live CV, the patterns behind the work, and case studies of it shipping.</p>
        <div class="hero-cta">
          <a class="btn p" href="#work">See the work</a>
          <a class="btn g" href="#contact">Get in touch</a>
        </div>
      </div>
      <div class="hero-r">
        <div class="hero-stats">
          {stats.map(([v, l]) => (
            <div class="stat">
              <div class="v">{v}</div>
              <div class="l">{l}</div>
            </div>
          ))}
        </div>
        <div class="glyph" aria-hidden="true">
          <div class="ts">T</div>
          <div class="sub">FIG. 00 / IDENTITY</div>
        </div>
      </div>
    </section>

    <!-- 00 NOW -->
    <section id="now">
      <div class="sec-head">
        <div class="big">{ixOf['now']}<span class="fig">Fig. {ixOf['now']}</span></div>
        <div class="htxt">
          <div class="eyebrow">/ now &middot; June 2026</div>
          <h2>What I'm focused on this quarter.</h2>
          <div class="blurb">A public note of where my head is right now, in the spirit of <i>nownownow.com</i>. I update it when things change, not on a schedule.</div>
        </div>
      </div>
      {nowRows.map((r) => (
        <div class="kv">
          <div class="k">{r.k}</div>
          <div class="v">
            {r.v}
            {r.cta && (<> <a href={r.cta[1]}>{r.cta[0]} &rarr;</a></>)}
          </div>
        </div>
      ))}
    </section>

    <!-- 01 WORK / CASE STUDIES -->
    <section id="work">
      <div class="sec-head">
        <div class="big">{ixOf['work']}<span class="fig">Fig. {ixOf['work']}</span></div>
        <div class="htxt">
          <div class="eyebrow">Case studies &middot; {caseCount} on file</div>
          <h2>Patterns I've <em>worked through</em>.</h2>
          <div class="blurb">Sanitised. Employer name, entity names and figures removed. Notes on how I think about this kind of work in fund services. <i>{shippedCount} shipped, {proposedCount} proposed.</i></div>
        </div>
      </div>
      <div class="cases">
        {cases.map((c) => (
          <a class="case" href={c.href}>
            <div class="c-no">{c.no}</div>
            <div class="c-metric">
              <span class="mv">{c.metric}</span>
              <span class="ml">{c.mlabel}</span>
            </div>
            <div class="c-body">
              <div class="c-title"><span>{c.title}</span><span class="arr">&rarr;</span></div>
              <div class="c-blurb">{c.blurb}</div>
              <div class="c-tags">
                {c.tags.map((t) => <span class="tag">{t}</span>)}
                <span class={c.shipped ? 'status shipped' : 'status proposed'}>{c.shipped ? 'Shipped' : 'Proposed'}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- 02 / 03 PROJECTS + NOTES (off-page index entries, kept truthful) -->
    <div class="offpage" aria-label="Index entries on separate pages">
      <a href="/projects/">
        <div class="op-ix">{nav.find((e) => e.target === '/projects/').no} &middot; Press {nav.find((e) => e.target === '/projects/').key}</div>
        <div class="op-nm"><span>Projects</span><span class="op-arr">&rarr;</span></div>
        <div class="op-d">Multi-agent orchestration, the exocortex, and the assembled stacks behind the work.</div>
      </a>
      <a href="/notes/">
        <div class="op-ix">{nav.find((e) => e.target === '/notes/').no} &middot; Press {nav.find((e) => e.target === '/notes/').key}</div>
        <div class="op-nm"><span>Notes</span><span class="op-arr">&rarr;</span></div>
        <div class="op-d">Writing on AI in finance ops, knowledge engineering, and applied automation.</div>
      </a>
      <a href="/thesis/">
        <div class="op-ix">{nav.find((e) => e.target === '/thesis/').no} &middot; Press {nav.find((e) => e.target === '/thesis/').key}</div>
        <div class="op-nm"><span>Thesis</span><span class="op-arr">&rarr;</span></div>
        <div class="op-d">Augmented gravity model: institutions, infrastructure and globalization on OECD bilateral exports.</div>
      </a>
    </div>

    <!-- 04 WORKFLOW AUTOMATION -->
    <section id="workflow">
      <div class="sec-head">
        <div class="big">{ixOf['workflow']}<span class="fig">Fig. {ixOf['workflow']}</span></div>
        <div class="htxt">
          <div class="eyebrow">Live demo</div>
          <h2>See the automation run, on synthetic data.</h2>
          <div class="blurb">Point AI at the manual workflows underneath a finance desk. It surfaces what is unbooked, mismatched, or missing, builds the upload template, and drafts the counterparty email. The operator reviews and signs off; the human owns the decision. Click through a before-and-after process map and run it live.</div>
        </div>
      </div>
      <div class="stages">
        {stages.map(([t, d], i) => (
          <div class="stage">
            <div class="n">STAGE {String(i + 1).padStart(2, '0')}</div>
            <h4>{t}</h4>
            <p>{d}</p>
          </div>
        ))}
      </div>
      <div class="wf-cta">
        <a class="btn p" href="/workflow-automation/" style="display:inline-block;border:1px solid var(--line);">Open the live demo &rarr;</a>
      </div>
    </section>

    <!-- 05 CV -->
    <section id="cv">
      <div class="sec-head">
        <div class="big">{ixOf['cv']}<span class="fig">Fig. {ixOf['cv']}</span></div>
        <div class="htxt">
          <div class="eyebrow">Live CV</div>
          <h2>Six years in Luxembourg fund services.</h2>
          <div class="blurb">Updated as roles, projects and credentials change. The condensed PDF version is on request.</div>
        </div>
      </div>

      <div class="cv-sub"><div class="lbl">Experience</div><div class="sum">{roleCount} roles &middot; 6+ years</div></div>
      {experience.map(([when, org, title, bullets]) => (
        <div class="job">
          <div class="when">{when}</div>
          <div class="det">
            <div class="org">{org}</div>
            <div class="title">{title}</div>
            <ul>{bullets.map((b) => <li>{b}</li>)}</ul>
          </div>
        </div>
      ))}

      <div class="cv-sub"><div class="lbl">Education</div><div class="sum">{degreeCount} degrees</div></div>
      {education.map(([when, org, title]) => (
        <div class="job">
          <div class="when">{when}</div>
          <div class="det">
            <div class="org">{org}</div>
            <div class="title">{title}</div>
          </div>
        </div>
      ))}

      <div class="cv-sub"><div class="lbl">Skills</div><div class="sum">{skillCount} domains</div></div>
      {skills.map(([k, v]) => (
        <div class="kv">
          <div class="k" style="color:var(--ink);font-size:12px;">{k}</div>
          <div class="v">{v}</div>
        </div>
      ))}

      <div class="cv-sub"><div class="lbl">Publication</div><div class="sum">1 thesis</div></div>
      <div class="job pub">
        <div class="when">MSc thesis</div>
        <div class="det">
          <div class="org">Augmented gravity model: Institutions, Infrastructure and Globalization impact on bilateral exports among OECD countries</div>
          <div class="title" style="margin-top:8px;">MSc thesis &middot; Erasmus University Rotterdam &middot; panel econometrics over 36 OECD economies, 1995 to 2018</div>
          <a class="pub-cta" href="/thesis">Read &rarr;</a>
        </div>
      </div>
    </section>

    <!-- 07 READING -->
    <section id="reading">
      <div class="sec-head">
        <div class="big">{ixOf['reading']}<span class="fig">Fig. {ixOf['reading']}</span></div>
        <div class="htxt">
          <div class="eyebrow">Reading</div>
          <h2>Mostly non-fiction.</h2>
          <div class="blurb">Themes I keep coming back to. A proper bookshelf with titles will go here once I've trimmed the list.</div>
        </div>
      </div>
      <div class="grid2">
        {reading.map(([t, n]) => (
          <div class="gcell">
            <h4>{t}</h4>
            <p>{n}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- LANGUAGES (supporting detail; index numeral 06 belongs to Thesis route) -->
    <section id="languages">
      <div class="sec-head">
        <div class="big">&middot;<span class="fig">Languages</span></div>
        <div class="htxt">
          <div class="eyebrow">Languages &middot; {langCount} spoken</div>
          <h2>Six, used regularly.</h2>
          <div class="blurb">Spoken regularly. Code and native name; no proficiency levels claimed.</div>
        </div>
      </div>
      <div class="langs">
        {languages.map(([code, nm]) => (
          <div class="lang">
            <div class="code">{code}</div>
            <div class="nm">{nm}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- 08 CONTACT -->
    <section class="contact" id="contact">
      <div class="wm" aria-hidden="true">hi.</div>
      <div class="contact-inner">
        <div class="eyebrow">{ixOf['contact']} &middot; Contact</div>
        <h2>If any of this is <em>interesting</em>, say hi.</h2>
        <p>Always interested in conversations about data engineering, automation, applied AI, multi-agent systems, knowledge engineering, agent infrastructure, especially where they meet regulated workflows.</p>
        <div class="contact-cta">
          <a href="https://www.linkedin.com/messaging/compose/?recipient=tomscholtes93">Message on LinkedIn</a>
          <a href="https://www.linkedin.com/in/tomscholtes93/">View profile</a>
          <a href="mailto:tom@tomscholtes.com">Email</a>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="foot-grid">
        <div class="foot-brand">
          <div style="display:flex;align-items:center;gap:10px;">
            <span class="tmark">T</span><b>Tom Scholtes</b>
          </div>
          <div class="tag">Notes on AI in finance ops, a live CV, and a portfolio of work.</div>
        </div>
        <div class="foot-col">
          <h5>Index</h5>
          {nav.map((e) => <a href={e.href}>{e.no} {e.name}</a>)}
        </div>
        <div class="foot-col">
          <h5>Elsewhere</h5>
          <a href="https://www.linkedin.com/in/tomscholtes93/">LinkedIn</a>
          <a href="/thesis">MSc thesis</a>
        </div>
        <div class="foot-col">
          <h5>Contact</h5>
          <a href="mailto:tom@tomscholtes.com">tom@tomscholtes.com</a>
          <a href="#contact">Say hi</a>
        </div>
      </div>
      <div class="foot-bot">
        <span>&copy; {year} Tom Scholtes &middot; Luxembourg</span>
        <span>Personal site &middot; opinions my own</span>
      </div>
    </footer>

  </div>

  <!-- Discoverable trigger for the keyboard index. -->
  <button class="kbtoggle" id="kbtoggle" type="button" aria-haspopup="dialog" aria-controls="palette" aria-expanded="false">
    Index <kbd>?</kbd>
  </button>

  <!-- Keyboard / touch index overlay (the signature, made accessible) -->
  <div class="palette" id="palette" role="dialog" aria-modal="true" aria-labelledby="palette-title" data-open="false">
    <div class="palette-card">
      <div class="palette-head">
        <h3 id="palette-title">Jump to index entry</h3>
        <button class="x" id="palette-close" type="button">Close (Esc)</button>
      </div>
      {nav.map((e) => (
        <button
          class="palette-row"
          type="button"
          data-key={e.key}
          data-mode={e.mode}
          data-target={e.target}
          data-name={e.name}
        >
          <div class="pk"><kbd>{e.key}</kbd></div>
          <div class="pn">{e.no} {e.name}</div>
          <div class="pt">{e.mode === 'route' ? 'page' : 'on this page'}</div>
        </button>
      ))}
      <div class="palette-foot">
        Press <kbd>0</kbd> to <kbd>8</kbd> any time to jump. <kbd>?</kbd> or <kbd>/</kbd> opens this list. <kbd>Esc</kbd> closes it. Entries marked <i>page</i> open a separate page.
      </div>
    </div>
  </div>

  <!-- Polite announcer for assistive tech on jump. -->
  <div class="sr-only" id="nav-live" role="status" aria-live="polite"></div>

  <script>
    (function () {
      // The index, mirrored from the page DOM so script and markup never drift.
      // Every entry resolves to a truthful destination: scroll to an in-page
      // anchor, or navigate to a separate route. No key is a dead no-op.
      const rows = Array.prototype.slice.call(document.querySelectorAll('.toc .row'));
      const map = {};
      rows.forEach(function (r) {
        map[r.getAttribute('data-key')] = {
          mode: r.getAttribute('data-mode'),
          target: r.getAttribute('data-target'),
          name: r.getAttribute('data-name'),
          ix: (r.querySelector('.ix') ? r.querySelector('.ix').textContent : '').trim(),
        };
      });

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const live = document.getElementById('nav-live');
      const palette = document.getElementById('palette');
      const kbtoggle = document.getElementById('kbtoggle');

      function announce(msg) { if (live) live.textContent = msg; }

      function go(entry) {
        if (!entry) return;
        if (entry.mode === 'route') {
          announce('Opening ' + entry.name);
          window.location.href = entry.target;
          return;
        }
        const el = document.getElementById(entry.target);
        if (!el) return;
        el.scrollIntoView({ behavior: prefersReduced ? 'auto' : 'smooth', block: 'start' });
        announce('Jumped to ' + entry.ix + ' ' + entry.name);
      }

      function entryFromEl(el) {
        return {
          mode: el.getAttribute('data-mode'),
          target: el.getAttribute('data-target'),
          name: el.getAttribute('data-name'),
          ix: '',
        };
      }

      // ---- Click path: TOC rows and palette rows use the SAME smooth jump ----
      function wireClicks(selector) {
        document.querySelectorAll(selector).forEach(function (el) {
          el.addEventListener('click', function (ev) {
            const entry = entryFromEl(el);
            if (entry.mode === 'scroll') {
              ev.preventDefault();
              closePalette();
              go(entry);
            }
            // route mode: let the native link/navigation proceed
          });
        });
      }
      wireClicks('.toc .row');
      wireClicks('.palette-row');

      // ---- Palette open / close ----
      function openPalette() {
        palette.setAttribute('data-open', 'true');
        kbtoggle.setAttribute('aria-expanded', 'true');
        const first = palette.querySelector('.palette-row');
        if (first) first.focus();
      }
      function closePalette() {
        palette.setAttribute('data-open', 'false');
        kbtoggle.setAttribute('aria-expanded', 'false');
      }
      kbtoggle.addEventListener('click', openPalette);
      document.getElementById('palette-close').addEventListener('click', closePalette);
      palette.addEventListener('click', function (ev) { if (ev.target === palette) closePalette(); });

      // ---- Keyboard signature ----
      window.addEventListener('keydown', function (e) {
        if (e.metaKey || e.ctrlKey || e.altKey) return;
        const t = e.target;
        if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;

        if (e.key === 'Escape') { closePalette(); return; }
        if (e.key === '?' || e.key === '/') {
          e.preventDefault();
          if (palette.getAttribute('data-open') === 'true') closePalette(); else openPalette();
          return;
        }
        if (map[e.key]) {
          e.preventDefault();
          closePalette();
          go(map[e.key]);
        }
      });

      // ---- Scroll-sync: live "you are here" readout + current TOC row ----
      const hereNo = document.getElementById('here-no');
      const hereNm = document.getElementById('here-nm');
      // Only in-page (scroll) entries can be "current".
      const scrollEntries = rows.filter(function (r) { return r.getAttribute('data-mode') === 'scroll'; });
      const sectionEls = scrollEntries
        .map(function (r) {
          const el = document.getElementById(r.getAttribute('data-target'));
          return el ? { el: el, row: r,
            no: (r.querySelector('.ix') ? r.querySelector('.ix').textContent : '').trim(),
            name: r.getAttribute('data-name') } : null;
        })
        .filter(Boolean);

      let current = null;
      function setCurrent(item) {
        if (current === item) return;
        current = item;
        rows.forEach(function (r) { r.removeAttribute('data-current'); });
        if (item) {
          item.row.setAttribute('data-current', 'true');
          if (hereNo) hereNo.textContent = item.no;
          if (hereNm) hereNm.textContent = item.name;
        }
      }

      if ('IntersectionObserver' in window && sectionEls.length) {
        const visible = new Set();
        const io = new IntersectionObserver(function (entries) {
          entries.forEach(function (en) {
            const found = sectionEls.find(function (s) { return s.el === en.target; });
            if (!found) return;
            if (en.isIntersecting) visible.add(found); else visible.delete(found);
          });
          // pick the topmost visible section
          let best = null, bestTop = Infinity;
          visible.forEach(function (s) {
            const top = s.el.getBoundingClientRect().top;
            if (top < bestTop) { bestTop = top; best = s; }
          });
          if (best) setCurrent(best);
        }, { rootMargin: '-90px 0px -55% 0px', threshold: 0 });
        sectionEls.forEach(function (s) { io.observe(s.el); });
      }
    })();
  </script>
</body>
</html>
