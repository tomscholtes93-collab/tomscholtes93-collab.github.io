          <a href="mailto:tom@tomscholtes.com">Email</a>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="foot-grid">
        <div class="foot-brand">
          <div style="display:flex;align-items:center;gap:10px;">
            <span class="tmark">T</span><b>Tom Scholtes</b>
          </div>
          <div class="tag">Notes on AI in finance ops, a live CV, and a portfolio of work.</div>
        </div>
        <div class="foot-col">
          <h5>Site</h5>
          <a href="/#now">Now</a>
          <a href="/#work">Work</a>
          <a href="/projects">Projects</a>
          <a href="/notes/">Notes</a>
          <a href="/#cv">CV</a>
          <a href="/#reading">Reading</a>
        </div>
        <div class="foot-col">
          <h5>Elsewhere</h5>
          <a href="https://www.linkedin.com/in/tomscholtes93/">LinkedIn</a>
          <a href="/thesis">MSc thesis</a>
        </div>
        <div class="foot-col">
          <h5>Contact</h5>
          <a href="mailto:tom@tomscholtes.com">tom@tomscholtes.com</a>
          <a href="/#contact">Say hi</a>
        </div>
      </div>
      <div class="foot-bot">
        <span>&copy; {year} Tom Scholtes · Luxembourg</span>
        <span>Personal site · opinions my own</span>
      </div>
    </footer>

  </div>

  <!-- aria-live announce for the keyboard signature -->
  <div class="toast" id="toast" role="status" aria-live="polite"><span class="t-ix" id="toastIx"></span><span id="toastTx"></span></div>

  <script>
    /* =========================================================
       SIGNATURE INTERACTION: the keyboard-driven index.
       Every printed index number (00-08) jumps somewhere truthful.
       - In-page entries scroll to their anchor (smooth).
       - Off-page entries (02 Projects, 03 Notes) navigate to the route.
       The map is built from the SAME nav table that prints the index,
       so the keys can never contradict what is on screen.
       ========================================================= */
    (function () {
      const toc = document.getElementById('toc');
      if (!toc) return;

      // Build {digit -> {target, kind, name, ix}} straight from the DOM rows.
      const rows = Array.prototype.slice.call(toc.querySelectorAll('.row'));
      const byDigit = {};
      rows.forEach(function (row) {
        const ix = row.getAttribute('data-ix');         // "00".."08"
        const digit = String(parseInt(ix, 10));         // "0".."8"
        byDigit[digit] = {
          target: row.getAttribute('data-target'),
          kind: row.getAttribute('data-kind'),
          name: (row.querySelector('.nm') || {}).textContent || '',
          ix: ix,
          row: row,
        };
      });

      const prefersReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function scrollToId(hash) {
        const el = document.querySelector(hash);
        if (!el) return false;
        el.scrollIntoView({ behavior: prefersReduce ? 'auto' : 'smooth', block: 'start' });
        return true;
      }

      // toast / aria-live announce
      const toast = document.getElementById('toast');
      const toastIx = document.getElementById('toastIx');
      const toastTx = document.getElementById('toastTx');
      let toastTimer = null;
      function announce(ix, name) {
        if (!toast) return;
        toastIx.textContent = ix;
        toastTx.textContent = name;
        toast.setAttribute('data-show', '1');
        clearTimeout(toastTimer);
        toastTimer = setTimeout(function () { toast.removeAttribute('data-show'); }, 1600);
      }

      // Make clicked index rows behave EXACTLY like the keyboard path:
      // same target, same smooth scroll, for in-page entries.
      rows.forEach(function (row) {
        if (row.getAttribute('data-kind') !== 'page') return; // routes follow normal href
        row.addEventListener('click', function (e) {
          const hash = row.getAttribute('data-target');
          if (hash && hash.charAt(0) === '#') {
            e.preventDefault();
            if (scrollToId(hash)) {
              history.replaceState(null, '', hash);
              announce(row.getAttribute('data-ix'), row.querySelector('.nm').textContent);
            }
          }
        });
      });

      function jump(entry) {
        if (!entry) return;
        if (entry.kind === 'route') {
          announce(entry.ix, entry.name + ' →');
          window.location.href = entry.target;     // truthful navigation, no dead key
          return;
        }
        if (scrollToId(entry.target)) {
          history.replaceState(null, '', entry.target);
          announce(entry.ix, entry.name);
        }
      }

      function isTypingTarget(t) {
        if (!t) return false;
        if (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.tagName === 'SELECT') return true;
        if (t.isContentEditable) return true;
        return false;
      }

      window.addEventListener('keydown', function (e) {
        if (e.metaKey || e.ctrlKey || e.altKey) return;
        if (isTypingTarget(e.target)) return;
        if (e.key < '0' || e.key > '8') return;     // only the printed index digits
        if (e.key.length !== 1) return;
        const entry = byDigit[e.key];
        if (!entry) return;
        e.preventDefault();
        jump(entry);
      });

      /* =========================================================
         SCROLL-SYNCED "you are here" instrument.
         Mirrors the current section's numeral in the topbar AND
         highlights the matching index row, so the index reads as
         live navigable state, not static decoration.
         ========================================================= */
      const hereIx = document.getElementById('hereIx');
      const hereNm = document.getElementById('hereNm');

      // Map each watched section element to its index entry.
      // Languages has no nav number; it inherits 07 (Reading) for the read-out.
      const watch = [
        { id: 'now', ix: '00', nm: 'Now' },
        { id: 'work', ix: '01', nm: 'Work' },
        { id: 'workflow', ix: '04', nm: 'Workflow Automation' },
        { id: 'cv', ix: '05', nm: 'CV' },
        { id: 'reading', ix: '07', nm: 'Reading' },
        { id: 'languages', ix: '07', nm: 'Reading' },
        { id: 'top', ix: '00', nm: 'Identity' },
        { id: 'contact', ix: '08', nm: 'Contact' },
      ];
      const watched = watch
        .map(function (w) { const el = document.getElementById(w.id); return el ? { el: el, w: w } : null; })
        .filter(Boolean);

      const rowByIx = {};
      rows.forEach(function (r) { rowByIx[r.getAttribute('data-ix')] = r; });

      let currentIx = null;
      function setCurrent(w) {
        if (!w) return;
        if (hereIx) hereIx.textContent = w.ix;
        if (hereNm) hereNm.textContent = w.nm;
        if (w.ix === currentIx) return;
        currentIx = w.ix;
        rows.forEach(function (r) { r.removeAttribute('data-current'); });
        if (rowByIx[w.ix]) rowByIx[w.ix].setAttribute('data-current', '1');
      }

      if ('IntersectionObserver' in window) {
        // Track the section whose header is nearest the top of the viewport.
        const visible = new Map();
        const io = new IntersectionObserver(function (entries) {
          entries.forEach(function (en) {
            if (en.isIntersecting) visible.set(en.target, en.intersectionRatio);
            else visible.delete(en.target);
          });
          // Pick the topmost visible watched section.
          let best = null, bestTop = Infinity;
          watched.forEach(function (item) {
            if (!visible.has(item.el)) return;
            const top = item.el.getBoundingClientRect().top;
            if (top < bestTop) { bestTop = top; best = item.w; }
          });
          if (best) setCurrent(best);
        }, { rootMargin: '-90px 0px -55% 0px', threshold: [0, 0.01, 0.2] });
        watched.forEach(function (item) { io.observe(item.el); });
      }

      // Initialise read-out on load.
      setCurrent({ ix: '00', nm: 'Now' });
    })();
  </script>
</body>
</html>
