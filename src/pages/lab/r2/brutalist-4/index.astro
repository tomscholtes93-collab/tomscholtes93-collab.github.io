const year = new Date().getFullYear();

// ---- DATA (verbatim from parent) ----
// nav: [index, name, target]. `target` is either an in-page id (#id) or a route (/...).
// `kind` derived below: 'page' = in-page anchor + smooth scroll; 'route' = navigate away.
