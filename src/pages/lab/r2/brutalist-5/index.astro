const year = new Date().getFullYear();

// ---- DATA (verbatim from parent) ----
// nav: [number, name, target]. target is either a bare in-page id (#anchor
// resolved at runtime) or an off-page route. `kind` tells the keyboard index
// and the click handler how to resolve it so EVERY index number is truthful.
const nav = [
  ['00', 'Now', 'now', 'anchor'],
  ['01', 'Work', 'work', 'anchor'],
  ['02', 'Projects', '/projects/', 'route'],
  ['03', 'Notes', '/notes/', 'route'],
  ['04', 'Workflow Automation', 'workflow', 'anchor'],
  ['05', 'CV', 'cv', 'anchor'],
  ['06', 'Thesis', '/thesis/', 'route'],
  ['07', 'Reading', 'reading', 'anchor'],
  ['08', 'Contact', 'contact', 'anchor'],
];

const stages = [
  ['Find', 'Reads the source files and surfaces what is unbooked, mismatched, or missing.'],
  ['Build', 'Generates the upload template for the accounting system and drafts the counterparty email.'],
  ['Sign off', 'The operator reviews and approves. The human owns the decision.'],
  ['Scale', 'The same approach maps every other workflow in the company, from the existing mailbox.'],
