const experience = [
  ['Mar 2025 · Present', 'Working in Controlling', 'SPV Controller', [
    'End-to-end SPV finance, statutory reporting, cash flows and investor distributions. Hands-on in fund-administration platforms. Construction and maintenance of waterfall models. LuxGAAP / eCDF annual accounts and BCL Annex IV filings.',
    'Payment automation across the SPV book: batch generation, exception routing, recharge / intercompany cases.',
    'Cross-system fund-data integration architecture.',
    'Task management workstream via MCP: Outlook + Monday.com wired into Claude Code through MCP.',
  ]],
  ['Feb 2023 · Mar 2025', 'Alter Domus', 'Fund & Corporate Services Officer', [
    'Full-cycle accounting for management companies, funds, SPVs and GPs. NAVs, financial statements, CSSF/BCL regulatory filings. Drove process improvements through technology and structured methodologies.',
  ]],
  ['Sep 2022 · Jan 2023', 'Waystone Administration Solutions', 'Junior Associate Fund Accountant', [
    'Capital calls, distributions, OPEX payments. LuxGAAP financial statements. Audit coordination. Fund-administration platform import automation.',
  ]],
  ['Feb 2021 · Aug 2022', 'Aztec Group', 'Junior Depositary Analyst', [
    'Asset confirmation and reconciliation for alternative investment funds. Depositary obligations and oversight duties. eFront reporting.',
  ]],
  ['Nov 2019 · Nov 2020', 'European Fund Administration', 'Intern Fund Accountant', [
    'NAV calculations, financial-statement preparation, first-level controls and reconciliations. Year-end audit support.',
  ]],
];

const education = [
  ['2017 · 2020', 'Erasmus School of Economics, University of Rotterdam', 'MSc Economics & Business, International Economics'],
  ['2014 · 2017', 'University of Luxembourg', 'BSc Economics, Law & Management'],
];

const skills = [
  ['Data analysis', 'Panel econometrics · fixed-effects OLS · large multi-source datasets · Python · advanced Excel'],
  ['Accounting systems', 'eFront · BOB50 · SAP · alternative-investment platforms'],
  ['IT / scripting', 'VBA · Python · Microsoft Power Automate'],
  ['Office', 'Advanced Excel · Word · PowerPoint'],
  ['Fund types', 'Private Equity · Private Debt · Real Estate'],
  ['AI tooling', 'Claude · Claude Code · ChatGPT · Glean · Even Realities G2 SDK (assembled stack)'],
  ['AI infra', 'MCP servers · Multi-agent orchestration · Knowledge bases · Local model serving'],
  ['Dev', 'TypeScript · Astro · React · GitHub Actions · Tailscale'],
  ['Frameworks', 'LuxGAAP · eCDF · CSSF / BCL filings'],
];

const reading = [
  ['Systems & ops quality', 'How operational excellence actually gets built and kept. Applies to finance ops as much as to engineering.'],
  ['Knowledge engineering', 'Encoding expertise into tools other people can use without becoming experts themselves.'],
  ['AI & cognition', 'Practical books on what current AI can and cannot do, and where it changes the work.'],
  ['Economics & finance', 'Continuing the line my degrees started. International economics, capital markets, regulation.'],
];

const languages = [
  ['EN', 'English'],
  ['DE', 'Deutsch'],
  ['FR', 'Français'],
  ['RU', 'Русский'],
  ['LU', 'Lëtzebuergesch'],
  ['UZ', 'Oʻzbekcha'],
];

// ---- DERIVED COUNTS (audit fix: never hand-type a count again) ----
const caseCount = cases.length;          // 9
const roleCount = experience.length;     // 5
const degreeCount = education.length;    // 2
const skillCount = skills.length;        // 9
const langCount = languages.length;      // 6
const yearsLabel = '6+ yrs';

const stats = [
  [yearsLabel, 'in Lux fund services'],
  [String(caseCount), 'case studies on file'],
  [String(langCount), 'languages spoken'],
];

// FIG numbers per section, matching the index. Turns the page into a coherent
// figure catalogue (the graph-paper glyph motif extended page-wide).
const FIG = {
  identity: '00', now: '00', work: '01', workflow: '04',
  cv: '05', reading: '07', languages: '06', contact: '08',
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Tom Scholtes. Finance ops engineer who automates the work in reach.</title>
  <style>
    :root{
      --ink:#0b0b0b;
      --paper:#f3f1ea;
      --line:#0b0b0b;
      --accent:#ff3b00;
      --mut:#6a6a64;
      --hair:1px;
      --pad:clamp(14px,3.2vw,28px);
    }
    *{box-sizing:border-box;}
    html{-webkit-text-size-adjust:100%;scroll-behavior:smooth;}
    @media (prefers-reduced-motion: reduce){html{scroll-behavior:auto;}}
    body{
      margin:0;
      background:var(--paper);
      color:var(--ink);
      font-family:"JetBrains Mono",ui-monospace,SFMono-Regular,Menlo,monospace;
      font-size:13px;
      line-height:1.45;
      -webkit-font-smoothing:antialiased;
    }
    a{color:inherit;text-decoration:none;}
    ::selection{background:var(--accent);color:var(--paper);}

    .wrap{max-width:1320px;margin:0 auto;border-left:var(--hair) solid var(--line);border-right:var(--hair) solid var(--line);}
    section{scroll-margin-top:54px;}

    /* ---- generic row primitives ---- */
    .row{display:grid;border-bottom:var(--hair) solid var(--line);}
    .mono-cap{font-weight:700;text-transform:uppercase;letter-spacing:.14em;font-size:10px;}
    .mut{color:var(--mut);}

    /* ---- TOP BAR (running instrument) ---- */
    .topbar{
      display:grid;grid-template-columns:1fr auto;align-items:stretch;
      border-bottom:2px solid var(--line);position:sticky;top:0;z-index:30;background:var(--paper);
    }
    .brand{display:flex;align-items:center;gap:12px;padding:10px var(--pad);min-width:0;}
    .tmark{
      width:26px;height:26px;display:grid;place-items:center;background:var(--ink);color:var(--paper);
      font-weight:700;font-size:14px;flex:none;
    }
    .brand b{font-weight:700;letter-spacing:.04em;white-space:nowrap;}
    .brand .crumb{margin-left:8px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    /* live "you are here" readout: the index numeral + name of current section */
    .here{display:inline-flex;align-items:baseline;gap:7px;margin-left:10px;padding:2px 8px;border:var(--hair) solid var(--line);}
    .here .hn{font-weight:700;color:var(--accent);font-size:12px;}
    .here .hl{font-size:9px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink);}
    @media (prefers-reduced-motion: no-preference){.here .hn{transition:color .15s ease;}}
    .topbar-meta{display:flex;align-items:center;gap:14px;padding:10px var(--pad);border-left:var(--hair) solid var(--line);}
    .langset{font-size:10px;letter-spacing:.14em;font-weight:500;}
    /* keyboard affordance chip: discoverability for the signature interaction */
    .keyhint{
      display:inline-flex;align-items:center;gap:7px;font-size:9px;letter-spacing:.1em;
      text-transform:uppercase;color:var(--mut);border:var(--hair) solid var(--line);
      padding:5px 9px;cursor:pointer;background:var(--paper);font-family:inherit;
    }
    .keyhint kbd{
      font-family:inherit;font-weight:700;color:var(--ink);background:var(--paper);
      border:var(--hair) solid var(--line);border-radius:2px;padding:1px 5px;font-size:9px;line-height:1;
    }
    @media (prefers-reduced-motion: no-preference){.keyhint{transition:background .12s,color .12s;}}
    .keyhint:hover{background:var(--ink);color:var(--paper);}
    .keyhint:hover kbd{background:transparent;color:var(--paper);border-color:#555;}
    .saychip{
      background:var(--accent);color:var(--paper);padding:6px 12px;font-weight:700;font-size:10px;
      letter-spacing:.14em;text-transform:uppercase;
    }
    @media (prefers-reduced-motion: no-preference){.saychip{transition:transform .12s ease,box-shadow .12s ease;}}
    .saychip:hover{transform:translate(-2px,-2px);box-shadow:3px 3px 0 var(--ink);}

    /* thin scroll-progress rule pinned to the bottom of the sticky bar */
    .progress{height:2px;background:transparent;position:relative;}
    .progress::after{content:"";position:absolute;left:0;top:0;bottom:0;width:var(--prog,0%);background:var(--accent);}
    @media (prefers-reduced-motion: no-preference){.progress::after{transition:width .08s linear;}}

    /* ---- STATUS STRIP (replaces decorative marquee with live info) ---- */
    .statusbar{
      display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:0;
      border-bottom:2px solid var(--line);background:var(--ink);color:var(--paper);
      font-size:10px;letter-spacing:.16em;text-transform:uppercase;font-weight:500;
    }
    .statusbar > *{padding:8px var(--pad);}
    .statusbar .s-mid{border-left:var(--hair) solid #444;border-right:var(--hair) solid #444;color:#cfcdc6;}
    .statusbar .s-dot{color:var(--accent);}
    .statusbar .live{display:inline-flex;align-items:center;gap:8px;}
    .statusbar .live .led{width:7px;height:7px;background:var(--accent);border-radius:50%;display:inline-block;}
    @media (prefers-reduced-motion: no-preference){.statusbar .live .led{animation:pulse 2.4s ease-in-out infinite;}}
    @keyframes pulse{0%,100%{opacity:1;}50%{opacity:.25;}}

    /* ---- INDEX NAV (table of contents) ---- */
    .toc .row{grid-template-columns:64px 1fr 130px;align-items:center;}
    .toc .row > *{padding:11px var(--pad);}
    .toc .ix{font-weight:700;color:var(--accent);border-right:var(--hair) solid var(--line);}
    .toc .nm{font-size:clamp(15px,2.6vw,22px);font-weight:500;letter-spacing:-.01em;}
    .toc .go{text-align:right;font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--mut);border-left:var(--hair) solid var(--line);}
    @media (prefers-reduced-motion: no-preference){.toc .row{transition:background .1s,color .1s;}}
    .toc .row:hover{background:var(--ink);color:var(--paper);}
    .toc .row:hover .go{color:var(--accent);}
    .toc .row:hover .ix{color:var(--accent);}
    /* current-section marker in the index (persistent state, not just hover) */
    .toc .row[data-active="1"]{background:var(--ink);color:var(--paper);}
    .toc .row[data-active="1"] .ix{color:var(--accent);}
    .toc .row[data-active="1"] .go::before{content:"here · ";color:var(--accent);}

    /* ---- SECTION HEADER ---- */
    .sec-head{
      display:grid;grid-template-columns:64px 1fr;border-bottom:2px solid var(--line);
      background:var(--ink);color:var(--paper);position:relative;
    }
    .sec-head .big{font-size:clamp(40px,9vw,90px);font-weight:700;line-height:.9;padding:8px 0 8px;text-align:center;border-right:var(--hair) solid #444;display:flex;align-items:center;justify-content:center;}
    .sec-head .htxt{padding:14px var(--pad);display:flex;flex-direction:column;justify-content:center;gap:6px;}
    .sec-head .eyebrow{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);font-weight:700;display:flex;gap:10px;align-items:center;}
    .sec-head .eyebrow .fig{color:#888;font-weight:500;}
    .sec-head h2{margin:0;font-family:"Instrument Serif",Georgia,serif;font-weight:400;font-size:clamp(22px,4.4vw,38px);line-height:1.05;letter-spacing:.005em;}
    .sec-head h2 em{font-style:italic;color:var(--accent);}
    .sec-head .blurb{font-size:11.5px;color:#cfcdc6;max-width:62ch;}
    .sec-head .blurb i{font-style:italic;color:#fff;}

    /* ---- HERO ---- */
    .hero{display:grid;grid-template-columns:1.55fr 1fr;border-bottom:2px solid var(--line);}
    .hero-l{padding:var(--pad);border-right:var(--hair) solid var(--line);}
    .hero-eyebrow{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);font-weight:700;margin-bottom:18px;}
    .hero-name{font-family:"Instrument Serif",Georgia,serif;font-weight:400;font-size:clamp(34px,7vw,82px);line-height:.94;letter-spacing:-.01em;margin:0 0 6px;}
    .hero-role{font-size:11px;letter-spacing:.04em;color:var(--mut);max-width:60ch;margin-bottom:22px;}
    .hero-head{font-family:"Instrument Serif",Georgia,serif;font-weight:400;font-size:clamp(24px,4.6vw,46px);line-height:1.04;margin:0 0 18px;}
    .hero-head em{font-style:italic;color:var(--accent);}
    .hero-lead{font-size:12.5px;line-height:1.65;max-width:64ch;margin:0 0 24px;}
    .hero-cta{display:flex;gap:0;border:var(--hair) solid var(--line);width:fit-content;max-width:100%;flex-wrap:wrap;}
    .btn{padding:12px 20px;font-weight:700;font-size:11px;letter-spacing:.12em;text-transform:uppercase;}
    .btn.p{background:var(--accent);color:var(--paper);}
    .btn.g{border-left:var(--hair) solid var(--line);}
    @media (prefers-reduced-motion: no-preference){.btn{transition:background .12s,color .12s,transform .12s;}}
    .btn.g:hover{background:var(--ink);color:var(--paper);}

    .hero-r{display:grid;grid-template-rows:auto 1fr;}
    .hero-stats{display:grid;}
    .stat{padding:var(--pad);border-bottom:var(--hair) solid var(--line);}
    .stat .v{font-size:clamp(34px,5vw,56px);font-weight:700;line-height:1;letter-spacing:-.02em;}
    .stat .l{font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--mut);margin-top:6px;}
    .glyph{
      flex:1;display:grid;place-items:center;overflow:hidden;position:relative;
      background:
        repeating-linear-gradient(0deg, transparent 0 13px, rgba(11,11,11,.07) 13px 14px),
        repeating-linear-gradient(90deg, transparent 0 13px, rgba(11,11,11,.07) 13px 14px);
    }
    .glyph .ts{font-family:"Instrument Serif",Georgia,serif;font-size:clamp(120px,24vw,260px);line-height:.8;color:var(--ink);opacity:.96;}
    .glyph .sub{position:absolute;bottom:10px;left:0;right:0;text-align:center;font-size:9px;letter-spacing:.3em;text-transform:uppercase;color:var(--mut);}

    /* ---- WORKFLOW STAGES ---- */
    .stages{display:grid;grid-template-columns:repeat(4,1fr);border-bottom:var(--hair) solid var(--line);}
    .stage{padding:var(--pad);border-right:var(--hair) solid var(--line);}
    .stage:last-child{border-right:0;}
    .stage .n{font-size:10px;font-weight:700;color:var(--accent);letter-spacing:.14em;}
    .stage h4{margin:6px 0 8px;font-size:15px;font-weight:700;}
    .stage p{margin:0;font-size:11px;color:var(--mut);line-height:1.55;}
    .wf-blurb{padding:var(--pad);border-bottom:var(--hair) solid var(--line);font-size:12px;line-height:1.6;max-width:80ch;}
    .wf-cta{padding:14px var(--pad);border-bottom:2px solid var(--line);}

    /* ---- CASES ---- */
    .case-bar{
      display:flex;flex-wrap:wrap;gap:0;border-bottom:2px solid var(--line);
      background:#e7e4da;align-items:stretch;
    }
    .case-bar .cb-lbl{padding:9px var(--pad);font-size:9px;letter-spacing:.18em;text-transform:uppercase;font-weight:700;border-right:var(--hair) solid var(--line);display:flex;align-items:center;}
    .filt{
      padding:9px 14px;font-family:inherit;font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;
      font-weight:500;background:transparent;border:0;border-right:var(--hair) solid var(--line);cursor:pointer;color:var(--ink);
    }
    @media (prefers-reduced-motion: no-preference){.filt{transition:background .12s,color .12s;}}
    .filt:hover{background:var(--ink);color:var(--paper);}
    .filt[aria-pressed="true"]{background:var(--accent);color:var(--paper);font-weight:700;}
    .filt .ct{color:var(--mut);margin-left:6px;font-weight:700;}
    .filt[aria-pressed="true"] .ct{color:var(--paper);}

    .case{
      display:grid;grid-template-columns:80px 200px 1fr;border-bottom:var(--hair) solid var(--line);align-items:stretch;
    }
    .case > *{padding:16px var(--pad);}
    .case .c-no{font-size:clamp(28px,5vw,52px);font-weight:700;line-height:.9;color:var(--ink);border-right:var(--hair) solid var(--line);display:flex;align-items:flex-start;}
    .case .c-metric{border-right:var(--hair) solid var(--line);display:flex;flex-direction:column;gap:6px;}
    .case .c-metric .mv{font-family:"Instrument Serif",Georgia,serif;font-size:22px;line-height:1;color:var(--accent);}
    .case .c-metric .ml{font-size:10px;color:var(--mut);letter-spacing:.04em;line-height:1.4;text-transform:uppercase;}
    .case .c-body{display:flex;flex-direction:column;gap:10px;}
    .case .c-title{font-size:clamp(15px,2.4vw,20px);font-weight:700;display:flex;justify-content:space-between;gap:14px;align-items:baseline;}
    .case .c-title .arr{color:var(--accent);font-weight:700;}
    .case .c-blurb{font-size:11.5px;color:#2a2a26;line-height:1.6;max-width:78ch;}
    .case .c-tags{display:flex;flex-wrap:wrap;gap:6px;align-items:center;}
    .tag{border:var(--hair) solid var(--line);padding:3px 8px;font-size:9.5px;letter-spacing:.06em;text-transform:uppercase;font-weight:500;}
    /* second functional color logic: shipped vs proposed vs personal */
    .badge{padding:3px 8px;font-size:9px;letter-spacing:.1em;text-transform:uppercase;font-weight:700;}
    .badge.shipped{background:var(--ink);color:var(--paper);}
    .badge.proposed{border:var(--hair) dashed var(--line);color:var(--mut);}
    .badge.personal{border:var(--hair) solid var(--accent);color:var(--accent);}
    @media (prefers-reduced-motion: no-preference){.case{transition:background .1s;}}
    .case:hover{background:#e7e4da;}
    .case:hover .c-no{color:var(--accent);}
    .case[hidden]{display:none;}

    /* ---- KEY/VALUE rows (Now) ---- */
    .kv{display:grid;grid-template-columns:200px 1fr;border-bottom:var(--hair) solid var(--line);}
    .kv .k{padding:16px var(--pad);font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:.06em;border-right:var(--hair) solid var(--line);color:var(--accent);}
    .kv .v{padding:16px var(--pad);font-size:11.5px;line-height:1.65;}
    .kv .v a{color:var(--ink);font-weight:700;border-bottom:2px solid var(--accent);}
    .kv .v a:hover{background:var(--accent);color:var(--paper);}

    /* ---- CV ---- */
    .cv-sub{display:grid;grid-template-columns:200px 1fr;border-bottom:2px solid var(--line);background:#e7e4da;}
    .cv-sub .lbl{padding:10px var(--pad);font-weight:700;text-transform:uppercase;letter-spacing:.16em;font-size:11px;border-right:var(--hair) solid var(--line);}
    .cv-sub .sum{padding:10px var(--pad);font-size:11px;color:var(--mut);letter-spacing:.04em;display:flex;align-items:center;}
    .job{display:grid;grid-template-columns:200px 1fr;border-bottom:var(--hair) solid var(--line);}
    .job .when{padding:16px var(--pad);font-size:11px;color:var(--mut);border-right:var(--hair) solid var(--line);font-weight:500;}
    .job .det{padding:16px var(--pad);}
    .job .org{font-size:16px;font-weight:700;}
    .job .title{font-size:12px;color:var(--accent);font-weight:500;margin:2px 0 10px;letter-spacing:.02em;}
    .job ul{margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:7px;}
    .job li{font-size:11.5px;line-height:1.55;padding-left:16px;position:relative;}
    .job li::before{content:"/";position:absolute;left:0;color:var(--accent);font-weight:700;}
    .pub .det .org{font-family:"Instrument Serif",Georgia,serif;font-weight:400;font-size:18px;line-height:1.2;}
    .pub-cta{display:inline-block;margin-top:10px;font-weight:700;font-size:11px;letter-spacing:.12em;text-transform:uppercase;border-bottom:2px solid var(--accent);}

    /* ---- READING / LANGUAGES grids ---- */
    .grid2{display:grid;grid-template-columns:1fr 1fr;}
    .gcell{padding:var(--pad);border-bottom:var(--hair) solid var(--line);border-right:var(--hair) solid var(--line);}
    .grid2 .gcell:nth-child(2n){border-right:0;}
    .gcell h4{margin:0 0 8px;font-size:15px;font-weight:700;}
    .gcell p{margin:0;font-size:11.5px;color:var(--mut);line-height:1.6;}

    .langs{display:grid;grid-template-columns:repeat(6,1fr);}
    .lang{padding:var(--pad);border-right:var(--hair) solid var(--line);text-align:center;}
    .lang:last-child{border-right:0;}
    .lang .code{font-size:clamp(28px,4vw,46px);font-weight:700;letter-spacing:-.02em;line-height:1;}
    .lang .nm{font-size:10px;margin-top:8px;color:var(--mut);letter-spacing:.06em;}

    /* ---- CONTACT ---- */
    .contact{position:relative;border-bottom:2px solid var(--line);overflow:hidden;background:var(--ink);color:var(--paper);}
    .contact .wm{position:absolute;right:-2vw;top:50%;transform:translateY(-50%);font-family:"Instrument Serif",Georgia,serif;font-size:clamp(160px,34vw,420px);line-height:.7;color:rgba(255,255,255,.06);pointer-events:none;user-select:none;}
    .contact-inner{position:relative;padding:var(--pad);z-index:2;}
    .contact .eyebrow{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);font-weight:700;}
    .contact h2{font-family:"Instrument Serif",Georgia,serif;font-weight:400;font-size:clamp(28px,6vw,60px);line-height:1.02;margin:12px 0;}
    .contact h2 em{font-style:italic;color:var(--accent);}
    .contact p{font-size:12.5px;line-height:1.65;max-width:64ch;color:#cfcdc6;margin:0 0 22px;}
    .contact-cta{display:flex;border:var(--hair) solid #555;width:fit-content;max-width:100%;flex-wrap:wrap;}
    .contact-cta a{padding:13px 20px;font-weight:700;font-size:11px;letter-spacing:.12em;text-transform:uppercase;border-left:var(--hair) solid #555;}
    .contact-cta a:first-child{border-left:0;background:var(--accent);color:var(--paper);}
    @media (prefers-reduced-motion: no-preference){.contact-cta a{transition:background .12s,color .12s;}}
    .contact-cta a:not(:first-child):hover{background:var(--paper);color:var(--ink);}

    /* ---- FOOTER ---- */
    footer{background:var(--ink);color:var(--paper);}
    .foot-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;border-bottom:var(--hair) solid #333;}
    .foot-grid > div{padding:var(--pad);border-right:var(--hair) solid #333;}
    .foot-grid > div:last-child{border-right:0;}
    .foot-brand b{font-weight:700;}
    .foot-brand .tag{font-size:11px;color:#aaa;margin-top:10px;line-height:1.5;max-width:34ch;}
    .foot-col h5{margin:0 0 12px;font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);font-weight:700;}
    .foot-col a{display:block;font-size:11px;color:#ddd;padding:4px 0;}
    .foot-col a:hover{color:var(--accent);}
    .foot-bot{display:flex;justify-content:space-between;gap:14px;flex-wrap:wrap;padding:12px var(--pad);font-size:10px;color:#888;letter-spacing:.06em;}

    /* ---- COMMAND PALETTE (signature, discoverable) ---- */
    .cmdk-back{
      position:fixed;inset:0;z-index:80;background:rgba(11,11,11,.55);
      display:none;align-items:flex-start;justify-content:center;padding:12vh 16px 16px;
    }
    .cmdk-back[data-open="1"]{display:flex;}
    .cmdk{
      width:min(560px,100%);background:var(--paper);border:2px solid var(--line);
      box-shadow:10px 10px 0 rgba(11,11,11,.35);max-height:74vh;display:flex;flex-direction:column;
    }
    @media (prefers-reduced-motion: no-preference){
      .cmdk-back[data-open="1"] .cmdk{animation:pop .14s ease-out;}
    }
    @keyframes pop{from{transform:translateY(-8px);opacity:.6;}to{transform:translateY(0);opacity:1;}}
    .cmdk-head{display:flex;align-items:center;justify-content:space-between;padding:11px var(--pad);border-bottom:2px solid var(--line);}
    .cmdk-head .t{font-size:10px;letter-spacing:.2em;text-transform:uppercase;font-weight:700;}
    .cmdk-head .esc{font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--mut);}
    .cmdk-list{overflow:auto;}
    .cmdk-item{
      display:grid;grid-template-columns:48px 1fr auto;align-items:center;
      border-bottom:var(--hair) solid var(--line);cursor:pointer;width:100%;text-align:left;
      background:transparent;border-left:0;border-right:0;border-top:0;font-family:inherit;color:var(--ink);
    }
    .cmdk-item > *{padding:11px var(--pad);}
    .cmdk-item .ck{font-weight:700;color:var(--accent);border-right:var(--hair) solid var(--line);}
    .cmdk-item .cn{font-size:14px;font-weight:500;}
    .cmdk-item .ct{font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--mut);}
    @media (prefers-reduced-motion: no-preference){.cmdk-item{transition:background .1s;}}
    .cmdk-item:hover,.cmdk-item[data-cursor="1"]{background:var(--ink);color:var(--paper);}
    .cmdk-item:hover .ct,.cmdk-item[data-cursor="1"] .ct{color:var(--accent);}

    /* visually-hidden live region for screen-reader jump announcements */
    .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0;}

    /* ---- REVEAL ON SCROLL (structural, transform-only, gated) ---- */
    @media (prefers-reduced-motion: no-preference){
      .rv{opacity:0;transform:translateY(10px);transition:opacity .42s ease,transform .42s ease;will-change:opacity,transform;}
      .rv[data-seen="1"]{opacity:1;transform:none;}
    }

    /* ---- RESPONSIVE ---- */
    @media (max-width:980px){
      .here{display:none;}
    }
    @media (max-width:820px){
      .hero{grid-template-columns:1fr;}
      .hero-l{border-right:0;border-bottom:var(--hair) solid var(--line);}
      .hero-stats{grid-template-columns:repeat(3,1fr);}
      .stat{border-right:var(--hair) solid var(--line);}
      .stat:last-child{border-right:0;}
      .glyph{min-height:200px;}
      .stages{grid-template-columns:repeat(2,1fr);}
      .stage:nth-child(2n){border-right:0;}
      .foot-grid{grid-template-columns:1fr 1fr;}
    }
    @media (max-width:600px){
      body{font-size:13px;}
      .topbar{grid-template-columns:1fr;}
      .topbar-meta{border-left:0;border-top:var(--hair) solid var(--line);justify-content:space-between;flex-wrap:wrap;}
      .keyhint{display:none;}
      .statusbar{grid-template-columns:1fr;}
      .statusbar .s-mid{border-left:0;border-right:0;border-top:var(--hair) solid #444;border-bottom:var(--hair) solid #444;}
      .toc .row{grid-template-columns:44px 1fr;}
      .toc .go{display:none;}
      .toc .row[data-active="1"] .go{display:none;}
      .sec-head{grid-template-columns:48px 1fr;}
      .case{grid-template-columns:1fr;}
      .case .c-no{border-right:0;border-bottom:var(--hair) solid var(--line);}
      .case .c-metric{border-right:0;border-bottom:var(--hair) solid var(--line);flex-direction:row;flex-wrap:wrap;align-items:baseline;}
      .kv{grid-template-columns:1fr;}
      .kv .k{border-right:0;border-bottom:var(--hair) solid var(--line);}
      .cv-sub{grid-template-columns:1fr;}
      .cv-sub .lbl{border-right:0;border-bottom:var(--hair) solid var(--line);}
      .job{grid-template-columns:1fr;}
      .job .when{border-right:0;border-bottom:var(--hair) solid var(--line);}
      .grid2{grid-template-columns:1fr;}
      .grid2 .gcell{border-right:0;}
      .langs{grid-template-columns:repeat(3,1fr);}
      .lang:nth-child(3n){border-right:0;}
      .lang:nth-child(n+4){border-top:var(--hair) solid var(--line);}
      .stages{grid-template-columns:1fr;}
      .stage{border-right:0;}
      .foot-grid{grid-template-columns:1fr;}
      .foot-grid > div{border-right:0;border-bottom:var(--hair) solid #333;}
    }
  </style>
</head>
<body>
  <div class="wrap">

    <!-- TOP BAR -->
    <div class="topbar">
      <div class="brand">
        <span class="tmark">T</span>
        <b>Tom Scholtes</b>
        <span class="mut mono-cap crumb">Index / Luxembourg</span>
        <span class="here" id="here" aria-hidden="true">
          <span class="hn" id="hereNo">00</span>
          <span class="hl" id="hereName">Now</span>
        </span>
      </div>
      <div class="topbar-meta">
        <span class="langset mut">EN / DE / FR / RU</span>
        <button class="keyhint" id="openCmd" type="button" aria-haspopup="dialog" aria-controls="cmdk">
          <span>Index</span><kbd>/</kbd>
        </button>
        <a class="saychip" href="#contact">Say hi</a>
      </div>
    </div>
    <div class="progress" id="progress" aria-hidden="true"></div>

    <!-- STATUS STRIP (live info, not decorative scroll) -->
    <div class="statusbar" aria-label="Status">
      <span class="live"><span class="led" aria-hidden="true"></span>Open to conversations</span>
      <span class="s-mid"><span class="s-dot">/</span> Finance ops engineer who automates the work in reach</span>
      <span>Lux fund services · PE · Debt · RE</span>
    </div>

    <!-- INDEX / TABLE OF CONTENTS -->
    <nav class="toc" aria-label="Index">
      {nav.map(([n, name, target, kind]) => (
        <a class="row" data-jump={target} data-kind={kind} data-no={n}
           href={kind === 'anchor' ? `#${target}` : target}>
          <div class="ix">{n}</div>
          <div class="nm">{name}</div>
          <div class="go">jump &rarr;</div>
        </a>
      ))}
    </nav>

    <!-- 00 NOW -->
    <section id="now">
      <div class="sec-head">
        <div class="big">00</div>
        <div class="htxt">
          <div class="eyebrow">/ now · June 2026 <span class="fig">FIG. {FIG.now} / FOCUS</span></div>
          <h2>What I'm focused on this quarter.</h2>
          <div class="blurb">A public note of where my head is right now, in the spirit of <i>nownownow.com</i>. I update it when things change, not on a schedule.</div>
        </div>
      </div>
      {nowRows.map((r) => (
        <div class="kv rv">
          <div class="k">{r.k}</div>
          <div class="v">
            {r.v}
            {r.cta && (<> <a href={r.cta[1]}>{r.cta[0]} &rarr;</a></>)}
          </div>
        </div>
      ))}
    </section>

    <!-- 01 WORK / CASE STUDIES -->
    <section id="work">
      <div class="sec-head">
        <div class="big">01</div>
        <div class="htxt">
          <div class="eyebrow">Case studies <span class="fig">FIG. {FIG.work} / WORK · {caseCount} ON FILE</span></div>
          <h2>Patterns I've <em>worked through</em>.</h2>
          <div class="blurb">Sanitised. Employer name, entity names and figures removed. Notes on how I think about this kind of work in fund services.</div>
        </div>
      </div>
      <div class="case-bar" role="group" aria-label="Filter case studies by status">
        <span class="cb-lbl">Filter</span>
        <button class="filt" type="button" data-filter="all" aria-pressed="true">All<span class="ct">{caseCount}</span></button>
        <button class="filt" type="button" data-filter="shipped" aria-pressed="false">Shipped<span class="ct">{cases.filter(c => c.state === 'shipped').length}</span></button>
        <button class="filt" type="button" data-filter="proposed" aria-pressed="false">Proposed<span class="ct">{cases.filter(c => c.state === 'proposed').length}</span></button>
        <button class="filt" type="button" data-filter="personal" aria-pressed="false">Personal<span class="ct">{cases.filter(c => c.state === 'personal').length}</span></button>
      </div>
      <div class="cases" id="cases">
        {cases.map((c) => (
          <a class="case rv" href={c.href} data-state={c.state}>
            <div class="c-no">{c.no}</div>
            <div class="c-metric">
              <span class="mv">{c.metric}</span>
              <span class="ml">{c.mlabel}</span>
            </div>
            <div class="c-body">
              <div class="c-title"><span>{c.title}</span><span class="arr">&rarr;</span></div>
              <div class="c-blurb">{c.blurb}</div>
              <div class="c-tags">
                {c.tags.map((t) => <span class="tag">{t}</span>)}
                {c.state === 'shipped' && <span class="badge shipped">Shipped</span>}
                {c.state === 'proposed' && <span class="badge proposed">Proposed</span>}
                {c.state === 'personal' && <span class="badge personal">Personal</span>}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- 04 WORKFLOW AUTOMATION -->
    <section id="workflow">
      <div class="sec-head">
        <div class="big">04</div>
        <div class="htxt">
          <div class="eyebrow">Live demo <span class="fig">FIG. {FIG.workflow} / AUTOMATION</span></div>
          <h2>See the automation run, on synthetic data.</h2>
          <div class="blurb">Point AI at the manual workflows underneath a finance desk. It surfaces what is unbooked, mismatched, or missing, builds the upload template, and drafts the counterparty email. The operator reviews and signs off; the human owns the decision. Click through a before-and-after process map and run it live.</div>
        </div>
      </div>
      <div class="stages">
        {stages.map(([t, d], i) => (
          <div class="stage rv">
            <div class="n">STAGE {String(i + 1).padStart(2, '0')}</div>
            <h4>{t}</h4>
            <p>{d}</p>
          </div>
        ))}
      </div>
      <div class="wf-cta">
        <a class="btn p" href="/workflow-automation/" style="display:inline-block;border:1px solid var(--line);">Open the live demo &rarr;</a>
      </div>
    </section>

    <!-- 05 CV -->
    <section id="cv">
      <div class="sec-head">
        <div class="big">05</div>
        <div class="htxt">
          <div class="eyebrow">Live CV <span class="fig">FIG. {FIG.cv} / RECORD</span></div>
          <h2>Six years in Luxembourg fund services.</h2>
          <div class="blurb">Updated as roles, projects and credentials change. The condensed PDF version is on request.</div>
        </div>
      </div>

      <div class="cv-sub"><div class="lbl">Experience</div><div class="sum">{roleCount} roles · 6+ years</div></div>
      {experience.map(([when, org, title, bullets]) => (
        <div class="job rv">
          <div class="when">{when}</div>
          <div class="det">
            <div class="org">{org}</div>
            <div class="title">{title}</div>
            <ul>{bullets.map((b) => <li>{b}</li>)}</ul>
          </div>
        </div>
      ))}

      <div class="cv-sub"><div class="lbl">Education</div><div class="sum">{degreeCount} degrees</div></div>
      {education.map(([when, org, title]) => (
        <div class="job rv">
          <div class="when">{when}</div>
          <div class="det">
            <div class="org">{org}</div>
            <div class="title">{title}</div>
          </div>
        </div>
      ))}

      <div class="cv-sub"><div class="lbl">Skills</div><div class="sum">{skillCount} domains</div></div>
      {skills.map(([k, v]) => (
        <div class="kv rv">
          <div class="k" style="color:var(--ink);font-size:12px;">{k}</div>
          <div class="v">{v}</div>
        </div>
      ))}

      <div class="cv-sub"><div class="lbl">Publication</div><div class="sum">1 thesis</div></div>
      <div class="job pub rv">
        <div class="when">MSc thesis</div>
        <div class="det">
          <div class="org">Augmented gravity model: Institutions, Infrastructure and Globalization impact on bilateral exports among OECD countries</div>
          <div class="title" style="margin-top:8px;">MSc thesis · Erasmus University Rotterdam · panel econometrics over 36 OECD economies, 1995 to 2018</div>
          <a class="pub-cta" href="/thesis">Read &rarr;</a>
        </div>
      </div>
    </section>

    <!-- 06 LANGUAGES -->
    <section id="languages">
      <div class="sec-head">
        <div class="big">06</div>
        <div class="htxt">
          <div class="eyebrow">Languages <span class="fig">FIG. {FIG.languages} / TONGUES · {langCount}</span></div>
          <h2>Six, used regularly.</h2>
          <div class="blurb">Spoken regularly. Code and native name; no proficiency levels claimed.</div>
        </div>
      </div>
      <div class="langs">
        {languages.map(([code, nm]) => (
          <div class="lang rv">
            <div class="code">{code}</div>
            <div class="nm">{nm}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- 07 READING -->
    <section id="reading">
      <div class="sec-head">
        <div class="big">07</div>
        <div class="htxt">
          <div class="eyebrow">Reading <span class="fig">FIG. {FIG.reading} / SHELF</span></div>
          <h2>Mostly non-fiction.</h2>
          <div class="blurb">Themes I keep coming back to. A proper bookshelf with titles will go here once I've trimmed the list.</div>
        </div>
      </div>
      <div class="grid2">
        {reading.map(([t, n]) => (
          <div class="gcell rv">
            <h4>{t}</h4>
            <p>{n}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- HERO / IDENTITY (figure cover; index numbers above are the spine) -->
    <section class="hero" id="top">
      <div class="hero-l">
        <div class="hero-eyebrow">Personal site · Luxembourg · FIG. {FIG.identity} / IDENTITY</div>
        <h1 class="hero-name">Tom Scholtes</h1>
        <div class="hero-role">Finance ops engineer who automates the work in reach. Builds AI-augmented automation for the operational work in regulated finance. Six years in Luxembourg fund services across PE, Private Debt and Real Estate.</div>
        <p class="hero-head">I build the automation behind <em>regulated finance</em> operations.</p>
        <p class="hero-lead">I'm Tom. I build AI-augmented automation for the operational work in regulated finance: regulatory notes, accounts quality review, document workflows, mailbox triage, and the reusable tooling that ties them together. Six years in Luxembourg fund services across PE, Private Debt and Real Estate, now spent designing the systems that do the work instead of doing it by hand. This site is the evidence: a live CV, the patterns behind the work, and case studies of it shipping.</p>
        <div class="hero-cta">
          <a class="btn p" href="#work">See the work</a>
          <a class="btn g" href="#contact">Get in touch</a>
        </div>
      </div>
      <div class="hero-r">
        <div class="hero-stats">
          {stats.map(([v, l]) => (
            <div class="stat">
              <div class="v">{v}</div>
              <div class="l">{l}</div>
            </div>
          ))}
        </div>
        <div class="glyph" aria-hidden="true">
          <div class="ts">T</div>
          <div class="sub">FIG. 00 / IDENTITY</div>
        </div>
      </div>
    </section>

    <!-- 08 CONTACT -->
    <section class="contact" id="contact">
      <div class="wm" aria-hidden="true">hi.</div>
      <div class="contact-inner">
        <div class="eyebrow">Contact · FIG. {FIG.contact} / REACH</div>
        <h2>If any of this is <em>interesting</em>, say hi.</h2>
        <p>Always interested in conversations about data engineering, automation, applied AI, multi-agent systems, knowledge engineering, agent infrastructure, especially where they meet regulated workflows.</p>
        <div class="contact-cta">
          <a href="https://www.linkedin.com/messaging/compose/?recipient=tomscholtes93">Message on LinkedIn</a>
          <a href="https://www.linkedin.com/in/tomscholtes93/">View profile</a>
          <a href="mailto:tom@tomscholtes.com">Email</a>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="foot-grid">
        <div class="foot-brand">
          <div style="display:flex;align-items:center;gap:10px;">
            <span class="tmark">T</span><b>Tom Scholtes</b>
          </div>
          <div class="tag">Notes on AI in finance ops, a live CV, and a portfolio of work.</div>
        </div>
        <div class="foot-col">
          <h5>Site</h5>
          <a href="/#now">Now</a>
          <a href="/#work">Work</a>
          <a href="/projects">Projects</a>
          <a href="/notes/">Notes</a>
          <a href="/#cv">CV</a>
          <a href="/#reading">Reading</a>
        </div>
        <div class="foot-col">
          <h5>Elsewhere</h5>
          <a href="https://www.linkedin.com/in/tomscholtes93/">LinkedIn</a>
          <a href="/thesis">MSc thesis</a>
        </div>
        <div class="foot-col">
          <h5>Contact</h5>
          <a href="mailto:tom@tomscholtes.com">tom@tomscholtes.com</a>
          <a href="/#contact">Say hi</a>
        </div>
      </div>
      <div class="foot-bot">
        <span>&copy; {year} Tom Scholtes · Luxembourg</span>
        <span>Personal site · opinions my own</span>
      </div>
    </footer>

  </div>

  <!-- COMMAND PALETTE: discoverable, accessible signature interaction -->
  <div class="cmdk-back" id="cmdkBack" aria-hidden="true">
    <div class="cmdk" id="cmdk" role="dialog" aria-modal="true" aria-label="Site index. Press a number to jump.">
      <div class="cmdk-head">
        <span class="t">Index · press a number</span>
        <span class="esc">esc to close</span>
      </div>
      <div class="cmdk-list" id="cmdkList">
        {nav.map(([n, name, target, kind]) => (
          <button class="cmdk-item" type="button" data-jump={target} data-kind={kind} data-no={n}>
            <span class="ck">{n}</span>
            <span class="cn">{name}</span>
            <span class="ct">{kind === 'route' ? 'open page' : 'jump'} &rarr;</span>
          </button>
        ))}
      </div>
    </div>
  </div>

  <div class="sr-only" id="live" aria-live="polite"></div>

  <script>
    (function () {
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ---- resolve an index target truthfully: anchor scrolls, route navigates ----
      function jump(target, kind, label) {
        if (kind === 'route') {
          window.location.href = target;
          return;
        }
        var el = document.getElementById(target);
        if (!el) { window.location.hash = target; return; }
        el.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'start' });
        if (history.replaceState) history.replaceState(null, '', '#' + target);
        var live = document.getElementById('live');
        if (live && label) live.textContent = 'Jumped to ' + label;
      }

      // unify TOC clicks + command-palette clicks through the same resolver
      function wireJumpers(nodes) {
        for (var i = 0; i < nodes.length; i++) {
          (function (node) {
            node.addEventListener('click', function (e) {
              var kind = node.getAttribute('data-kind');
              var target = node.getAttribute('data-jump');
              if (kind === 'anchor') {
                e.preventDefault();
                jump(target, kind, node.querySelector('.nm,.cn') ? node.querySelector('.nm,.cn').textContent : target);
                closePalette();
              }
              // route links: let the browser navigate naturally
            });
          })(nodes[i]);
        }
      }
      wireJumpers(document.querySelectorAll('.toc .row'));
      wireJumpers(document.querySelectorAll('.cmdk-item'));

      // ---- key -> nav entry map, aligned 1:1 with the printed index ----
      var byNumber = {};
      var navNodes = document.querySelectorAll('.cmdk-item');
      for (var i = 0; i < navNodes.length; i++) {
        var n = navNodes[i].getAttribute('data-no');           // "00".."08"
        byNumber[String(parseInt(n, 10))] = navNodes[i];        // key "0".."8"
      }
      function jumpByKey(k) {
        var node = byNumber[k];
        if (!node) return false;
        jump(node.getAttribute('data-jump'), node.getAttribute('data-kind'),
             node.querySelector('.cn') ? node.querySelector('.cn').textContent : k);
        return true;
      }

      // ---- command palette open/close + cursor navigation ----
      var back = document.getElementById('cmdkBack');
      var items = Array.prototype.slice.call(document.querySelectorAll('.cmdk-item'));
      var cursor = -1, lastFocus = null;
      function setCursor(idx) {
        if (cursor > -1 && items[cursor]) items[cursor].removeAttribute('data-cursor');
        cursor = (idx + items.length) % items.length;
        items[cursor].setAttribute('data-cursor', '1');
        items[cursor].scrollIntoView({ block: 'nearest' });
      }
      function openPalette() {
        lastFocus = document.activeElement;
        back.setAttribute('data-open', '1');
        back.setAttribute('aria-hidden', 'false');
        cursor = -1; setCursor(0);
      }
      function closePalette() {
        if (back.getAttribute('data-open') !== '1') return;
        back.removeAttribute('data-open');
        back.setAttribute('aria-hidden', 'true');
        if (cursor > -1 && items[cursor]) items[cursor].removeAttribute('data-cursor');
        cursor = -1;
        if (lastFocus && lastFocus.focus) lastFocus.focus();
      }
      document.getElementById('openCmd').addEventListener('click', openPalette);
      back.addEventListener('click', function (e) { if (e.target === back) closePalette(); });

      // ---- global key handling ----
      function isTyping(t) {
        if (!t) return false;
        if (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.tagName === 'SELECT') return true;
        if (t.isContentEditable) return true;
        return false;
      }
      window.addEventListener('keydown', function (e) {
        var open = back.getAttribute('data-open') === '1';

        if (open) {
          if (e.key === 'Escape') { e.preventDefault(); closePalette(); return; }
          if (e.key === 'ArrowDown') { e.preventDefault(); setCursor(cursor + 1); return; }
          if (e.key === 'ArrowUp') { e.preventDefault(); setCursor(cursor - 1); return; }
          if (e.key === 'Enter') { e.preventDefault(); if (items[cursor]) items[cursor].click(); return; }
          if (/^[0-8]$/.test(e.key)) { e.preventDefault(); closePalette(); jumpByKey(e.key); return; }
          return;
        }

        if (e.metaKey || e.ctrlKey || e.altKey) return;
        if (isTyping(e.target)) return;

        // open the palette: "/" or "g" (discoverable via the chip + this hint)
        if (e.key === '/' || e.key === 'g' || e.key === 'G') { e.preventDefault(); openPalette(); return; }
        // direct number jump from anywhere: every key 0..8 is truthful
        if (/^[0-8]$/.test(e.key)) { e.preventDefault(); jumpByKey(e.key); return; }
      });

      // ---- "you are here" instrument: topbar readout + active TOC row ----
      var sections = [
        { id: 'now',       no: '00', name: 'Now' },
        { id: 'work',      no: '01', name: 'Work' },
        { id: 'workflow',  no: '04', name: 'Workflow' },
        { id: 'cv',        no: '05', name: 'CV' },
        { id: 'languages', no: '06', name: 'Languages' },
        { id: 'reading',   no: '07', name: 'Reading' },
        { id: 'top',       no: '00', name: 'Identity' },
        { id: 'contact',   no: '08', name: 'Contact' },
      ];
      var hereNo = document.getElementById('hereNo');
      var hereName = document.getElementById('hereName');
      var tocRows = document.querySelectorAll('.toc .row');
      var current = null;
      function setHere(no, name) {
        if (current === no + name) return;
        current = no + name;
        if (hereNo) hereNo.textContent = no;
        if (hereName) hereName.textContent = name;
        for (var i = 0; i < tocRows.length; i++) {
          if (tocRows[i].getAttribute('data-no') === no) tocRows[i].setAttribute('data-active', '1');
          else tocRows[i].removeAttribute('data-active');
        }
      }

      if ('IntersectionObserver' in window) {
        var visible = {};
        var io = new IntersectionObserver(function (entries) {
          for (var i = 0; i < entries.length; i++) {
            var s = sections.filter(function (x) { return x.id === entries[i].target.id; })[0];
            if (!s) continue;
            visible[s.id] = entries[i].isIntersecting ? entries[i].intersectionRatio : 0;
          }
          // pick the most-visible tracked section
          var best = null, bestR = 0;
          for (var k = 0; k < sections.length; k++) {
            var r = visible[sections[k].id] || 0;
            if (r > bestR) { bestR = r; best = sections[k]; }
          }
          if (best) setHere(best.no, best.name);
        }, { rootMargin: '-52px 0px -55% 0px', threshold: [0, 0.15, 0.4, 0.75, 1] });
        for (var i = 0; i < sections.length; i++) {
          var el = document.getElementById(sections[i].id);
          if (el) io.observe(el);
        }
      }

      // ---- scroll progress rule ----
      var prog = document.getElementById('progress');
      var ticking = false;
      function updateProgress() {
        var h = document.documentElement;
        var max = h.scrollHeight - h.clientHeight;
        var pct = max > 0 ? (h.scrollTop / max) * 100 : 0;
        prog.style.setProperty('--prog', pct.toFixed(1) + '%');
        ticking = false;
      }
      window.addEventListener('scroll', function () {
        if (!ticking) { window.requestAnimationFrame(updateProgress); ticking = true; }
      }, { passive: true });
      updateProgress();

      // ---- case-study filter (reinforces the "index" concept) ----
      var filterBtns = document.querySelectorAll('.filt');
      var caseEls = document.querySelectorAll('#cases .case');
      for (var f = 0; f < filterBtns.length; f++) {
        filterBtns[f].addEventListener('click', function () {
          var val = this.getAttribute('data-filter');
          for (var b = 0; b < filterBtns.length; b++) {
            filterBtns[b].setAttribute('aria-pressed', filterBtns[b] === this ? 'true' : 'false');
          }
          for (var c = 0; c < caseEls.length; c++) {
            var show = (val === 'all') || (caseEls[c].getAttribute('data-state') === val);
            if (show) caseEls[c].removeAttribute('hidden');
            else caseEls[c].setAttribute('hidden', '');
          }
        }.bind(filterBtns[f]));
      }

      // ---- reveal-on-scroll (gated; if reduced, everything is shown at once) ----
      if (reduce || !('IntersectionObserver' in window)) {
        var all = document.querySelectorAll('.rv');
        for (var r2 = 0; r2 < all.length; r2++) all[r2].setAttribute('data-seen', '1');
      } else {
        var rvio = new IntersectionObserver(function (entries) {
          for (var i = 0; i < entries.length; i++) {
            if (entries[i].isIntersecting) {
              entries[i].target.setAttribute('data-seen', '1');
              rvio.unobserve(entries[i].target);
            }
          }
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
        var rvs = document.querySelectorAll('.rv');
        for (var v = 0; v < rvs.length; v++) rvio.observe(rvs[v]);
      }
    })();
  </script>
</body>
</html>
