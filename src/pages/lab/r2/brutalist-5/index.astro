  },
  {
    no: '05', metric: 'Onboarding', mlabel: 'structured payment and accounting guide',
    title: 'Process Documentation & Knowledge Transfer',
    blurb: 'Patterns for documenting payment and accounting workflows in a way new joiners can self-serve. Payment flow, exception handling, approval routing, recharge and intercompany cases.',
    tags: ['Technical writing', 'Process mapping'], href: '/case/process-documentation/', state: 'shipped',
  },
  {
    no: '06', metric: 'Implementation', mlabel: 'contribution to platform rollout',
    title: 'Fund Accounting Platform Integration',
    blurb: 'Patterns I’ve worked through during fund-accounting platform rollouts. Pref-share reconciliation logic, waterfall validation approaches, edge-case discovery.',
    tags: ['Reconciliation', 'Vendor collab', 'Validation'], href: '/case/fund-accounting-platform-integration/', state: 'shipped',
  },
  {
    no: '07', metric: 'Library', mlabel: 'of reusable Claude skill patterns',
    title: 'AI Skill Architecture & Reusable Tooling',
    blurb: 'A library of small, opinionated AI skill patterns. Notes generation, quality review, anonymisation, mailbox triage, classification. Each with deterministic inputs and outputs. From single-purpose skills to five-persona orchestration, see Projects.',
    tags: ['Skill design', 'Knowledge eng.', 'Infrastructure'], href: '/case/ai-skill-architecture/', state: 'shipped',
  },
  {
    no: '08', metric: 'Pattern', mlabel: 'designed',
    title: 'Cross-system fund-data reconciliation architecture',
    blurb: 'Designed a bridging architecture for reconciling two source-of-truth platforms in a fund-administration setting while the underlying master data model was still being scoped. Generic pattern. Proposed internally; not deployed.',
    tags: ['Data integration', 'Master data', 'Internal proposal'], href: '/case/cross-system-reconciliation/', state: 'proposed',
  },
  {
    no: '09', metric: 'Pattern', mlabel: 'personal automation architecture',
    title: 'End-to-end email automation',
    blurb: 'An incoming message triggers an agent that fetches attachments, reads them, searches across knowledge systems, delegates research, and once the answer is well grounded drafts a reply and proposes which attachments to attach. A self-review loop runs the draft through a second model until it has no further comments, then hands a clean output to a human reviewer who owns the decision.',
    tags: ['Agentic', 'Self-review loop', 'Human-in-the-loop'], href: '/case/email-automation/', state: 'personal',
  },
];

const nowRows = [
  { k: 'Building', v: 'End-to-end email automation as a personal architecture. An incoming message triggers an agent that fetches attachments, reads them, searches across knowledge systems, delegates research, and once the answer is well grounded drafts the reply and proposes which attachments to include. A self-review loop runs the draft through a second model until it has no further comments, then hands a clean output to a human reviewer who owns the decision.', cta: ['See the demo', '/workflow-automation/'] },
  { k: 'Testing', v: 'Frontier models on large, long-context files. How far the current generation holds up running real workflows over very large inputs.' },
  { k: 'Orchestrating', v: 'Workflow orchestration with n8n, extending the automation surface beyond a single agent.' },
  { k: 'Running', v: 'An agentic memory system on my own infrastructure. A voice-first assistant over AR glasses with a memory that consolidates during sleep, running across two machines that talk to each other, turning ideas into video journals or music within hours.', cta: ['See the project', '/projects/exocortex'] },
  { k: 'Learning', v: 'Cloud computing and GPU inference, to serve models faster and at lower marginal cost.' },
  { k: 'Throughline', v: 'Applied research on frontier models and frontier technologies. Curiosity is the throughline across all of it.' },
