<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Tom Scholtes. Finance ops engineer who automates the work in reach.</title>
  <meta name="description" content="Personal site, live CV, and a portfolio of automation I've built for regulated finance operations. Six years in Luxembourg fund services, now designing the systems that do the work." />
  <style>
    :root {
      --paper: #f7f4ec;
      --paper-2: #f1ece0;
      --ink: #1a1714;
      --ink-soft: #4a443c;
      --ink-faint: #8a8174;
      --rule: #d8d0c0;
      --rule-strong: #b8ad97;
      --accent: #9c3b2e;
      --accent-soft: #c06b56;
      --serif: 'Instrument Serif', Georgia, 'Times New Roman', serif;
      --sans: 'Inter', system-ui, -apple-system, sans-serif;
      --mono: 'JetBrains Mono', ui-monospace, 'SFMono-Regular', monospace;
      --gutter: clamp(20px, 5vw, 64px);
      --rail: 200px;
      --navh: 50px;
    }

    * { box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; scroll-padding-top: calc(var(--navh) + 14px); }

    body {
      margin: 0;
      background: var(--paper);
      color: var(--ink);
      font-family: var(--sans);
      font-size: 16.5px;
      line-height: 1.55;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }
    @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      background-image:
        radial-gradient(circle at 18% 22%, rgba(0,0,0,0.018) 0.6px, transparent 0.6px),
        radial-gradient(circle at 72% 64%, rgba(0,0,0,0.015) 0.6px, transparent 0.6px);
      background-size: 4px 4px, 5px 5px;
      mix-blend-mode: multiply;
    }

    a { color: inherit; }

    .wrap {
      max-width: 1320px;
      margin: 0 auto;
      padding: 0 var(--gutter);
      position: relative;
      z-index: 2;
    }

    /* ---- Top nav strip ---- */
    nav.bar {
      position: sticky;
      top: 0;
      z-index: 30;
      background: color-mix(in srgb, var(--paper) 92%, transparent);
      backdrop-filter: saturate(140%) blur(6px);
      border-bottom: 1px solid var(--ink);
    }
    .nav-inner {
      max-width: 1320px;
      margin: 0 auto;
      padding: 0 var(--gutter);
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: var(--navh);
    }
    .nav-brand {
      display: flex;
      align-items: center;
      gap: 9px;
      font-family: var(--serif);
      font-size: 21px;
      letter-spacing: 0.01em;
      white-space: nowrap;
      text-decoration: none;
    }
    .nav-brand .mark {
      width: 26px; height: 26px;
      display: grid; place-items: center;
      background: var(--ink);
      color: var(--paper);
      font-family: var(--serif);
      font-size: 16px;
      line-height: 1;
    }
    .nav-links {
      display: flex;
      gap: 17px;
      list-style: none;
      margin: 0; padding: 0;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .nav-links a {
      text-decoration: none;
      color: var(--ink-soft);
      white-space: nowrap;
      padding: 3px 0;
      border-bottom: 1px solid transparent;
    }
    .nav-links a:hover { color: var(--accent); border-bottom-color: var(--accent); }
    .nav-right { display: flex; align-items: center; gap: 13px; }
    .lang-switch {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      color: var(--ink-faint);
      white-space: nowrap;
    }
    .lang-switch b { color: var(--ink); font-weight: 700; }
    .nav-cta {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--paper);
      background: var(--accent);
      padding: 7px 13px;
      white-space: nowrap;
    }
    .nav-cta:hover { background: var(--ink); }
    .nav-toggle {
      display: none;
      font-family: var(--mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      background: none;
      border: 1px solid var(--ink);
      color: var(--ink);
      padding: 6px 10px;
      cursor: pointer;
    }

    /* ---- Identity strip (replaces newspaper masthead) ---- */
    .ident {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 16px;
      flex-wrap: wrap;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-faint);
      padding: 16px 0 14px;
      border-bottom: 1px solid var(--rule);
    }
    .ident b { color: var(--ink-soft); font-weight: 500; }
    .ident .status { display: inline-flex; align-items: center; gap: 7px; color: var(--ink-soft); }
    .dot { width: 7px; height: 7px; background: var(--accent); border-radius: 50%; display: inline-block; }
    @media (prefers-reduced-motion: no-preference) {
      .dot { animation: pulse 2.4s ease-in-out infinite; }
      @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.35; } }
    }

    /* ====== Two-column shell: sticky contents rail + content ====== */
    .shell {
      display: grid;
      grid-template-columns: var(--rail) 1fr;
      gap: clamp(28px, 4vw, 56px);
      align-items: start;
    }

    /* ---- Sticky contents rail (the scan index) ---- */
    .toc {
      position: sticky;
      top: calc(var(--navh) + 28px);
      align-self: start;
      padding-top: 44px;
    }
    .toc-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink-faint);
      margin-bottom: 14px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--rule-strong);
    }
    .toc ol { list-style: none; margin: 0; padding: 0; }
    .toc li { margin: 0; }
    .toc a {
      display: grid;
      grid-template-columns: 22px 1fr;
      gap: 9px;
      align-items: baseline;
      text-decoration: none;
      color: var(--ink-soft);
      padding: 7px 0;
      border-left: 2px solid transparent;
      padding-left: 12px;
      margin-left: -14px;
      transition: color 0.18s ease, border-color 0.18s ease;
    }
    .toc a .tn { font-family: var(--mono); font-size: 10px; color: var(--ink-faint); letter-spacing: 0.04em; }
    .toc a .tl { font-family: var(--sans); font-size: 13.5px; font-weight: 500; line-height: 1.2; }
    .toc a:hover { color: var(--accent); }
    .toc a.active { color: var(--accent); border-left-color: var(--accent); }
    .toc a.active .tn { color: var(--accent); }
    .toc-foot {
      margin-top: 22px;
      padding-top: 16px;
      border-top: 1px solid var(--rule);
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.04em;
      color: var(--ink-faint);
      line-height: 1.7;
    }
    .toc-foot a { color: var(--ink-soft); text-decoration: none; border-bottom: 1px solid var(--rule-strong); }
    .toc-foot a:hover { color: var(--accent); border-color: var(--accent); }

    /* ---- Section shell (tighter rhythm) ---- */
    section { padding: clamp(40px, 5.2vw, 72px) 0; border-bottom: 1px solid var(--rule); scroll-margin-top: calc(var(--navh) + 14px); }
    section:first-child { padding-top: 40px; }
    .kicker {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 14px;
    }
    .kicker::before { content: ''; width: 26px; height: 1px; background: var(--accent); }
    h2.feature {
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(32px, 5vw, 58px);
      line-height: 0.98;
      letter-spacing: -0.01em;
      margin: 0 0 0.32em;
    }
    .feature em { font-style: italic; color: var(--accent); }
    .deck {
      font-size: clamp(15.5px, 1.7vw, 18px);
      color: var(--ink-soft);
      max-width: 60ch;
      line-height: 1.5;
    }

    /* ====== OVERVIEW (hero) ====== */
    .hero-eyebrow {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink-faint);
      margin-bottom: 16px;
    }
    .hero-headline {
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(40px, 7.4vw, 96px);
      line-height: 0.92;
      letter-spacing: -0.015em;
      margin: 0 0 0.3em;
      max-width: 16ch;
    }
    .hero-headline em { font-style: italic; color: var(--accent); }
    .hero-lead {
      font-size: clamp(16.5px, 1.6vw, 19px);
      line-height: 1.55;
      color: var(--ink);
      max-width: 58ch;
      margin: 0 0 26px;
    }
    .hero-lead b { font-weight: 600; }

    /* the 20-second scan strip: hard facts, no fake metrics */
    .scan {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border: 1px solid var(--ink);
      margin: 0 0 26px;
    }
    .scan-cell {
      padding: 16px 16px 14px;
      border-right: 1px solid var(--rule);
    }
    .scan-cell:last-child { border-right: 0; }
    .scan-v {
      font-family: var(--serif);
      font-size: clamp(30px, 4vw, 46px);
      line-height: 0.92;
      color: var(--accent);
      display: flex;
      align-items: baseline;
      gap: 4px;
    }
    .scan-v .u { font-family: var(--sans); font-size: 0.36em; font-weight: 600; color: var(--ink-soft); letter-spacing: 0.02em; }
    .scan-v.sm { font-size: clamp(18px, 2vw, 24px); color: var(--ink); }
    .scan-l {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.02em;
      color: var(--ink-soft);
      line-height: 1.35;
      margin-top: 9px;
    }

    .hero-cta-row { display: flex; flex-wrap: wrap; gap: 12px; }
    .btn {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 11px 18px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .btn-solid { background: var(--ink); color: var(--paper); }
    .btn-solid:hover { background: var(--accent); }
    .btn-ghost { border: 1px solid var(--ink); color: var(--ink); }
    .btn-ghost:hover { background: var(--ink); color: var(--paper); }

    /* ====== WORKFLOW ====== */
    .wf-grid {
      display: grid;
      grid-template-columns: 1.05fr 1fr;
      gap: clamp(28px, 4vw, 52px);
      align-items: start;
    }
    .pullquote {
      font-family: var(--serif);
      font-size: clamp(24px, 3vw, 36px);
      line-height: 1.14;
      color: var(--ink);
      border-top: 3px solid var(--accent);
      border-bottom: 1px solid var(--rule);
      padding: 18px 0;
      margin: 0;
    }
    .wf-stages { list-style: none; margin: 22px 0 0; padding: 0; }
    .wf-stages li {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 15px;
      padding: 13px 0;
      border-bottom: 1px solid var(--rule);
    }
    .wf-stages li:last-child { border-bottom: 0; }
    .wf-num { font-family: var(--serif); font-size: 28px; color: var(--accent-soft); line-height: 1; }
    .wf-stage-name { font-weight: 600; font-size: 15px; letter-spacing: 0.02em; margin-bottom: 2px; }
    .wf-stage-desc { font-size: 14px; color: var(--ink-soft); line-height: 1.46; }

    /* ====== CASE STUDIES: real grid, DOM order = visual order ====== */
    .work-head { display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 16px; margin-bottom: 6px; }
    .work-meta { font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-faint); }
    .cases {
      margin-top: 28px;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      column-gap: clamp(28px, 3.5vw, 52px);
      row-gap: 0;
      border-top: 1px solid var(--rule);
    }
    .case {
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      padding: 20px 0;
      border-bottom: 1px solid var(--rule);
    }
    /* vertical divider between the two columns */
    .case:nth-child(odd) { padding-right: clamp(14px, 1.8vw, 26px); border-right: 1px solid var(--rule); }
    .case:nth-child(even) { padding-left: clamp(14px, 1.8vw, 26px); }
    .case-top {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 8px;
    }
    .case-no {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent);
    }
    /* kind = a status chip, NOT a fake serif metric */
    .case-kind {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-soft);
      border: 1px solid var(--rule-strong);
      padding: 2px 7px;
      white-space: nowrap;
    }
    .case-title {
      font-family: var(--serif);
      font-size: clamp(21px, 2.1vw, 27px);
      line-height: 1.04;
      margin: 0 0 4px;
      color: var(--ink);
    }
    .case:hover .case-title { color: var(--accent); }
    .case-title .arrow { font-family: var(--sans); font-size: 0.6em; vertical-align: middle; }
    .case-scope {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.02em;
      color: var(--ink-faint);
      margin: 0 0 9px;
      line-height: 1.35;
    }
    .case-blurb { font-size: 14px; color: var(--ink-soft); line-height: 1.48; margin: 0 0 11px; }
    .case-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: auto; }
    .tag {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.02em;
      color: var(--ink-soft);
      border: 1px solid var(--rule-strong);
      padding: 3px 8px;
    }

    /* ====== NOW (ledger) ====== */
    .now-grid { display: grid; grid-template-columns: 1fr; }
    .now-row {
      display: grid;
      grid-template-columns: 150px 1fr;
      gap: clamp(16px, 3vw, 40px);
      padding: 18px 0;
      border-bottom: 1px solid var(--rule);
      align-items: baseline;
    }
    .now-row:first-of-type { border-top: 1px solid var(--ink); }
    .now-key { font-family: var(--serif); font-size: clamp(21px, 2.4vw, 28px); color: var(--accent); line-height: 1; }
    .now-val { font-size: 15px; color: var(--ink); line-height: 1.5; max-width: 66ch; }
    .now-val a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent-soft); white-space: nowrap; }
    .now-val a:hover { background: var(--accent); color: var(--paper); border-color: var(--accent); }

    /* ====== CV ====== */
    .cv-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: clamp(28px, 4vw, 56px);
      margin-top: 30px;
      align-items: start;
    }
    .cv-subhead {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--ink);
      border-bottom: 2px solid var(--ink);
      padding-bottom: 6px;
      margin: 0 0 6px;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }
    .cv-subhead .count { color: var(--ink-faint); font-size: 10px; }
    .role { padding: 16px 0; border-bottom: 1px solid var(--rule); }
    .role-head { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: baseline; gap: 8px; }
    .role-title { font-family: var(--serif); font-size: clamp(20px, 2.1vw, 25px); line-height: 1.05; }
    .role-co { color: var(--ink-soft); }
    .role-dates { font-family: var(--mono); font-size: 11px; letter-spacing: 0.03em; color: var(--ink-faint); white-space: nowrap; }
    .role-points { margin: 9px 0 0; padding: 0; list-style: none; }
    .role-points li {
      font-size: 14px;
      color: var(--ink-soft);
      line-height: 1.48;
      padding-left: 16px;
      position: relative;
      margin-bottom: 6px;
    }
    .role-points li::before {
      content: '';
      position: absolute;
      left: 0; top: 0.62em;
      width: 6px; height: 6px;
      background: var(--accent-soft);
    }
    .cv-aside > div { margin-bottom: 26px; }
    .edu-item { padding: 11px 0; border-bottom: 1px solid var(--rule); }
    .edu-school { font-family: var(--serif); font-size: 19px; line-height: 1.1; }
    .edu-deg { font-size: 13.5px; color: var(--ink-soft); margin: 3px 0; }
    .edu-dates { font-family: var(--mono); font-size: 11px; color: var(--ink-faint); letter-spacing: 0.03em; }
    .skill-row { padding: 8px 0; border-bottom: 1px solid var(--rule); }
    .skill-k { font-family: var(--mono); font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--accent); margin-bottom: 2px; }
    .skill-v { font-size: 13px; color: var(--ink-soft); line-height: 1.42; }
    .pub { border: 1px solid var(--ink); padding: 16px; background: var(--paper-2); }
    .pub-title { font-family: var(--serif); font-size: 20px; line-height: 1.12; margin-bottom: 8px; }
    .pub-note { font-size: 13px; color: var(--ink-soft); line-height: 1.46; margin-bottom: 12px; }
    .pub-link { font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent); }
    .pub-link:hover { background: var(--accent); color: var(--paper); }

    /* ====== READING ====== */
    .reading-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; margin-top: 28px; border-top: 1px solid var(--ink); }
    .shelf-item { padding: 20px 16px 20px 0; border-right: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
    .shelf-item:last-child { border-right: 0; }
    .shelf-num { font-family: var(--mono); font-size: 10px; letter-spacing: 0.1em; color: var(--ink-faint); margin-bottom: 8px; }
    .shelf-t { font-family: var(--serif); font-size: 22px; line-height: 1.06; margin-bottom: 7px; }
    .shelf-n { font-size: 13.5px; color: var(--ink-soft); line-height: 1.46; }

    /* ====== LANGUAGES ====== */
    .lang-row { display: flex; flex-wrap: wrap; gap: 0; margin-top: 28px; border: 1px solid var(--ink); }
    .lang { flex: 1 1 16%; min-width: 110px; padding: 18px 15px; border-right: 1px solid var(--rule); display: flex; flex-direction: column; gap: 4px; }
    .lang:last-child { border-right: 0; }
    .lang-code { font-family: var(--mono); font-size: 12px; letter-spacing: 0.1em; color: var(--accent); }
    .lang-name { font-family: var(--serif); font-size: 25px; line-height: 1; }

    /* ====== CONTACT ====== */
    .contact { position: relative; overflow: hidden; }
    .contact-water {
      position: absolute; right: -2vw; top: 50%; transform: translateY(-50%);
      font-family: var(--serif); font-size: clamp(160px, 38vw, 480px);
      line-height: 0.8; color: var(--rule); opacity: 0.5; pointer-events: none; z-index: 0; user-select: none;
    }
    .contact-inner { position: relative; z-index: 1; max-width: 64ch; }
    .contact h2 { margin-bottom: 0.3em; }
    .contact-body { font-size: clamp(15.5px, 1.7vw, 18px); color: var(--ink-soft); line-height: 1.5; max-width: 56ch; }
    .contact-cta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 26px; }

    /* ====== FOOTER ====== */
    footer { background: var(--ink); color: var(--paper); padding: clamp(40px, 6vw, 68px) 0 28px; position: relative; z-index: 2; }
    .footer-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 28px; padding-bottom: 32px; border-bottom: 1px solid rgba(247,244,236,0.18); }
    .footer-brand { display: flex; align-items: center; gap: 10px; font-family: var(--serif); font-size: 25px; }
    .footer-brand .mark { width: 30px; height: 30px; display: grid; place-items: center; border: 1px solid var(--paper); font-size: 17px; }
    .footer-tag { font-size: 14px; color: rgba(247,244,236,0.7); margin-top: 13px; max-width: 34ch; line-height: 1.48; }
    .footer-col h4 { font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(247,244,236,0.55); margin: 0 0 13px; }
    .footer-col ul { list-style: none; margin: 0; padding: 0; }
    .footer-col li { margin-bottom: 8px; }
    .footer-col a { color: rgba(247,244,236,0.86); text-decoration: none; font-size: 14px; }
    .footer-col a:hover { color: var(--accent-soft); }
    .footer-bottom { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 10px; padding-top: 20px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.03em; color: rgba(247,244,236,0.55); }

    /* ====== Mobile menu ====== */
    .mobile-menu { display: none; position: fixed; inset: 0; z-index: 40; background: var(--paper); padding: 78px var(--gutter) 40px; overflow-y: auto; }
    .mobile-menu.open { display: block; }
    .mobile-menu a { display: block; font-family: var(--serif); font-size: 32px; text-decoration: none; color: var(--ink); padding: 11px 0; border-bottom: 1px solid var(--rule); }
    .mobile-menu a:hover { color: var(--accent); }
    .mm-close { position: absolute; top: 16px; right: var(--gutter); font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; background: none; border: 1px solid var(--ink); padding: 8px 12px; cursor: pointer; }

    /* ====== Reveal ====== */
    @media (prefers-reduced-motion: no-preference) {
      .reveal { opacity: 0; transform: translateY(14px); transition: opacity 0.6s ease, transform 0.6s ease; }
      .reveal.in { opacity: 1; transform: none; }
      .nav-links a, .btn, .case-title, .now-val a, .footer-col a, .toc a { transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease; }
    }

    /* ====== Responsive ====== */
    @media (max-width: 1040px) {
      :root { --rail: 168px; }
    }
    @media (max-width: 900px) {
      .shell { grid-template-columns: 1fr; gap: 0; }
      .toc { display: none; }
      .wf-grid, .cv-grid { grid-template-columns: 1fr; }
      .reading-grid { grid-template-columns: repeat(2, 1fr); }
      .shelf-item:nth-child(2n) { border-right: 0; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 720px) {
      .nav-links, .lang-switch { display: none; }
      .nav-toggle { display: inline-block; }
      .scan { grid-template-columns: repeat(2, 1fr); }
      .scan-cell:nth-child(2) { border-right: 0; }
      .scan-cell:nth-child(1), .scan-cell:nth-child(2) { border-bottom: 1px solid var(--rule); }
      .now-row { grid-template-columns: 1fr; gap: 6px; }
      .reading-grid { grid-template-columns: 1fr; }
      .shelf-item { border-right: 0; }
      .footer-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 620px) {
      .cases { grid-template-columns: 1fr; }
      .case:nth-child(odd) { padding-right: 0; border-right: 0; }
      .case:nth-child(even) { padding-left: 0; }
    }
    @media (max-width: 480px) {
      body { font-size: 16px; }
      .scan { grid-template-columns: 1fr; }
      .scan-cell { border-right: 0; border-bottom: 1px solid var(--rule); }
      .scan-cell:last-child { border-bottom: 0; }
      .lang { flex: 1 1 100%; min-width: 0; border-right: 0; border-bottom: 1px solid var(--rule); }
      .lang:last-child { border-bottom: 0; }
    }
  </style>
</head>
<body>
  <!-- NAV -->
  <nav class="bar">
    <div class="nav-inner">
      <a class="nav-brand" href="#top" aria-label="Tom Scholtes home">
        <span class="mark">T</span> Tom Scholtes
      </a>
      <ul class="nav-links">
        {navItems.map((it) => (<li><a href={it.href}>{it.label}</a></li>))}
      </ul>
      <div class="nav-right">
        <span class="lang-switch"><b>EN</b> / DE / FR / RU</span>
        <a class="nav-cta" href="#contact">Say hi</a>
        <button class="nav-toggle" id="navToggle" aria-label="Open menu">Menu</button>
      </div>
    </div>
  </nav>

  <!-- MOBILE MENU -->
  <div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Navigation">
    <button class="mm-close" id="mmClose" aria-label="Close menu">Close</button>
    {navItems.map((it) => (<a href={it.href}>{it.label}</a>))}
    <a href="#contact">Say hi</a>
  </div>

  <div class="wrap">
    <!-- IDENTITY STRIP -->
    <div class="ident">
      <span><b>Tom Scholtes</b> · Finance ops engineer · Luxembourg</span>
      <span class="status"><span class="dot" aria-hidden="true"></span> Live CV &amp; portfolio · updated {year}</span>
    </div>

    <!-- SHELL: sticky contents rail + content -->
    <div class="shell">
      <!-- CONTENTS RAIL (the scan index) -->
      <aside class="toc" aria-label="Contents">
        <div class="toc-label">Contents</div>
        <ol>
          {toc.map((t) => (
            <li>
              <a href={`#${t.id}`} data-toc={t.id}>
                <span class="tn">{t.n}</span>
                <span class="tl">{t.label}</span>
              </a>
            </li>
          ))}
        </ol>
        <div class="toc-foot">
          <a href="https://www.linkedin.com/in/tomscholtes93/">LinkedIn</a><br />
          <a href="mailto:tom@tomscholtes.com">Email</a><br />
          <a href="/thesis/">MSc thesis</a>
        </div>
      </aside>

      <!-- CONTENT COLUMN -->
      <div class="content">
        <!-- OVERVIEW / HERO -->
        <section id="top">
          <div class="hero-eyebrow reveal">Overview · 20-second read</div>
          <h1 class="hero-headline reveal">I build the automation behind <em>regulated finance</em> operations.</h1>
          <p class="hero-lead reveal">I'm Tom. I build AI-augmented automation for the operational work in regulated finance: regulatory notes, accounts quality review, document workflows, mailbox triage, and the reusable tooling that ties them together. <b>Six years in Luxembourg fund services</b> across PE, Private Debt and Real Estate, now spent designing the systems that do the work instead of doing it by hand. This site is the evidence: a live CV, the patterns behind the work, and case studies of it shipping.</p>
          <div class="scan reveal">
            {scanFacts.map((f) => (
              <div class="scan-cell">
                <div class={f.u || /^\d/.test(f.v) ? 'scan-v' : 'scan-v sm'}>{f.v}{f.u && (<span class="u">{f.u}</span>)}</div>
                <div class="scan-l">{f.l}</div>
              </div>
            ))}
          </div>
          <div class="hero-cta-row reveal">
            <a class="btn btn-solid" href="#work">See the work</a>
            <a class="btn btn-ghost" href="#contact">Get in touch</a>
          </div>
        </section>

        <!-- WORKFLOW -->
        <section id="workflow">
          <span class="kicker reveal">Live demo</span>
          <div class="wf-grid">
            <div>
              <h2 class="feature reveal">See the automation run, on synthetic data.</h2>
              <p class="deck reveal">Point AI at the manual workflows underneath a finance desk. It surfaces what is unbooked, mismatched, or missing, builds the upload template, and drafts the counterparty email. The operator reviews and signs off; the human owns the decision. Click through a before-and-after process map and run it live.</p>
              <div class="hero-cta-row reveal" style="margin-top:18px;">
                <a class="btn btn-solid" href="/workflow-automation/">Open the live demo</a>
              </div>
            </div>
            <div class="reveal">
              <blockquote class="pullquote">The operator reviews and signs off. The human owns the decision.</blockquote>
              <ol class="wf-stages">
                {stages.map((s) => (
                  <li>
                    <span class="wf-num">{s.n}</span>
                    <div>
                      <div class="wf-stage-name">{s.name}</div>
                      <div class="wf-stage-desc">{s.desc}</div>
                    </div>
                  </li>
                ))}
              </ol>
            </div>
          </div>
        </section>

        <!-- CASE STUDIES -->
        <section id="work">
          <span class="kicker reveal">Case studies</span>
          <div class="work-head">
            <h2 class="feature reveal" style="margin-bottom:0;">Patterns I've worked through.</h2>
            <span class="work-meta reveal">Nine features · sanitised</span>
          </div>
          <p class="deck reveal" style="margin-top:12px;">Sanitised. Employer name, entity names and figures removed. Notes on how I think about this kind of work in fund services. Read in order, 01 to 09.</p>
          <div class="cases">
            {cases.map((c) => (
              <a class="case reveal" href={c.href}>
                <div class="case-top">
                  <span class="case-no">Case {c.n}</span>
                  <span class="case-kind">{c.kind}</span>
                </div>
                <h3 class="case-title">{c.title} <span class="arrow">&rarr;</span></h3>
                <p class="case-scope">{c.metricLabel}</p>
                <p class="case-blurb">{c.blurb}</p>
                <div class="case-tags">
                  {c.tags.map((t) => (<span class="tag">{t}</span>))}
                </div>
              </a>
            ))}
          </div>
        </section>

        <!-- NOW -->
        <section id="now">
          <span class="kicker reveal">/ now · June 2026</span>
          <h2 class="feature reveal">What I'm focused on this quarter.</h2>
          <p class="deck reveal">A public note of where my head is right now, in the spirit of <em>nownownow.com</em>. I update it when things change, not on a schedule.</p>
          <div class="now-grid" style="margin-top:26px;">
            {nowRows.map((r) => (
              <div class="now-row reveal">
                <div class="now-key">{r.k}</div>
                <div class="now-val">
                  {r.v}{r.cta && (<>{' '}<a href={r.cta.href}>{r.cta.label} &rarr;</a></>)}
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- CV -->
        <section id="cv">
          <span class="kicker reveal">Live CV</span>
          <h2 class="feature reveal">Six years in Luxembourg fund services.</h2>
          <p class="deck reveal">Updated as roles, projects and credentials change. The condensed PDF version is on request.</p>
          <div class="cv-grid">
            <div class="cv-main">
              <div class="cv-subhead reveal">Experience <span class="count">5 roles · 6+ years</span></div>
              {roles.map((r) => (
                <div class="role reveal">
                  <div class="role-head">
                    <div class="role-title">{r.role} <span class="role-co">/ {r.title}</span></div>
                    <span class="role-dates">{r.dates}</span>
                  </div>
                  <ul class="role-points">
                    {r.points.map((p) => (<li>{p}</li>))}
                  </ul>
                </div>
              ))}
            </div>
            <aside class="cv-aside">
              <div class="reveal">
                <div class="cv-subhead">Education</div>
                {education.map((e) => (
                  <div class="edu-item">
                    <div class="edu-school">{e.school}</div>
                    <div class="edu-deg">{e.deg}</div>
                    <div class="edu-dates">{e.dates}</div>
                  </div>
                ))}
              </div>
              <div class="reveal">
                <div class="cv-subhead">Skills</div>
                {skills.map((s) => (
                  <div class="skill-row">
                    <div class="skill-k">{s.k}</div>
                    <div class="skill-v">{s.v}</div>
                  </div>
                ))}
              </div>
              <div class="reveal">
                <div class="cv-subhead">Publication</div>
                <div class="pub">
                  <div class="pub-title">Augmented gravity model: Institutions, Infrastructure and Globalization impact on bilateral exports among OECD countries</div>
                  <div class="pub-note">MSc thesis · Erasmus University Rotterdam · panel econometrics over 36 OECD economies, 1995 to 2018</div>
                  <a class="pub-link" href="/thesis">Read &rarr;</a>
                </div>
              </div>
            </aside>
          </div>
        </section>

        <!-- READING -->
        <section id="reading">
          <span class="kicker reveal">Reading</span>
          <h2 class="feature reveal">Mostly non-fiction.</h2>
          <p class="deck reveal">Themes I keep coming back to. A proper bookshelf with titles will go here once I've trimmed the list.</p>
          <div class="reading-grid">
            {readingThemes.map((r, i) => (
              <div class="shelf-item reveal">
                <div class="shelf-num">{String(i + 1).padStart(2, '0')} / Shelf</div>
                <div class="shelf-t">{r.t}</div>
                <div class="shelf-n">{r.n}</div>
              </div>
            ))}
          </div>
        </section>

        <!-- LANGUAGES -->
        <section id="languages">
          <span class="kicker reveal">Languages</span>
          <h2 class="feature reveal">Six, used regularly.</h2>
          <div class="lang-row">
            {languages.map((l) => (
              <div class="lang reveal">
                <span class="lang-code">{l.c}</span>
                <span class="lang-name">{l.n}</span>
              </div>
            ))}
          </div>
        </section>

        <!-- CONTACT -->
        <section id="contact" class="contact">
          <div class="contact-water" aria-hidden="true">hi.</div>
          <div class="contact-inner">
            <span class="kicker reveal">Contact</span>
            <h2 class="feature reveal">If any of this is <em>interesting</em>, say hi.</h2>
            <p class="contact-body reveal">Always interested in conversations about data engineering, automation, applied AI, multi-agent systems, knowledge engineering, agent infrastructure, especially where they meet regulated workflows.</p>
            <div class="contact-cta reveal">
              <a class="btn btn-solid" href="https://www.linkedin.com/messaging/compose/?recipient=tomscholtes93">Message on LinkedIn</a>
              <a class="btn btn-ghost" href="https://www.linkedin.com/in/tomscholtes93/">View profile</a>
              <a class="btn btn-ghost" href="mailto:tom@tomscholtes.com">Email</a>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>

  <!-- FOOTER -->
  <footer>
    <div class="wrap">
      <div class="footer-grid">
        <div>
          <div class="footer-brand"><span class="mark">T</span> Tom Scholtes</div>
          <p class="footer-tag">Notes on AI in finance ops, a live CV, and a portfolio of work.</p>
        </div>
        <div class="footer-col">
          <h4>Site</h4>
          <ul>
            <li><a href="#now">Now</a></li>
            <li><a href="#work">Work</a></li>
