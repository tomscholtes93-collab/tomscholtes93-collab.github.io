  <!-- floating discoverability chip for the keyboard signature -->
  <button class="keyhint inter" id="keyhint" type="button" aria-haspopup="dialog" aria-controls="palette">
    Index <span class="kbd">/</span> jump <span class="kbd">0</span>&ndash;<span class="kbd">8</span>
  </button>

  <!-- command palette -->
  <div class="palette" id="palette" data-open="false" role="dialog" aria-modal="true" aria-label="Index command palette">
    <div class="scrim" data-close></div>
    <div class="panel">
      <div class="phead">
        <span class="pt inter">Index · jump anywhere</span>
        <span class="pc inter">type a number, ↑↓ then ↵, Esc to close</span>
      </div>
      <div class="plist" id="plist">
        {nav.map((e) => (
          <button class="pitem" type="button" data-target={e.target} data-no={e.n}>
            <span class="pno">{e.n}</span>
            <span class="pnm inter">{e.name}</span>
            <span class="pgo inter">{e.target.startsWith('#') ? 'jump →' : 'open →'}</span>
          </button>
        ))}
      </div>
    </div>
  </div>

  <p class="sr-only" id="liveRegion" aria-live="polite"></p>

  <script>
    (function () {
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var nav = [];
      try { nav = JSON.parse(document.body.getAttribute('data-index') || '[]'); } catch (e) { nav = []; }
      var byKey = {};
      nav.forEach(function (e) { byKey[e.n.slice(-1)] = e; });

      var live = document.getElementById('liveRegion');
      function announce(msg) { if (live) { live.textContent = msg; } }

      // Resolve an index target: in-page anchor scrolls smoothly; route navigates.
      function go(target, label) {
        if (!target) return;
        if (target.charAt(0) === '#') {
          var el = document.querySelector(target);
          if (el) {
            el.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'start' });
            if (history.replaceState) history.replaceState(null, '', target);
            if (label) announce('Jumped to ' + label);
          }
        } else {
          window.location.href = target;
        }
      }

      // ---- keyboard index: every number truthfully jumps ----
      function editable(t) {
        return t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable);
      }
      window.addEventListener('keydown', function (e) {
        if (e.metaKey || e.ctrlKey || e.altKey) return;
        if (editable(e.target)) return;

        if (e.key === '/' && !paletteOpen()) { e.preventDefault(); openPalette(); return; }

        if (paletteOpen()) return; // palette has its own handler

        var entry = byKey[e.key];
        if (entry) { e.preventDefault(); go(entry.target, entry.name); }
      });

      // ---- command palette ----
      var palette = document.getElementById('palette');
      var plist = document.getElementById('plist');
      var items = plist ? Array.prototype.slice.call(plist.querySelectorAll('.pitem')) : [];
      var sel = -1;

      function paletteOpen() { return palette && palette.getAttribute('data-open') === 'true'; }
      function setSel(i) {
        if (!items.length) return;
        sel = (i + items.length) % items.length;
        items.forEach(function (it, idx) { it.classList.toggle('sel', idx === sel); });
        items[sel].scrollIntoView({ block: 'nearest' });
      }
      function openPalette() {
        if (!palette) return;
        palette.setAttribute('data-open', 'true');
        sel = -1;
        items.forEach(function (it) { it.classList.remove('sel'); });
        announce('Index palette open. Type a number or use arrow keys.');
      }
      function closePalette() {
        if (!palette) return;
        palette.setAttribute('data-open', 'false');
      }

      items.forEach(function (it) {
        it.addEventListener('click', function () {
          closePalette();
          go(it.getAttribute('data-target'), it.querySelector('.pnm').textContent);
        });
      });
      palette && palette.addEventListener('click', function (e) {
        if (e.target && e.target.hasAttribute('data-close')) closePalette();
      });
      palette && palette.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') { e.preventDefault(); closePalette(); return; }
        if (e.key === 'ArrowDown') { e.preventDefault(); setSel(sel + 1); return; }
        if (e.key === 'ArrowUp') { e.preventDefault(); setSel(sel - 1); return; }
        if (e.key === 'Enter' && sel >= 0) {
          e.preventDefault();
          var it = items[sel];
          closePalette();
          go(it.getAttribute('data-target'), it.querySelector('.pnm').textContent);
          return;
        }
        var entry = byKey[e.key];
        if (entry) {
          e.preventDefault();
          closePalette();
          go(entry.target, entry.name);
        }
      });
      var keyhint = document.getElementById('keyhint');
      keyhint && keyhint.addEventListener('click', openPalette);

      // ---- smooth-scroll for in-page anchor clicks (toc + any #link), unified path ----
      document.addEventListener('click', function (e) {
        var a = e.target.closest && e.target.closest('a[href^="#"]');
        if (!a) return;
        var href = a.getAttribute('href');
        if (!href || href === '#') return;
        var el = document.querySelector(href);
        if (!el) return;
        e.preventDefault();
        go(href, a.textContent.trim());
      });

      // ---- scroll-sync "you are here" instrument ----
      var locNo = document.getElementById('locNo');
      var locNm = document.getElementById('locNm');
      var tocRows = Array.prototype.slice.call(document.querySelectorAll('#toc .row'));
      var rowByTarget = {};
      tocRows.forEach(function (r) { rowByTarget[r.getAttribute('data-target')] = r; });

      // map each in-page section element to its index entry
      var sections = [];
      nav.forEach(function (entry) {
        if (entry.target.charAt(0) !== '#') return;
        var el = document.querySelector(entry.target);
        if (el) sections.push({ entry: entry, el: el });
      });

      var current = null;
      function setCurrent(entry) {
        if (!entry || (current && current.n === entry.n)) return;
        current = entry;
        if (locNo) locNo.textContent = entry.n;
        if (locNm) locNm.textContent = entry.name;
        tocRows.forEach(function (r) {
          r.classList.toggle('is-current', r.getAttribute('data-target') === entry.target);
        });
      }

      if ('IntersectionObserver' in window && sections.length) {
        var visible = {};
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (en) {
            var t = en.target.getAttribute('id');
            if (en.isIntersecting) visible['#' + t] = en.intersectionRatio;
            else delete visible['#' + t];
          });
          // pick the topmost visible section in index order
          for (var i = 0; i < sections.length; i++) {
            if (visible[sections[i].entry.target] != null) { setCurrent(sections[i].entry); return; }
          }
        }, { rootMargin: '-62px 0px -55% 0px', threshold: [0, 0.01, 0.25] });
        sections.forEach(function (s) { io.observe(s.el); });
      }

      // ---- case-study filter (reflowing index) ----
      var caseEls = Array.prototype.slice.call(document.querySelectorAll('#cases .case'));
      var filterBtns = Array.prototype.slice.call(document.querySelectorAll('.filt'));
      var shownEl = document.getElementById('caseShown');
      function applyFilter(f) {
        var shown = 0;
        caseEls.forEach(function (c) {
          var match = (f === 'all') || (c.getAttribute('data-status') === f);
          c.hidden = !match;
          if (match) shown++;
        });
        if (shownEl) shownEl.textContent = String(shown);
        filterBtns.forEach(function (b) {
          b.setAttribute('aria-pressed', b.getAttribute('data-filter') === f ? 'true' : 'false');
        });
        var labelMap = { all: 'all', shipped: 'shipped', pattern: 'proposed and personal' };
        announce('Showing ' + shown + ' ' + (labelMap[f] || f) + ' case studies.');
      }
      filterBtns.forEach(function (b) {
        b.addEventListener('click', function () { applyFilter(b.getAttribute('data-filter')); });
      });

      // ---- in-medium reconciliation demo (deterministic, no data invented; synthetic rows) ----
      var demoRun = document.getElementById('demoRun');
      var demoOut = document.getElementById('demoOut');
      var rows = [
        { id: 'SPV-Alpha', booked: 1204500.00, source: 1204500.00 },
        { id: 'SPV-Beta',  booked: 880000.00,  source: 879250.00 },
        { id: 'SPV-Gamma', booked: 415750.00,  source: 415750.00 },
        { id: 'SPV-Delta', booked: 0.00,        source: 62300.00 }
      ];
      function fmt(n) {
        return n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      }
      demoRun && demoRun.addEventListener('click', function () {
        var lines = [];
        var flags = 0;
        rows.forEach(function (r) {
          var diff = +(r.booked - r.source).toFixed(2);
          if (Math.abs(diff) < 0.005) {
            lines.push(r.id + '  matched (' + fmt(r.source) + ')');
          } else {
            flags++;
            var sign = diff > 0 ? '+' : '';
            lines.push(r.id + '  FLAG  delta ' + sign + fmt(diff));
          }
        });
        lines.push('');
        lines.push(flags + ' of ' + rows.length + ' rows flagged for sign-off. Human owns the decision.');
        if (demoOut) {
          // render with simple class markers
          demoOut.innerHTML = lines.map(function (l) {
            if (l.indexOf('FLAG') > -1) return '<span class="flag">' + l + '</span>';
            if (l.indexOf('matched') > -1) return '<span class="ok">' + l + '</span>';
            return l;
          }).join('\n');
        }
        announce(flags + ' rows flagged by the reconciliation check.');
      });
    })();
  </script>
</body>
