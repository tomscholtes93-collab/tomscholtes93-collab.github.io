  <script>
    // Mobile menu
    const toggle = document.getElementById('navToggle');
    const menu = document.getElementById('mobileMenu');
    const close = document.getElementById('mmClose');
    const openMenu = () => { if (menu) { menu.classList.add('open'); document.body.style.overflow = 'hidden'; } };
    const closeMenu = () => { if (menu) { menu.classList.remove('open'); document.body.style.overflow = ''; } };
    toggle && toggle.addEventListener('click', openMenu);
    close && close.addEventListener('click', closeMenu);
    menu && menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));

    const motionOK = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;

    // Scroll reveal (gated on motion preference)
    if (motionOK && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    } else {
      document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in'));
    }

    // SIGNATURE: the "automation run" plays once on view, replayable on click.
    // Fully motion-gated. With reduced motion the box just shows its final state.
    const runbox = document.getElementById('runbox');
    const runstatus = document.getElementById('runstatus');
    const runbar = document.getElementById('runbar');
    const replay = document.getElementById('runReplay');

    const RUN_MS = 2900; // last line delay (1.95s) + after-panel fade end (~2.9s)

    function setStatus(text, live) {
      if (runstatus) {
        runstatus.textContent = text;
        runstatus.classList.toggle('is-live', !!live);
      }
      if (runbar) runbar.classList.toggle('is-live', !!live);
    }

    function playRun() {
      if (!runbox) return;
      // restart the CSS animations cleanly
      runbox.classList.remove('run');
      runbox.classList.add('armed');
      // force reflow so re-adding .run replays the keyframes
      void runbox.offsetWidth;
      runbox.classList.add('run');
      setStatus('running', true);
      window.clearTimeout(playRun._t);
      playRun._t = window.setTimeout(() => {
        setStatus('signed off', false);
      }, RUN_MS);
    }

    if (runbox) {
      if (motionOK) {
        runbox.classList.add('armed');
        setStatus('idle', false);
        if ('IntersectionObserver' in window) {
          let played = false;
          const rio = new IntersectionObserver((entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting && !played) { played = true; playRun(); rio.unobserve(e.target); }
            });
          }, { threshold: 0.4 });
          rio.observe(runbox);
        } else {
          playRun();
        }
        // replay is allowed even with motion on
        replay && replay.addEventListener('click', playRun);
      } else {
        // reduced motion: show the completed state, no animation, no replay churn
        setStatus('signed off', false);
        replay && (replay.style.display = 'none');
      }
    }
  </script>
