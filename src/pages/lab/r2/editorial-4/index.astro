<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Tom Scholtes. Finance ops engineer who automates the work in reach.</title>
  <meta name="description" content="Personal site, live CV, and a portfolio of automation I've built for regulated finance operations. Six years in Luxembourg fund services, now designing the systems that do the work." />
  <style>
    :root {
      --paper: #f7f4ec;
      --paper-2: #f1ece0;
      --ink: #1a1714;
      --ink-soft: #4a443c;
      --ink-faint: #8a8174;
      --rule: #d8d0c0;
      --rule-strong: #b8ad97;
      --accent: #9c3b2e;
      --accent-soft: #c06b56;
      --signal: #2f6b4f;        /* one reserved "live / running" event colour */
      --serif: 'Instrument Serif', Georgia, 'Times New Roman', serif;
      --sans: 'Inter', system-ui, -apple-system, sans-serif;
      --mono: 'JetBrains Mono', ui-monospace, 'SFMono-Regular', monospace;
      --gutter: clamp(20px, 5vw, 72px);
    }

    * { box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }

    body {
      margin: 0;
      background: var(--paper);
      color: var(--ink);
      font-family: var(--sans);
      font-size: 17px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      background-image:
        radial-gradient(circle at 18% 22%, rgba(0,0,0,0.018) 0.6px, transparent 0.6px),
        radial-gradient(circle at 72% 64%, rgba(0,0,0,0.015) 0.6px, transparent 0.6px);
      background-size: 4px 4px, 5px 5px;
      mix-blend-mode: multiply;
    }

    a { color: inherit; }

    .wrap {
      max-width: 1340px;
      margin: 0 auto;
      padding: 0 var(--gutter);
      position: relative;
      z-index: 2;
    }

    /* ---- Masthead (person, not publication) ---- */
    .masthead {
      border-bottom: 3px double var(--ink);
      padding-top: 18px;
    }
    .masthead-top {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--ink-soft);
      padding-bottom: 10px;
    }
    .masthead-top .iss { font-weight: 500; }
    .masthead-title {
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(40px, 9vw, 116px);
      line-height: 0.92;
      letter-spacing: -0.01em;
      margin: 6px 0 4px;
      text-align: center;
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
      padding: 8px 0 12px;
    }
    .masthead-sub {
      text-align: center;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--ink-faint);
      padding: 8px 0 14px;
    }

    /* ---- Nav strip ---- */
    nav.editorial {
      position: sticky;
      top: 0;
      z-index: 30;
      background: var(--paper);
      border-bottom: 1px solid var(--ink);
      box-shadow: 0 1px 0 var(--rule);
    }
    .nav-inner {
      max-width: 1340px;
      margin: 0 auto;
      padding: 0 var(--gutter);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      min-height: 46px;
    }
    .nav-brand {
      display: flex;
      align-items: center;
      gap: 9px;
      font-family: var(--serif);
      font-size: 21px;
      letter-spacing: 0.01em;
      white-space: nowrap;
      text-decoration: none;
    }
    .nav-brand .mark {
      font-family: var(--serif);
      width: 26px; height: 26px;
      display: grid; place-items: center;
      border: 1px solid var(--ink);
      background: var(--ink);
      color: var(--paper);
      font-size: 16px;
      line-height: 1;
    }
    .nav-links {
      display: flex;
      gap: 18px;
      list-style: none;
      margin: 0; padding: 0;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .nav-links a {
      text-decoration: none;
      color: var(--ink-soft);
      white-space: nowrap;
      padding: 4px 0;
      border-bottom: 1px solid transparent;
    }
    .nav-links a:hover { color: var(--accent); border-bottom-color: var(--accent); }
    .nav-right { display: flex; align-items: center; gap: 14px; }
    .lang-switch {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      color: var(--ink-faint);
      white-space: nowrap;
    }
    .lang-switch b { color: var(--ink); font-weight: 700; }
    .nav-cta {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--paper);
      background: var(--accent);
      padding: 7px 13px;
      white-space: nowrap;
    }
    .nav-cta:hover { background: var(--ink); }
    .nav-toggle {
      display: none;
      font-family: var(--mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      background: none;
      border: 1px solid var(--ink);
      color: var(--ink);
      padding: 6px 10px;
      cursor: pointer;
    }

    /* ---- Section shell ---- */
    section { padding: clamp(48px, 7vw, 96px) 0; border-bottom: 1px solid var(--rule); }
    .kicker {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 18px;
    }
    .kicker::before {
      content: '';
      width: 30px; height: 1px;
      background: var(--accent);
    }
    h2.feature {
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(34px, 6vw, 68px);
      line-height: 0.98;
      letter-spacing: -0.01em;
      margin: 0 0 0.4em;
    }
    .feature em { font-style: italic; color: var(--accent); }
    .deck {
      font-size: clamp(16px, 2vw, 19px);
      color: var(--ink-soft);
      max-width: 56ch;
      line-height: 1.55;
    }

    /* ---- HERO ---- */
    .hero { padding-top: clamp(34px, 5vw, 60px); }
    .hero-grid {
      display: grid;
      grid-template-columns: 1.55fr 1fr;
      gap: clamp(28px, 5vw, 64px);
      align-items: start;
    }
    .hero-headline {
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(46px, 9vw, 124px);
      line-height: 0.9;
      letter-spacing: -0.015em;
      margin: 0 0 0.34em;
    }
    .hero-headline em { font-style: italic; color: var(--accent); }
    .hero-lead {
      font-size: clamp(17px, 1.8vw, 20px);
      line-height: 1.62;
      color: var(--ink);
      max-width: 60ch;
    }
    .hero-eyebrow {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink-faint);
      margin-bottom: 20px;
    }
    .hero-cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: 28px;
    }
    .btn {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 12px 20px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .btn-solid { background: var(--ink); color: var(--paper); }
    .btn-solid:hover { background: var(--accent); }
    .btn-ghost { border: 1px solid var(--ink); color: var(--ink); }
    .btn-ghost:hover { background: var(--ink); color: var(--paper); }

    /* hero sidebar */
    .hero-aside {
      border-left: 1px solid var(--rule-strong);
      padding-left: clamp(20px, 3vw, 36px);
    }

    /* ====================================================== */
    /* SIGNATURE: the inline "automation run" instrument       */
    /* ====================================================== */
    .runbox {
      border: 1px solid var(--ink);
      background: var(--paper-2);
      position: relative;
    }
    .runbox-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      background: var(--ink);
      color: var(--paper);
      font-family: var(--mono);
      font-size: 10.5px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 7px 11px;
    }
    .runbox-bar .dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--accent-soft);
      display: inline-block;
      margin-right: 7px;
      vertical-align: middle;
    }
    .runbox-bar.is-live .dot { background: #6fce9c; }
    .runbox-status { color: rgba(247,244,236,0.7); }
    .runbox-status.is-live { color: #9ee3bd; }
    .run-log {
      list-style: none;
      margin: 0;
      padding: 4px 0 6px;
      font-family: var(--mono);
      font-size: 12px;
      line-height: 1.5;
    }
    .run-log li {
      display: grid;
      grid-template-columns: 46px 60px 1fr;
      gap: 8px;
      align-items: baseline;
      padding: 6px 12px;
      border-bottom: 1px solid var(--rule);
      color: var(--ink-soft);
    }
    .run-log li:last-child { border-bottom: 0; }
    .run-t { color: var(--ink-faint); font-size: 11px; }
    .run-stage {
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 500;
      color: var(--accent);
    }
    .run-stage[data-s="hold"] { color: var(--signal); }
    .run-txt { color: var(--ink); }
    .run-foot {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
      border-top: 1px solid var(--ink);
      padding: 9px 12px;
      font-family: var(--mono);
      font-size: 10.5px;
      letter-spacing: 0.04em;
      color: var(--ink-faint);
    }
    .run-replay {
      font-family: var(--mono);
      font-size: 10.5px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      background: none;
      border: 1px solid var(--rule-strong);
      color: var(--ink-soft);
      padding: 5px 11px;
      cursor: pointer;
    }
    .run-replay:hover { border-color: var(--ink); color: var(--ink); }
    /* before / after compact ledger under the log */
    .ba {
      display: grid;
      grid-template-columns: 1fr 22px 1fr;
      align-items: stretch;
      border-top: 1px solid var(--ink);
    }
    .ba-col { padding: 12px; }
    .ba-col.before { background: transparent; }
    .ba-col.after { background: rgba(47,107,79,0.06); }
    .ba-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink-faint);
      margin-bottom: 7px;
    }
    .ba-col.after .ba-label { color: var(--signal); }
    .ba-line {
      font-size: 13px;
      color: var(--ink-soft);
      line-height: 1.45;
      margin-bottom: 4px;
    }
    .ba-line b { font-family: var(--serif); font-weight: 400; font-size: 18px; color: var(--ink); }
    .ba-col.after .ba-line b { color: var(--signal); }
    .ba-mid {
      display: grid;
      place-items: center;
      font-family: var(--serif);
      font-size: 22px;
      color: var(--accent);
      border-left: 1px solid var(--rule);
      border-right: 1px solid var(--rule);
    }
    .figcaption {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.04em;
      color: var(--ink-faint);
      margin-top: 10px;
      line-height: 1.45;
    }

    /* stats rail */
    .stats {
      display: grid;
      grid-template-columns: 1fr;
      margin-top: 24px;
      border-top: 1px solid var(--rule);
    }
    .stat {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 14px;
      padding: 12px 0;
      border-bottom: 1px solid var(--rule);
    }
    .stat-val {
      font-family: var(--serif);
      font-size: 38px;
      line-height: 1;
      color: var(--accent);
    }
    .stat-label {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--ink-soft);
      text-align: right;
      max-width: 18ch;
    }

    /* ---- Workflow (pull quote spread) ---- */
    .wf-grid {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: clamp(28px, 5vw, 60px);
      align-items: start;
    }
    .pullquote {
      font-family: var(--serif);
      font-size: clamp(26px, 3.4vw, 40px);
      line-height: 1.16;
      color: var(--ink);
      border-top: 3px solid var(--accent);
      border-bottom: 1px solid var(--rule);
      padding: 22px 0;
    }
    .wf-stages {
      list-style: none;
      margin: 26px 0 0;
      padding: 0;
    }
    .wf-stages li {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 16px;
      padding: 16px 0;
      border-bottom: 1px solid var(--rule);
    }
    .wf-num {
      font-family: var(--serif);
      font-size: 30px;
      color: var(--accent-soft);
      line-height: 1;
    }
    .wf-stage-name {
      font-family: var(--sans);
      font-weight: 600;
      font-size: 15px;
      letter-spacing: 0.02em;
      margin-bottom: 3px;
    }
    .wf-stage-desc { font-size: 14.5px; color: var(--ink-soft); line-height: 1.5; }

    /* ---- Case studies (real 2-col grid; DOM order = numeric order) ---- */
    .work-head { display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 20px; margin-bottom: 8px; }
    .work-meta { font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-faint); }
    .cases {
      margin-top: 36px;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      column-gap: clamp(28px, 4vw, 56px);
      row-gap: 0;
    }
    .case {
      display: block;
      text-decoration: none;
      color: inherit;
      padding: 24px 0 26px;
      border-top: 1px solid var(--rule);
    }
    /* re-derive column divider intentionally: vertical rule between the two columns */
    .case:nth-child(odd) { padding-right: clamp(14px, 2vw, 28px); border-right: 1px solid var(--rule); }
    .case:nth-child(even) { padding-left: clamp(14px, 2vw, 28px); }
    /* top hairline only on the first row */
    .case:nth-child(1), .case:nth-child(2) { border-top: 1px solid var(--ink); }
    .case-top {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 14px;
      margin-bottom: 10px;
    }
    .case-no {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent);
    }
    /* kind tag, not a fake metric number */
    .case-kind {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-soft);
      border: 1px solid var(--rule-strong);
      padding: 3px 8px;
      white-space: nowrap;
    }
    .case-kind[data-k="Running"] { color: var(--signal); border-color: var(--signal); }
    .case-title {
      font-family: var(--serif);
      font-size: clamp(22px, 2.4vw, 30px);
      line-height: 1.04;
      margin: 0 0 6px;
      color: var(--ink);
    }
    .case:hover .case-title { color: var(--accent); }
    .case-title .arrow { font-family: var(--sans); font-size: 0.62em; vertical-align: middle; }
    .case-metricline {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.02em;
      color: var(--ink-faint);
      line-height: 1.4;
      margin: 0 0 10px;
    }
    .case-blurb { font-size: 14.5px; color: var(--ink-soft); line-height: 1.52; margin: 0 0 12px; }
    .case-tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .tag {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.02em;
      color: var(--ink-soft);
      border: 1px solid var(--rule-strong);
      padding: 3px 8px;
    }

    /* ---- Now (ledger) ---- */
    .now-grid { display: grid; grid-template-columns: 1fr; }
    .now-row {
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: clamp(16px, 3vw, 44px);
      padding: 22px 0;
      border-bottom: 1px solid var(--rule);
      align-items: baseline;
    }
    .now-row:first-of-type { border-top: 1px solid var(--ink); }
    .now-key {
      font-family: var(--serif);
      font-size: clamp(22px, 2.6vw, 30px);
      color: var(--accent);
      line-height: 1;
    }
    .now-val { font-size: 15.5px; color: var(--ink); line-height: 1.55; max-width: 64ch; }
    .now-val a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent-soft); white-space: nowrap; }
    .now-val a:hover { background: var(--accent); color: var(--paper); border-color: var(--accent); }

    /* ---- CV ---- */
    .cv-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: clamp(28px, 5vw, 64px);
      margin-top: 36px;
      align-items: start;
    }
    .cv-subhead {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink);
      border-bottom: 2px solid var(--ink);
      padding-bottom: 6px;
      margin: 0 0 6px;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }
    .cv-subhead .count { color: var(--ink-faint); font-size: 10px; }
    .role { padding: 18px 0; border-bottom: 1px solid var(--rule); }
    .role-head { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: baseline; gap: 8px; }
    .role-title { font-family: var(--serif); font-size: clamp(20px, 2.2vw, 26px); line-height: 1.05; }
    .role-co { color: var(--ink-soft); }
    .role-dates { font-family: var(--mono); font-size: 11px; letter-spacing: 0.04em; color: var(--ink-faint); white-space: nowrap; }
    .role-points { margin: 10px 0 0; padding: 0; list-style: none; }
    .role-points li {
      font-size: 14.5px;
      color: var(--ink-soft);
      line-height: 1.52;
      padding-left: 18px;
      position: relative;
      margin-bottom: 7px;
    }
    /* plainer marker than the journalism mark; a simple square tick */
    .role-points li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.62em;
      width: 6px; height: 6px;
      background: var(--accent-soft);
    }
    .cv-aside > div { margin-bottom: 30px; }
    .edu-item { padding: 12px 0; border-bottom: 1px solid var(--rule); }
    .edu-school { font-family: var(--serif); font-size: 19px; line-height: 1.1; }
    .edu-deg { font-size: 13.5px; color: var(--ink-soft); margin: 3px 0; }
    .edu-dates { font-family: var(--mono); font-size: 11px; color: var(--ink-faint); letter-spacing: 0.04em; }
    .skill-row { padding: 9px 0; border-bottom: 1px solid var(--rule); }
    .skill-k { font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent); margin-bottom: 2px; }
    .skill-v { font-size: 13px; color: var(--ink-soft); line-height: 1.45; }
    .pub {
      border: 1px solid var(--ink);
      padding: 18px;
      background: var(--paper-2);
    }
    .pub-title { font-family: var(--serif); font-size: 20px; line-height: 1.12; margin-bottom: 8px; }
    .pub-note { font-size: 13px; color: var(--ink-soft); line-height: 1.5; margin-bottom: 12px; }
    .pub-link { font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent); }
    .pub-link:hover { background: var(--accent); color: var(--paper); }

    /* ---- Reading shelf ---- */
    .reading-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      margin-top: 36px;
      border-top: 1px solid var(--ink);
    }
    .shelf-item {
      padding: 22px 18px 22px 0;
      border-right: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
    }
    .shelf-item:last-child { border-right: 0; }
    .shelf-num { font-family: var(--mono); font-size: 11px; letter-spacing: 0.1em; color: var(--ink-faint); margin-bottom: 8px; }
    .shelf-t { font-family: var(--serif); font-size: 23px; line-height: 1.06; margin-bottom: 8px; }
    .shelf-n { font-size: 13.5px; color: var(--ink-soft); line-height: 1.5; }

    /* ---- Languages ---- */
    .lang-row { display: flex; flex-wrap: wrap; gap: 0; margin-top: 32px; border: 1px solid var(--ink); }
    .lang {
      flex: 1 1 16%;
      min-width: 120px;
      padding: 20px 16px;
      border-right: 1px solid var(--rule);
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .lang:last-child { border-right: 0; }
    .lang-code { font-family: var(--mono); font-size: 12px; letter-spacing: 0.1em; color: var(--accent); }
    .lang-name { font-family: var(--serif); font-size: 26px; line-height: 1; }

    /* ---- Contact ---- */
    .contact { position: relative; overflow: hidden; }
    .contact-water {
      position: absolute;
      right: -2vw;
      top: 50%;
      transform: translateY(-50%);
      font-family: var(--serif);
      font-size: clamp(200px, 44vw, 560px);
      line-height: 0.8;
      color: var(--rule);
      opacity: 0.55;
      pointer-events: none;
      z-index: 0;
      user-select: none;
    }
    .contact-inner { position: relative; z-index: 1; max-width: 64ch; }
    .contact h2 { margin-bottom: 0.3em; }
    .contact-body { font-size: clamp(16px, 1.8vw, 19px); color: var(--ink-soft); line-height: 1.55; max-width: 56ch; }
    .contact-cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 30px; }

    /* ---- Footer ---- */
    footer {
      background: var(--ink);
      color: var(--paper);
      padding: clamp(40px, 6vw, 72px) 0 30px;
      position: relative;
      z-index: 2;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: 1.6fr 1fr 1fr 1fr;
      gap: 30px;
      padding-bottom: 36px;
      border-bottom: 1px solid rgba(247,244,236,0.18);
    }
    .footer-brand { display: flex; align-items: center; gap: 10px; font-family: var(--serif); font-size: 26px; }
    .footer-brand .mark {
      width: 30px; height: 30px; display: grid; place-items: center;
      border: 1px solid var(--paper); font-size: 17px;
    }
    .footer-tag { font-size: 14px; color: rgba(247,244,236,0.7); margin-top: 14px; max-width: 34ch; line-height: 1.5; }
    .footer-col h4 { font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(247,244,236,0.55); margin: 0 0 14px; }
    .footer-col ul { list-style: none; margin: 0; padding: 0; }
    .footer-col li { margin-bottom: 9px; }
    .footer-col a { color: rgba(247,244,236,0.86); text-decoration: none; font-size: 14px; }
    .footer-col a:hover { color: var(--accent-soft); }
    .footer-bottom {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 10px;
      padding-top: 22px;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.04em;
      color: rgba(247,244,236,0.55);
    }

    /* ---- Mobile menu ---- */
    .mobile-menu {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 40;
      background: var(--paper);
      padding: 80px var(--gutter) 40px;
      overflow-y: auto;
    }
    .mobile-menu.open { display: block; }
    .mobile-menu a {
      display: block;
      font-family: var(--serif);
      font-size: 34px;
      text-decoration: none;
      color: var(--ink);
      padding: 12px 0;
      border-bottom: 1px solid var(--rule);
    }
    .mobile-menu a:hover { color: var(--accent); }
    .mm-close {
      position: absolute;
      top: 18px; right: var(--gutter);
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      background: none;
      border: 1px solid var(--ink);
      padding: 8px 12px;
      cursor: pointer;
    }

    /* ---- Reveal + run animation (all motion-gated) ---- */
    @media (prefers-reduced-motion: no-preference) {
      .reveal { opacity: 0; transform: translateY(16px); transition: opacity 0.7s ease, transform 0.7s ease; }
      .reveal.in { opacity: 1; transform: none; }
      .nav-links a, .btn, .case-title, .now-val a, .footer-col a, .run-replay { transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease; }

      /* run-log line reveal: hidden until the box is armed, then staggered */
      .runbox.armed .run-log li { opacity: 0; transform: translateY(6px); }
      .runbox.run .run-log li { animation: logline 0.5s ease forwards; }
      .runbox.run .run-log li:nth-child(1) { animation-delay: 0.05s; }
      .runbox.run .run-log li:nth-child(2) { animation-delay: 0.45s; }
      .runbox.run .run-log li:nth-child(3) { animation-delay: 0.85s; }
      .runbox.run .run-log li:nth-child(4) { animation-delay: 1.25s; }
      .runbox.run .run-log li:nth-child(5) { animation-delay: 1.6s; }
      .runbox.run .run-log li:nth-child(6) { animation-delay: 1.95s; }
      .runbox.armed .ba-col.after { opacity: 0.25; }
      .runbox.run .ba-col.after { animation: afterin 0.6s ease 2.3s forwards; }
      @keyframes logline { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }
      @keyframes afterin { from { opacity: 0.25; } to { opacity: 1; } }
    }

    /* ---- Responsive ---- */
    @media (max-width: 980px) {
      .hero-grid, .wf-grid, .cv-grid { grid-template-columns: 1fr; }
      .hero-aside { border-left: 0; padding-left: 0; border-top: 1px solid var(--rule-strong); padding-top: 24px; }
      .reading-grid { grid-template-columns: repeat(2, 1fr); }
      .shelf-item:nth-child(2n) { border-right: 0; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 720px) {
      .nav-links, .lang-switch { display: none; }
      .nav-toggle { display: inline-block; }
      .now-row { grid-template-columns: 1fr; gap: 8px; }
      .reading-grid { grid-template-columns: 1fr; }
      .shelf-item { border-right: 0; }
      .footer-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 600px) {
      /* cases collapse to single column; reset the column dividers */
      .cases { grid-template-columns: 1fr; }
      .case:nth-child(odd), .case:nth-child(even) { padding-left: 0; padding-right: 0; border-right: 0; }
      .case:nth-child(1), .case:nth-child(2) { border-top: 1px solid var(--rule); }
      .case:nth-child(1) { border-top: 1px solid var(--ink); }
      .run-log li { grid-template-columns: 40px 54px 1fr; gap: 6px; font-size: 11px; }
      .ba { grid-template-columns: 1fr; }
      .ba-mid { border: 0; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); padding: 6px 0; }
    }
    @media (max-width: 480px) {
      body { font-size: 16px; }
      .lang { flex: 1 1 100%; min-width: 0; border-right: 0; border-bottom: 1px solid var(--rule); }
      .lang:last-child { border-bottom: 0; }
    }
  </style>
</head>
<body>
  <!-- NAV -->
  <nav class="editorial">
    <div class="nav-inner">
      <a class="nav-brand" href="/#" aria-label="Tom Scholtes home">
        <span class="mark">T</span> Tom Scholtes
      </a>
      <ul class="nav-links">
        {navItems.map((it) => (<li><a href={it.href}>{it.label}</a></li>))}
      </ul>
      <div class="nav-right">
        <span class="lang-switch"><b>EN</b> / DE / FR / RU</span>
        <a class="nav-cta" href="/#contact">Say hi</a>
        <button class="nav-toggle" id="navToggle" aria-label="Open menu">Menu</button>
      </div>
    </div>
  </nav>

  <!-- MOBILE MENU -->
  <div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Navigation">
    <button class="mm-close" id="mmClose" aria-label="Close menu">Close</button>
    {navItems.map((it) => (<a href={it.href}>{it.label}</a>))}
    <a href="/#contact">Say hi</a>
  </div>

  <div class="wrap">
    <!-- MASTHEAD (person, not a publication) -->
    <header class="masthead">
      <div class="masthead-top">
        <span class="iss">Luxembourg &middot; est. {year}</span>
        <span>Finance ops engineer</span>
      </div>
      <h1 class="masthead-title">Tom Scholtes</h1>
      <div class="masthead-sub">I build the automation behind regulated finance operations</div>
    </header>

    <!-- HERO -->
    <section class="hero" id="top">
      <div class="hero-eyebrow reveal">Personal site &middot; live CV &middot; portfolio of work</div>
      <div class="hero-grid">
        <div>
          <h2 class="hero-headline reveal">I build the automation behind <em>regulated finance</em> operations.</h2>
          <p class="hero-lead reveal">I'm Tom. I build AI-augmented automation for the operational work in regulated finance: regulatory notes, accounts quality review, document workflows, mailbox triage, and the reusable tooling that ties them together. Six years in Luxembourg fund services across PE, Private Debt and Real Estate, now spent designing the systems that do the work instead of doing it by hand. This site is the evidence: a live CV, the patterns behind the work, and case studies of it shipping.</p>
          <div class="hero-cta-row reveal">
            <a class="btn btn-solid" href="#work">See the work</a>
            <a class="btn btn-ghost" href="#contact">Get in touch</a>
          </div>
        </div>
        <aside class="hero-aside reveal">
          <!-- SIGNATURE: live "automation run" instrument, animates on view -->
          <figure class="runbox" id="runbox" aria-label="Illustration: a finance automation pass, shown step by step">
            <figcaption class="runbox-bar" id="runbar">
              <span><span class="dot"></span>finance-pass</span>
              <span class="runbox-status" id="runstatus">idle</span>
            </figcaption>
            <ul class="run-log">
              {runLog.map((r) => (
                <li>
                  <span class="run-t">{r.t}</span>
                  <span class="run-stage" data-s={r.s}>{r.s}</span>
                  <span class="run-txt">{r.txt}</span>
                </li>
              ))}
            </ul>
            <div class="ba" aria-hidden="false">
              <div class="ba-col before">
                <div class="ba-label">By hand</div>
                <div class="ba-line"><b>open</b> three files, eyeball each cross-reference</div>
                <div class="ba-line">draft the template and email manually</div>
              </div>
              <div class="ba-mid">&rarr;</div>
              <div class="ba-col after">
                <div class="ba-label">Same pass, automated</div>
                <div class="ba-line"><b>one</b> review of a drafted template and email</div>
                <div class="ba-line">the human signs off and owns the decision</div>
              </div>
            </div>
            <div class="run-foot">
              <span>Illustrative. Synthetic data, no client files.</span>
              <button class="run-replay" id="runReplay" type="button">Replay</button>
            </div>
          </figure>
          <p class="figcaption">A finance pass, step by step. The machine finds and drafts; a human signs off. Run it for real on the live demo.</p>
          <div class="stats">
            <div class="stat"><span class="stat-val">6 yrs</span><span class="stat-label">in Lux fund services</span></div>
            <div class="stat"><span class="stat-val">9</span><span class="stat-label">case studies on file</span></div>
            <div class="stat"><span class="stat-val">6</span><span class="stat-label">languages spoken</span></div>
          </div>
        </aside>
      </div>
    </section>

    <!-- WORKFLOW AUTOMATION -->
    <section id="workflow">
      <span class="kicker reveal">Live demo</span>
      <div class="wf-grid">
        <div>
          <h2 class="feature reveal">See the automation run, on synthetic data.</h2>
          <p class="deck reveal">Point AI at the manual workflows underneath a finance desk. It surfaces what is unbooked, mismatched, or missing, builds the upload template, and drafts the counterparty email. The operator reviews and signs off; the human owns the decision. Click through a before-and-after process map and run it live.</p>
          <div class="hero-cta-row reveal" style="margin-top:22px;">
            <a class="btn btn-solid" href="/workflow-automation/">Open the live demo</a>
          </div>
        </div>
        <div class="reveal">
          <blockquote class="pullquote">The operator reviews and signs off. The human owns the decision.</blockquote>
          <ol class="wf-stages">
            {stages.map((s) => (
              <li>
                <span class="wf-num">{s.n}</span>
                <div>
                  <div class="wf-stage-name">{s.name}</div>
                  <div class="wf-stage-desc">{s.desc}</div>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <!-- CASE STUDIES -->
    <section id="work">
      <span class="kicker reveal">Case studies</span>
      <div class="work-head">
        <h2 class="feature reveal" style="margin-bottom:0;">Patterns I've worked through.</h2>
        <span class="work-meta reveal">Nine features &middot; sanitised</span>
      </div>
      <p class="deck reveal" style="margin-top:14px;">Sanitised. Employer name, entity names and figures removed. Notes on how I think about this kind of work in fund services.</p>
      <div class="cases">
        {cases.map((c) => (
          <a class="case reveal" href={c.href}>
            <div class="case-top">
              <span class="case-no">Case {c.n}</span>
              <span class="case-kind" data-k={c.kind}>{c.kind}</span>
            </div>
            <h3 class="case-title">{c.title} <span class="arrow">&rarr;</span></h3>
            <p class="case-metricline">{c.metricLabel}</p>
            <p class="case-blurb">{c.blurb}</p>
            <div class="case-tags">
              {c.tags.map((t) => (<span class="tag">{t}</span>))}
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- NOW -->
    <section id="now">
      <span class="kicker reveal">/ now &middot; June 2026</span>
