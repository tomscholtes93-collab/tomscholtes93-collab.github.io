  <!-- ============ DATA PAYLOAD + GRAPH ENGINE ============ -->
  <script type="application/json" id="data">{JSON.stringify({ nodes, edges, meta })}</script>
  <script type="application/json" id="tourdata" set:html={tourSay}></script>
  <script>
    document.body.classList.remove('nojs');

    const DATA = JSON.parse(document.getElementById('data').textContent);
    const TOUR = JSON.parse(document.getElementById('tourdata').textContent);
    const stage = document.getElementById('stage');
    const viewport = document.getElementById('viewport');
    const wires = document.getElementById('wires');
    const panel = document.getElementById('panel');
    const srlive = document.getElementById('srlive');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const nodeEls = {};
    document.querySelectorAll('.node').forEach(el => { nodeEls[el.dataset.node] = el; });
    const nodeMap = {};
    DATA.nodes.forEach(n => { nodeMap[n.id] = n; });

    /* ---- one-line precis per node, harvested from the SAME templates that feed
       the panel: take the .lead text. Single source of truth, no retyping. ---- */
    DATA.nodes.forEach(n => {
      const tpl = document.getElementById('tpl-' + n.id);
      const lead = tpl && tpl.content.querySelector('.lead');
      const target = document.querySelector(`[data-precis="${n.id}"]`);
      if (lead && target) target.textContent = lead.textContent.trim();
    });

    /* ---- draw wires (curved connectors) ---- */
    const SVGNS = 'http://www.w3.org/2000/svg';
    const wireEls = [];
    DATA.edges.forEach((e) => {
      const a = nodeMap[e.a], b = nodeMap[e.b];
      const my = (a.y + b.y) / 2;
      const d = `M ${a.x} ${a.y} C ${a.x} ${my}, ${b.x} ${my}, ${b.x} ${b.y}`;
      const p = document.createElementNS(SVGNS, 'path');
      p.setAttribute('d', d); p.setAttribute('class', 'wire');
      p.dataset.a = e.a; p.dataset.b = e.b;
      wires.appendChild(p);

      const flow = document.createElementNS(SVGNS, 'path');
      flow.setAttribute('d', d); flow.setAttribute('class', 'wire-flow');
      flow.dataset.a = e.a; flow.dataset.b = e.b;
      wires.appendChild(flow);

      const t = document.createElementNS(SVGNS, 'text');
      // offset label perpendicular-ish to reduce collision with crossing wires
      const dx = (b.x - a.x), dy = (b.y - a.y);
      const len = Math.hypot(dx, dy) || 1;
      const ox = (-dy / len) * 10, oy = (dx / len) * 10;
      t.setAttribute('x', (a.x + b.x) / 2 + ox);
      t.setAttribute('y', my - 2 + oy);
      t.setAttribute('text-anchor', 'middle');
      t.setAttribute('class', 'edge-label');
      t.dataset.a = e.a; t.dataset.b = e.b;
      t.textContent = e.label;
      wires.appendChild(t);

      wireEls.push({ p, flow, t });
    });

    function highlightEdges(id) {
      wires.querySelectorAll('.wire, .edge-label').forEach(el => {
        const on = id && (el.dataset.a === id || el.dataset.b === id);
        el.classList.toggle('hot', !!on);
      });
      wires.querySelectorAll('.wire-flow').forEach(el => {
        const on = id && (el.dataset.a === id || el.dataset.b === id);
        if (on && !reduce) { el.style.opacity = '.9'; el.classList.add('anim'); }
        else { el.style.opacity = '0'; el.classList.remove('anim'); }
      });
    }

    /* ---- pan + zoom ---- */
    let scale = 1, tx = 0, ty = 0;
    const LOGW = 1600, LOGH = 1100;

    function apply(animate) {
      if (animate && !reduce) viewport.classList.remove('live');
      else viewport.classList.add('live');
      viewport.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
    }

    function fit() {
      const vw = stage.clientWidth, vh = stage.clientHeight;
      const ov = document.body.classList.contains('overview');
      scale = Math.min(vw / LOGW, vh / LOGH) * (ov ? 1.02 : 0.96);
      scale = Math.max(0.3, Math.min(scale, 1.4));
      tx = (vw - LOGW * scale) / 2;
      ty = (vh - LOGH * scale) / 2 + 14;
      apply(true);
    }

    // narrow desktop: panel becomes a bottom sheet, so center the node above it
    function panelIsSheet() { return stage.clientWidth < 820; }

    function focusNode(n, openScale) {
      const vw = stage.clientWidth, vh = stage.clientHeight;
      const sheet = panelIsSheet();
      const panelW = (panel.classList.contains('open') && !sheet) ? Math.min(560, vw) : 0;
      const panelH = (panel.classList.contains('open') && sheet) ? Math.min(vh * 0.62, vh) : 0;
      const visW = vw - panelW;
      const visH = vh - panelH;
      scale = openScale || Math.min(1.05, scale < 0.7 ? 0.85 : scale);
      tx = visW / 2 - n.x * scale;
      ty = visH / 2 - n.y * scale + 10;
      apply(true);
    }

    /* apply bottom-sheet geometry to the panel when the viewport is narrow */
    function syncPanelMode() {
      if (panelIsSheet()) {
        panel.style.top = 'auto';
        panel.style.width = '100%';
        panel.style.height = 'min(62vh, 100%)';
        panel.style.borderLeft = '0';
        panel.style.borderTop = '1px solid var(--line-2)';
        panel.style.transform = panel.classList.contains('open') ? 'translateY(0)' : 'translateY(100%)';
        panel.dataset.sheet = '1';
      } else {
        panel.style.top = '0';
        panel.style.width = 'min(560px, 100vw)';
        panel.style.height = 'auto';
        panel.style.borderTop = '0';
        panel.style.borderLeft = '1px solid var(--line-2)';
        panel.style.transform = panel.classList.contains('open') ? 'translateX(0)' : 'translateX(100%)';
        panel.dataset.sheet = '';
      }
    }

    /* drag */
    let dragging = false, sx = 0, sy = 0, stx = 0, sty = 0, moved = false;
    stage.addEventListener('pointerdown', (ev) => {
      if (ev.target.closest('.node')) return;
      stopTour('user');
      dragging = true; moved = false;
      sx = ev.clientX; sy = ev.clientY; stx = tx; sty = ty;
      stage.classList.add('dragging');
      stage.setPointerCapture(ev.pointerId);
    });
    stage.addEventListener('pointermove', (ev) => {
      if (!dragging) return;
      tx = stx + (ev.clientX - sx);
      ty = sty + (ev.clientY - sy);
      if (Math.abs(ev.clientX - sx) + Math.abs(ev.clientY - sy) > 4) moved = true;
      apply(false);
    });
    function endDrag() { dragging = false; stage.classList.remove('dragging'); }
    stage.addEventListener('pointerup', endDrag);
    stage.addEventListener('pointercancel', endDrag);

    /* wheel zoom (anchored at cursor) */
    stage.addEventListener('wheel', (ev) => {
      ev.preventDefault();
      stopTour('user');
      const rect = stage.getBoundingClientRect();
      const cx = ev.clientX - rect.left, cy = ev.clientY - rect.top;
      const prev = scale;
      const delta = -ev.deltaY * 0.0014;
      scale = Math.max(0.3, Math.min(2.2, scale * (1 + delta)));
      const k = scale / prev;
      tx = cx - (cx - tx) * k;
      ty = cy - (cy - ty) * k;
      apply(false);
    }, { passive: false });

    /* pinch zoom */
    let pinch = null;
    stage.addEventListener('touchstart', (ev) => {
      if (ev.touches.length === 2) {
        const [a, b] = ev.touches;
        pinch = { d: Math.hypot(a.clientX - b.clientX, a.clientY - b.clientY), s: scale };
      }
    }, { passive: true });
    stage.addEventListener('touchmove', (ev) => {
      if (pinch && ev.touches.length === 2) {
        const [a, b] = ev.touches;
        const d = Math.hypot(a.clientX - b.clientX, a.clientY - b.clientY);
        scale = Math.max(0.3, Math.min(2.2, pinch.s * (d / pinch.d)));
        apply(false);
      }
    }, { passive: true });
    stage.addEventListener('touchend', () => { pinch = null; }, { passive: true });

    document.getElementById('zin').onclick = () => { scale = Math.min(2.2, scale * 1.2); apply(true); };
    document.getElementById('zout').onclick = () => { scale = Math.max(0.3, scale / 1.2); apply(true); };
    document.getElementById('zreset').onclick = () => { setOverview(false); closePanel(); fit(); };

    /* ---- overview (see-everything) mode ---- */
    const zall = document.getElementById('zall');
    function setOverview(on) {
      document.body.classList.toggle('overview', on);
      zall.classList.toggle('active', on);
      zall.setAttribute('aria-pressed', on ? 'true' : 'false');
      if (on) { closePanel(); highlightEdges(null); fit(); }
    }
    zall.onclick = () => { stopTour('user'); setOverview(!document.body.classList.contains('overview')); };

    /* hover highlight */
    Object.entries(nodeEls).forEach(([id, el]) => {
      el.addEventListener('pointerenter', () => { if (!panel.classList.contains('open') && !tourState.running) highlightEdges(id); });
      el.addEventListener('pointerleave', () => { if (!panel.classList.contains('open') && !tourState.running) highlightEdges(null); });
      el.addEventListener('click', () => { if (moved) { moved = false; return; } stopTour('user'); openNode(id); });
    });

    /* ---- panel rendering: CLONE the matching template (single source) ---- */
    let activeId = null;
    function openNode(id) {
      if (document.body.classList.contains('overview')) setOverview(false);
      activeId = id;
      Object.values(nodeEls).forEach(el => el.classList.remove('active', 'touring'));
      nodeEls[id].classList.add('active');
      highlightEdges(id);

      document.getElementById('ptag').textContent = DATA.meta[id].tag;
      document.getElementById('ptitle').textContent = DATA.meta[id].title;
      document.getElementById('pmeta').textContent = DATA.meta[id].meta;

      const body = document.getElementById('pbody');
      body.innerHTML = '';
      const wrap = document.createElement('div');
      wrap.className = 'pcontent';
      wrap.appendChild(document.getElementById('tpl-' + id).content.cloneNode(true));
      body.appendChild(wrap);
      body.scrollTop = 0;
      body.querySelectorAll('[data-goto]').forEach(b => {
        b.addEventListener('click', (ev) => { ev.preventDefault(); openNode(b.dataset.goto); });
      });

      panel.classList.add('open');
      syncPanelMode();
      focusNode(nodeMap[id]);
      // calm SR announcement: title only, not a re-read of the whole body
      srlive.textContent = DATA.meta[id].title + ' node opened.';
    }

    function closePanel() {
      panel.classList.remove('open');
      syncPanelMode();
      activeId = null;
      Object.values(nodeEls).forEach(el => el.classList.remove('active'));
      if (!tourState.running) highlightEdges(null);
    }
    document.getElementById('pclose').onclick = closePanel;
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { stopTour('user'); closePanel(); if (document.body.classList.contains('overview')) setOverview(false); }
    });

    /* keyboard access on nodes */
    Object.values(nodeEls).forEach(el => el.setAttribute('tabindex', '0'));
    Object.entries(nodeEls).forEach(([id, el]) => {
      el.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); stopTour('user'); openNode(id); } });
      el.addEventListener('focus', () => stopTour('user'));
    });

    window.addEventListener('resize', () => { syncPanelMode(); if (activeId) focusNode(nodeMap[activeId]); else fit(); });

    /* ---- flow animation via stroke offset ---- */
    if (!reduce) {
      let off = 0;
      (function tick() {
        off = (off - 0.6) % 14;
        wires.querySelectorAll('.wire-flow.anim').forEach(el => { el.style.strokeDashoffset = off; });
        requestAnimationFrame(tick);
      })();
    }

    /* ================= AUTO-TOUR ================= */
    /* On load with motion allowed, the graph assembles (edges draw in), then a
       narrated walk steps through each node. Any interaction hands control over;
       a replay pill lets the visitor restart it. */
    const hud = document.getElementById('tourhud');
    const bar = document.getElementById('tourbar');
    const capEl = document.getElementById('tourcap');
    const whoEl = document.getElementById('tourwho');
    const progEl = document.getElementById('tourprog');
    const pauseBtn = document.getElementById('tourpause');
    const skipBtn = document.getElementById('tourskip');
    const replayPill = document.getElementById('replaytour');

    const STEP_MS = 2400;
    const tourState = { running: false, i: 0, paused: false, timer: 0, started: 0, elapsed: 0 };

    function tourSpotlight(id) {
      Object.values(nodeEls).forEach(el => el.classList.remove('touring', 'active'));
      const el = nodeEls[id];
      if (el) el.classList.add('touring');
      highlightEdges(id);
      const n = nodeMap[id];
      // gentle pan to the node without opening the panel (content shown via HUD)
      const vw = stage.clientWidth, vh = stage.clientHeight;
      scale = 0.92;
      tx = vw / 2 - n.x * scale;
      ty = vh / 2 - n.y * scale + 6;
      apply(true);
    }

    function setHud(step, idx) {
      whoEl.textContent = nodeMap[step.id].label;
      capEl.textContent = step.say;
      progEl.textContent = (idx + 1) + ' / ' + TOUR.length;
      srlive.textContent = nodeMap[step.id].label + '. ' + step.say;
    }

    function runBar(ms) {
      bar.classList.add('show');
      bar.style.transition = 'none';
      bar.style.width = '0';
      // force reflow so the next width transitions
      void bar.offsetWidth;
      if (!reduce) {
        bar.style.transition = 'width ' + ms + 'ms linear';
        bar.style.width = '100%';
      } else {
        bar.style.width = '100%';
      }
    }

    function tourStep() {
      if (!tourState.running) return;
      const step = TOUR[tourState.i];
      setHud(step, tourState.i);
      tourSpotlight(step.id);
      runBar(STEP_MS);
      tourState.started = Date.now();
      tourState.elapsed = 0;
      tourState.timer = window.setTimeout(advance, STEP_MS);
    }

    function advance() {
      tourState.i++;
      if (tourState.i >= TOUR.length) { finishTour(); return; }
      tourStep();
    }

    function startTour() {
      if (tourState.running) return;
      replayPill.classList.remove('show');
      setOverview(false);
      closePanel();
      tourState.running = true;
      tourState.i = 0;
      tourState.paused = false;
      pauseBtn.textContent = 'pause';
      hud.classList.add('show');
      tourStep();
    }

    function pauseTour() {
      if (!tourState.running || tourState.paused) return;
      tourState.paused = true;
      window.clearTimeout(tourState.timer);
      tourState.elapsed += Date.now() - tourState.started;
      // freeze the bar mid-fill
      const pct = Math.min(100, (tourState.elapsed / STEP_MS) * 100);
      bar.style.transition = 'none';
      bar.style.width = pct + '%';
      pauseBtn.textContent = 'resume';
    }

    function resumeTour() {
      if (!tourState.running || !tourState.paused) return;
      tourState.paused = false;
      pauseBtn.textContent = 'pause';
      const remain = Math.max(120, STEP_MS - tourState.elapsed);
      if (!reduce) {
        bar.style.transition = 'width ' + remain + 'ms linear';
        bar.style.width = '100%';
      }
      tourState.started = Date.now();
      tourState.timer = window.setTimeout(advance, remain);
    }

    pauseBtn.onclick = () => { tourState.paused ? resumeTour() : pauseTour(); };

    function endTourChrome() {
      hud.classList.remove('show');
      bar.classList.remove('show');
      bar.style.width = '0';
      Object.values(nodeEls).forEach(el => el.classList.remove('touring'));
    }

    // stop because the user took over: hand control, surface replay, do NOT open
    function stopTour(reason) {
      if (!tourState.running) return;
      window.clearTimeout(tourState.timer);
      tourState.running = false;
      tourState.paused = false;
      endTourChrome();
      if (!panel.classList.contains('open') && !document.body.classList.contains('overview')) {
        highlightEdges(activeId);
      }
      replayPill.classList.add('show');
    }

    // natural completion: land on identity, open it, offer replay
    function finishTour() {
      window.clearTimeout(tourState.timer);
      tourState.running = false;
      endTourChrome();
      replayPill.classList.add('show');
      srlive.textContent = 'Tour complete. The map is yours to explore.';
      fit();
    }

    skipBtn.onclick = () => { stopTour('user'); };
    replayPill.onclick = () => { startTour(); };

    /* ---- intro: draw edges in, then auto-tour ---- */
    function drawEdgesIn() {
      if (reduce) return Promise.resolve();
      return new Promise((resolve) => {
        wireEls.forEach((w, i) => {
          const len = w.p.getTotalLength();
          w.p.style.setProperty('--len', len);
          w.p.classList.add('drawing');
          w.p.style.transition = 'none';
          void w.p.getBoundingClientRect();
          const delay = 90 + i * 55;
          w.t.style.opacity = '0';
          w.t.style.transition = 'opacity .4s ease ' + (delay + 260) + 'ms';
          window.setTimeout(() => {
            w.p.style.transition = 'stroke-dashoffset .6s cubic-bezier(.2,.8,.2,1)';
            w.p.style.strokeDashoffset = '0';
          }, delay);
          window.setTimeout(() => { w.t.style.opacity = '1'; }, delay + 10);
        });
        window.setTimeout(() => {
          wireEls.forEach(w => { w.p.classList.remove('drawing'); w.p.style.transition = ''; w.p.style.removeProperty('--len'); w.p.style.strokeDashoffset = ''; });
          resolve();
        }, 90 + wireEls.length * 55 + 700);
      });
    }

    /* ---- boot ---- */
    syncPanelMode();
    fit();

    // respect a user who already started interacting before boot resolved
    let booted = false;
    function boot() {
      if (booted) return; booted = true;
      if (reduce) {
        // no motion: no auto-walk. Open identity statically and offer the tour as opt-in.
        openNode('identity');
        replayPill.classList.add('show');
        return;
      }
      drawEdgesIn().then(() => {
        // if the visitor already grabbed control during the intro, do not start
        if (panel.classList.contains('open') || document.body.classList.contains('overview') || dragging) {
          replayPill.classList.add('show');
          return;
        }
        startTour();
      });
    }
    // start shortly after layout settles
    window.setTimeout(boot, reduce ? 0 : 300);

    /* ---- mobile vertical-trace packet (one pass on load) ---- */
    (function () {
      if (reduce) return;
      const packet = document.getElementById('packet');
      if (!packet) return;
      // run once when the trace scrolls into view
      const trace = packet.parentElement;
      if (!('IntersectionObserver' in window)) { packet.classList.add('run'); return; }
      const io = new IntersectionObserver((ents) => {
        ents.forEach(e => { if (e.isIntersecting) { packet.classList.add('run'); io.disconnect(); } });
      }, { threshold: 0.25 });
      io.observe(trace);
    })();
  </script>
</body>
</html>
