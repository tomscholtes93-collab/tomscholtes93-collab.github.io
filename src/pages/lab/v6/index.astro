  </div>

  <script>
    // Signature interaction: keyboard-driven index. Press a section number (0-8)
    // to jump straight to that entry, true to a "table of contents of a life".
    (function () {
      const map = {
        '0': 'now', '1': 'work', '2': '#', '3': '#', '4': 'workflow',
        '5': 'cv', '6': 'languages', '7': 'reading', '8': 'contact',
      };
      window.addEventListener('keydown', function (e) {
        if (e.metaKey || e.ctrlKey || e.altKey) return;
        const t = e.target;
        if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA')) return;
        const id = map[e.key];
        if (!id || id === '#') return;
        const el = document.getElementById(id);
        if (el) {
          el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    })();
  </script>
</body>
