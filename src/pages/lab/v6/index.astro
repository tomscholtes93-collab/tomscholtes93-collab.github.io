---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Tom Scholtes. Finance ops engineer who automates the work in reach.</title>
  <style>
    :root{
      --ink:#0b0b0b;
      --paper:#f3f1ea;
      --line:#0b0b0b;
      --accent:#ff3b00;
      --mut:#6a6a64;
      --hair:1px;
      --pad:clamp(14px,3.2vw,28px);
    }
    *{box-sizing:border-box;}
    html{-webkit-text-size-adjust:100%;}
    body{
      margin:0;
      background:var(--paper);
      color:var(--ink);
      font-family:"JetBrains Mono",ui-monospace,SFMono-Regular,Menlo,monospace;
      font-size:13px;
      line-height:1.45;
      -webkit-font-smoothing:antialiased;
    }
    a{color:inherit;text-decoration:none;}
    ::selection{background:var(--accent);color:var(--paper);}

    .wrap{max-width:1320px;margin:0 auto;border-left:var(--hair) solid var(--line);border-right:var(--hair) solid var(--line);}

    /* ---- generic row primitives ---- */
    .row{display:grid;border-bottom:var(--hair) solid var(--line);}
    .mono-cap{font-weight:700;text-transform:uppercase;letter-spacing:.14em;font-size:10px;}
    .mut{color:var(--mut);}

    /* ---- TOP BAR ---- */
    .topbar{
      display:grid;grid-template-columns:1fr auto;align-items:stretch;
      border-bottom:2px solid var(--line);position:sticky;top:0;z-index:30;background:var(--paper);
    }
    .brand{display:flex;align-items:center;gap:12px;padding:10px var(--pad);}
    .tmark{
      width:26px;height:26px;display:grid;place-items:center;background:var(--ink);color:var(--paper);
      font-weight:700;font-size:14px;
    }
    .brand b{font-weight:700;letter-spacing:.04em;}
    .topbar-meta{display:flex;align-items:center;gap:14px;padding:10px var(--pad);border-left:var(--hair) solid var(--line);}
    .langset{font-size:10px;letter-spacing:.14em;font-weight:500;}
    .saychip{
      background:var(--accent);color:var(--paper);padding:6px 12px;font-weight:700;font-size:10px;
      letter-spacing:.14em;text-transform:uppercase;
    }
    @media (prefers-reduced-motion: no-preference){.saychip{transition:transform .12s ease;}}
    .saychip:hover{transform:translate(-2px,-2px);box-shadow:3px 3px 0 var(--ink);}

    /* ---- MARQUEE ---- */
    .marquee{
      overflow:hidden;white-space:nowrap;border-bottom:2px solid var(--line);
      background:var(--ink);color:var(--paper);
    }
    .marquee ul{display:inline-flex;list-style:none;margin:0;padding:0;}
    .marquee li{padding:8px 0;font-size:11px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;}
    .marquee li span{padding:0 22px;border-right:var(--hair) solid #444;}
    .marquee .dot{color:var(--accent);}
    @media (prefers-reduced-motion: no-preference){
      .marquee ul{animation:scroll 38s linear infinite;}
      .marquee:hover ul{animation-play-state:paused;}
    }
    @keyframes scroll{from{transform:translateX(0);}to{transform:translateX(-50%);}}

    /* ---- INDEX NAV (table of contents) ---- */
    .toc .row{grid-template-columns:64px 1fr 130px;align-items:center;}
    .toc .row > *{padding:11px var(--pad);}
    .toc .ix{font-weight:700;color:var(--accent);border-right:var(--hair) solid var(--line);}
    .toc .nm{font-size:clamp(15px,2.6vw,22px);font-weight:500;letter-spacing:-.01em;}
    .toc .go{text-align:right;font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--mut);border-left:var(--hair) solid var(--line);}
    @media (prefers-reduced-motion: no-preference){.toc .row{transition:background .1s;}}
    .toc .row:hover{background:var(--ink);color:var(--paper);}
    .toc .row:hover .go{color:var(--accent);}
    .toc .row:hover .ix{color:var(--accent);}

    /* ---- SECTION HEADER ---- */
    .sec-head{
      display:grid;grid-template-columns:64px 1fr;border-bottom:2px solid var(--line);
      background:var(--ink);color:var(--paper);
    }
    .sec-head .big{font-size:clamp(40px,9vw,90px);font-weight:700;line-height:.9;padding:8px 0 8px;text-align:center;border-right:var(--hair) solid #444;}
    .sec-head .htxt{padding:14px var(--pad);display:flex;flex-direction:column;justify-content:center;gap:6px;}
    .sec-head .eyebrow{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);font-weight:700;}
    .sec-head h2{margin:0;font-family:"Instrument Serif",Georgia,serif;font-weight:400;font-size:clamp(22px,4.4vw,38px);line-height:1.05;letter-spacing:.005em;}
    .sec-head h2 em{font-style:italic;color:var(--accent);}
    .sec-head .blurb{font-size:11.5px;color:#cfcdc6;max-width:62ch;}
    .sec-head .blurb i{font-style:italic;color:#fff;}

    /* ---- HERO ---- */
    .hero{display:grid;grid-template-columns:1.55fr 1fr;border-bottom:2px solid var(--line);}
    .hero-l{padding:var(--pad);border-right:var(--hair) solid var(--line);}
    .hero-eyebrow{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);font-weight:700;margin-bottom:18px;}
    .hero-name{font-family:"Instrument Serif",Georgia,serif;font-weight:400;font-size:clamp(34px,7vw,82px);line-height:.94;letter-spacing:-.01em;margin:0 0 6px;}
    .hero-role{font-size:11px;letter-spacing:.04em;color:var(--mut);max-width:60ch;margin-bottom:22px;}
    .hero-head{font-family:"Instrument Serif",Georgia,serif;font-weight:400;font-size:clamp(24px,4.6vw,46px);line-height:1.04;margin:0 0 18px;}
    .hero-head em{font-style:italic;color:var(--accent);}
    .hero-lead{font-size:12.5px;line-height:1.65;max-width:64ch;margin:0 0 24px;}
    .hero-cta{display:flex;gap:0;border:var(--hair) solid var(--line);width:fit-content;max-width:100%;flex-wrap:wrap;}
    .btn{padding:12px 20px;font-weight:700;font-size:11px;letter-spacing:.12em;text-transform:uppercase;}
    .btn.p{background:var(--accent);color:var(--paper);}
    .btn.g{border-left:var(--hair) solid var(--line);}
    @media (prefers-reduced-motion: no-preference){.btn{transition:background .12s,color .12s;}}
    .btn.g:hover{background:var(--ink);color:var(--paper);}

    .hero-r{display:grid;grid-template-rows:auto 1fr;}
    .hero-stats{display:grid;}
    .stat{padding:var(--pad);border-bottom:var(--hair) solid var(--line);}
    .stat .v{font-size:clamp(34px,5vw,56px);font-weight:700;line-height:1;letter-spacing:-.02em;}
    .stat .l{font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--mut);margin-top:6px;}
    .glyph{
      flex:1;display:grid;place-items:center;overflow:hidden;position:relative;
      background:
        repeating-linear-gradient(0deg, transparent 0 13px, rgba(11,11,11,.07) 13px 14px),
        repeating-linear-gradient(90deg, transparent 0 13px, rgba(11,11,11,.07) 13px 14px);
    }
    .glyph .ts{font-family:"Instrument Serif",Georgia,serif;font-size:clamp(120px,24vw,260px);line-height:.8;color:var(--ink);opacity:.96;}
    .glyph .sub{position:absolute;bottom:10px;left:0;right:0;text-align:center;font-size:9px;letter-spacing:.3em;text-transform:uppercase;color:var(--mut);}

    /* ---- WORKFLOW STAGES ---- */
    .stages{display:grid;grid-template-columns:repeat(4,1fr);border-bottom:var(--hair) solid var(--line);}
    .stage{padding:var(--pad);border-right:var(--hair) solid var(--line);}
    .stage:last-child{border-right:0;}
    .stage .n{font-size:10px;font-weight:700;color:var(--accent);letter-spacing:.14em;}
    .stage h4{margin:6px 0 8px;font-size:15px;font-weight:700;}
    .stage p{margin:0;font-size:11px;color:var(--mut);line-height:1.55;}
    .wf-blurb{padding:var(--pad);border-bottom:var(--hair) solid var(--line);font-size:12px;line-height:1.6;max-width:80ch;}
    .wf-cta{padding:14px var(--pad);border-bottom:2px solid var(--line);}

    /* ---- CASES ---- */
    .cases{}
    .case{
      display:grid;grid-template-columns:80px 200px 1fr;border-bottom:var(--hair) solid var(--line);align-items:stretch;
    }
    .case > *{padding:16px var(--pad);}
    .case .c-no{font-size:clamp(28px,5vw,52px);font-weight:700;line-height:.9;color:var(--ink);border-right:var(--hair) solid var(--line);display:flex;align-items:flex-start;}
    .case .c-metric{border-right:var(--hair) solid var(--line);display:flex;flex-direction:column;gap:6px;}
    .case .c-metric .mv{font-family:"Instrument Serif",Georgia,serif;font-size:22px;line-height:1;color:var(--accent);}
    .case .c-metric .ml{font-size:10px;color:var(--mut);letter-spacing:.04em;line-height:1.4;text-transform:uppercase;}
    .case .c-body{display:flex;flex-direction:column;gap:10px;}
    .case .c-title{font-size:clamp(15px,2.4vw,20px);font-weight:700;display:flex;justify-content:space-between;gap:14px;align-items:baseline;}
    .case .c-title .arr{color:var(--accent);font-weight:700;}
    .case .c-blurb{font-size:11.5px;color:#2a2a26;line-height:1.6;max-width:78ch;}
    .case .c-tags{display:flex;flex-wrap:wrap;gap:6px;}
    .tag{border:var(--hair) solid var(--line);padding:3px 8px;font-size:9.5px;letter-spacing:.06em;text-transform:uppercase;font-weight:500;}
    @media (prefers-reduced-motion: no-preference){.case{transition:background .1s;}}
    .case:hover{background:#e7e4da;}
    .case:hover .c-no{color:var(--accent);}

    /* ---- KEY/VALUE rows (Now) ---- */
    .kv{display:grid;grid-template-columns:200px 1fr;border-bottom:var(--hair) solid var(--line);}
    .kv .k{padding:16px var(--pad);font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:.06em;border-right:var(--hair) solid var(--line);color:var(--accent);}
    .kv .v{padding:16px var(--pad);font-size:11.5px;line-height:1.65;}
    .kv .v a{color:var(--ink);font-weight:700;border-bottom:2px solid var(--accent);}
    .kv .v a:hover{background:var(--accent);color:var(--paper);}

    /* ---- CV ---- */
    .cv-sub{display:grid;grid-template-columns:200px 1fr;border-bottom:2px solid var(--line);background:#e7e4da;}
    .cv-sub .lbl{padding:10px var(--pad);font-weight:700;text-transform:uppercase;letter-spacing:.16em;font-size:11px;border-right:var(--hair) solid var(--line);}
    .cv-sub .sum{padding:10px var(--pad);font-size:11px;color:var(--mut);letter-spacing:.04em;display:flex;align-items:center;}
    .job{display:grid;grid-template-columns:200px 1fr;border-bottom:var(--hair) solid var(--line);}
    .job .when{padding:16px var(--pad);font-size:11px;color:var(--mut);border-right:var(--hair) solid var(--line);font-weight:500;}
    .job .det{padding:16px var(--pad);}
    .job .org{font-size:16px;font-weight:700;}
    .job .title{font-size:12px;color:var(--accent);font-weight:500;margin:2px 0 10px;letter-spacing:.02em;}
    .job ul{margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:7px;}
    .job li{font-size:11.5px;line-height:1.55;padding-left:16px;position:relative;}
    .job li::before{content:"/";position:absolute;left:0;color:var(--accent);font-weight:700;}
    .pub .det .org{font-family:"Instrument Serif",Georgia,serif;font-weight:400;font-size:18px;line-height:1.2;}
    .pub-cta{display:inline-block;margin-top:10px;font-weight:700;font-size:11px;letter-spacing:.12em;text-transform:uppercase;border-bottom:2px solid var(--accent);}

    /* ---- READING / LANGUAGES grids ---- */
    .grid2{display:grid;grid-template-columns:1fr 1fr;}
    .gcell{padding:var(--pad);border-bottom:var(--hair) solid var(--line);border-right:var(--hair) solid var(--line);}
    .grid2 .gcell:nth-child(2n){border-right:0;}
    .gcell h4{margin:0 0 8px;font-size:15px;font-weight:700;}
    .gcell p{margin:0;font-size:11.5px;color:var(--mut);line-height:1.6;}

    .langs{display:grid;grid-template-columns:repeat(6,1fr);}
    .lang{padding:var(--pad);border-right:var(--hair) solid var(--line);text-align:center;}
    .lang:last-child{border-right:0;}
    .lang .code{font-size:clamp(28px,4vw,46px);font-weight:700;letter-spacing:-.02em;line-height:1;}
    .lang .nm{font-size:10px;margin-top:8px;color:var(--mut);letter-spacing:.06em;}

    /* ---- CONTACT ---- */
    .contact{position:relative;border-bottom:2px solid var(--line);overflow:hidden;background:var(--ink);color:var(--paper);}
    .contact .wm{position:absolute;right:-2vw;top:50%;transform:translateY(-50%);font-family:"Instrument Serif",Georgia,serif;font-size:clamp(160px,34vw,420px);line-height:.7;color:rgba(255,255,255,.06);pointer-events:none;user-select:none;}
    .contact-inner{position:relative;padding:var(--pad);z-index:2;}
    .contact .eyebrow{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);font-weight:700;}
    .contact h2{font-family:"Instrument Serif",Georgia,serif;font-weight:400;font-size:clamp(28px,6vw,60px);line-height:1.02;margin:12px 0;}
    .contact h2 em{font-style:italic;color:var(--accent);}
    .contact p{font-size:12.5px;line-height:1.65;max-width:64ch;color:#cfcdc6;margin:0 0 22px;}
    .contact-cta{display:flex;border:var(--hair) solid #555;width:fit-content;max-width:100%;flex-wrap:wrap;}
    .contact-cta a{padding:13px 20px;font-weight:700;font-size:11px;letter-spacing:.12em;text-transform:uppercase;border-left:var(--hair) solid #555;}
    .contact-cta a:first-child{border-left:0;background:var(--accent);color:var(--paper);}
    @media (prefers-reduced-motion: no-preference){.contact-cta a{transition:background .12s,color .12s;}}
    .contact-cta a:not(:first-child):hover{background:var(--paper);color:var(--ink);}

    /* ---- FOOTER ---- */
    footer{background:var(--ink);color:var(--paper);}
    .foot-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;border-bottom:var(--hair) solid #333;}
    .foot-grid > div{padding:var(--pad);border-right:var(--hair) solid #333;}
    .foot-grid > div:last-child{border-right:0;}
    .foot-brand b{font-weight:700;}
    .foot-brand .tag{font-size:11px;color:#aaa;margin-top:10px;line-height:1.5;max-width:34ch;}
    .foot-col h5{margin:0 0 12px;font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);font-weight:700;}
    .foot-col a{display:block;font-size:11px;color:#ddd;padding:4px 0;}
    .foot-col a:hover{color:var(--accent);}
    .foot-bot{display:flex;justify-content:space-between;gap:14px;flex-wrap:wrap;padding:12px var(--pad);font-size:10px;color:#888;letter-spacing:.06em;}

    /* ---- RESPONSIVE ---- */
    @media (max-width:820px){
      .hero{grid-template-columns:1fr;}
      .hero-l{border-right:0;border-bottom:var(--hair) solid var(--line);}
      .hero-stats{grid-template-columns:repeat(3,1fr);}
      .stat{border-right:var(--hair) solid var(--line);}
      .stat:last-child{border-right:0;}
      .glyph{min-height:200px;}
      .stages{grid-template-columns:repeat(2,1fr);}
      .stage:nth-child(2n){border-right:0;}
      .foot-grid{grid-template-columns:1fr 1fr;}
    }
    @media (max-width:600px){
      body{font-size:13px;}
      .topbar{grid-template-columns:1fr;}
      .topbar-meta{border-left:0;border-top:var(--hair) solid var(--line);justify-content:space-between;}
      .toc .row{grid-template-columns:44px 1fr;}
      .toc .go{display:none;}
      .sec-head{grid-template-columns:48px 1fr;}
      .case{grid-template-columns:1fr;}
      .case .c-no{border-right:0;border-bottom:var(--hair) solid var(--line);}
      .case .c-metric{border-right:0;border-bottom:var(--hair) solid var(--line);flex-direction:row;flex-wrap:wrap;align-items:baseline;}
      .kv{grid-template-columns:1fr;}
      .kv .k{border-right:0;border-bottom:var(--hair) solid var(--line);}
      .cv-sub{grid-template-columns:1fr;}
      .cv-sub .lbl{border-right:0;border-bottom:var(--hair) solid var(--line);}
      .job{grid-template-columns:1fr;}
      .job .when{border-right:0;border-bottom:var(--hair) solid var(--line);}
      .grid2{grid-template-columns:1fr;}
      .grid2 .gcell{border-right:0;}
      .langs{grid-template-columns:repeat(3,1fr);}
      .lang:nth-child(3n){border-right:0;}
      .lang:nth-child(n+4){border-top:var(--hair) solid var(--line);}
      .stages{grid-template-columns:1fr;}
      .stage{border-right:0;}
      .foot-grid{grid-template-columns:1fr;}
      .foot-grid > div{border-right:0;border-bottom:var(--hair) solid #333;}
    }
  </style>
</head>
<body>
  <div class="wrap">

    <!-- TOP BAR -->
    <div class="topbar">
      <div class="brand">
        <span class="tmark">T</span>
        <b>Tom Scholtes</b>
        <span class="mut mono-cap" style="margin-left:8px;">Index / Luxembourg</span>
      </div>
      <div class="topbar-meta">
        <span class="langset mut">EN / DE / FR / RU</span>
        <a class="saychip" href="#contact">Say hi</a>
      </div>
    </div>

    <!-- MARQUEE -->
    <div class="marquee" aria-hidden="true">
      <ul>
        <li>
          <span class="dot">FINANCE OPS ENGINEER WHO AUTOMATES THE WORK IN REACH</span>
          <span>SIX YEARS / LUXEMBOURG FUND SERVICES</span>
          <span>PE · PRIVATE DEBT · REAL ESTATE</span>
          <span class="dot">A LIVE CV · A PORTFOLIO OF WORK</span>
          <span>AI-AUGMENTED AUTOMATION FOR REGULATED FINANCE</span>
        </li>
        <li>
          <span class="dot">FINANCE OPS ENGINEER WHO AUTOMATES THE WORK IN REACH</span>
          <span>SIX YEARS / LUXEMBOURG FUND SERVICES</span>
          <span>PE · PRIVATE DEBT · REAL ESTATE</span>
          <span class="dot">A LIVE CV · A PORTFOLIO OF WORK</span>
          <span>AI-AUGMENTED AUTOMATION FOR REGULATED FINANCE</span>
        </li>
