---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import NoteCard from '../../components/NoteCard.astro';
import RevealObserver from '../../components/RevealObserver.astro';
import { getCollection } from 'astro:content';
import { t as translate, getLocale, type Locale } from '../../i18n';

const locale = (Astro.currentLocale ?? getLocale(Astro.url)) as Locale;
const t = (k: string) => translate(k, locale);

const entries = (await getCollection('notes', ({ data, slug }) =>
    data.status === 'published' && slug.startsWith('en/')))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---
<Base
  title={t('meta.notes.index.title')}
  description={t('meta.notes.index.description')}
  path="/notes/"
>
  <Nav active="notes" />
  <main>
    <header class="paper notes-index-header">
      <div class="container">
        <span class="eyebrow">{t('notes.index.eyebrow')}</span>
        <h1 class="title">{t('notes.index.heading.pre')} <em>{t('notes.index.heading.em')}</em>{t('notes.index.heading.post')}</h1>
        <p class="sub">{t('notes.index.sub')}</p>
      </div>
    </header>

    <section class="notes-index">
      <div class="container">
        <ol class="notes-list">
          {entries.map((entry, i) => (
            <li class="reveal" style={`--reveal-delay: ${Math.min(i, 5) * 50}ms`}>
              <NoteCard entry={entry} />
            </li>
          ))}
        </ol>
      </div>
    </section>
  </main>
  <Footer />
  <RevealObserver />
</Base>
