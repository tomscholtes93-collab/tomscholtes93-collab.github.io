---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import RevealObserver from '../../components/RevealObserver.astro';
import { t as translate, getLocale, localizePath, type Locale } from '../../i18n';

const locale = (Astro.currentLocale ?? getLocale(Astro.url)) as Locale;
const t = (k: string) => translate(k, locale);
const devswarmHref = localizePath('/projects/devswarm/', locale);
const exocortexHref = localizePath('/projects/exocortex/', locale);
const tagList = (slug: 'devswarm' | 'exocortex') =>
  [0, 1, 2, 3]
    .map((i) => t(`projects.index.card.${slug}.tag.${i}`))
    .filter((s) => s && s.length > 0);
const devswarmTags = tagList('devswarm');
const exocortexTags = tagList('exocortex');
---
<Base
  title={t('meta.projects.title')}
  description={t('meta.projects.description')}
  path="/projects/"
>
  <Nav active="projects" />
  <main>
    <header class="paper">
      <div class="container">
        <span class="eyebrow">{t('projects.index.eyebrow')}</span>
        <h1 class="title">{t('projects.index.heading.pre')} <em>{t('projects.index.heading.em')}</em> {t('projects.index.heading.post')}</h1>
        <p class="sub">{t('projects.index.sub')}</p>
      </div>
    </header>

    <section class="cards reveal" id="projects-list">
      <div class="container">
        <div class="proj-cards">

          <a class="card" href={devswarmHref}>
            <div class="card-head">
              <span class="card-num">{t('projects.index.card.devswarm.num')}</span>
              <div class="card-metric">
                <div class="card-metric-num">{t('projects.index.card.devswarm.metric')}</div>
                <div class="card-metric-lbl">{t('projects.index.card.devswarm.label')}</div>
              </div>
            </div>
            <h2>{t('projects.index.card.devswarm.title')}<span class="arr"> →</span></h2>
            <p>{t('projects.index.card.devswarm.body')}</p>
            <div class="tags">
              {devswarmTags.map((tg) => <span class="tag">{tg}</span>)}
            </div>
          </a>

          <a class="card in-progress" href={exocortexHref}>
            <div class="card-head">
              <span class="card-num">{t('projects.index.card.exocortex.num')}</span>
              <div class="card-metric">
                <div class="card-metric-num">{t('projects.index.card.exocortex.metric')}</div>
                <div class="card-metric-lbl">{t('projects.index.card.exocortex.label')}</div>
              </div>
            </div>
            <h2>{t('projects.index.card.exocortex.title')}<span class="arr"> →</span></h2>
            <p>{t('projects.index.card.exocortex.body')}</p>
            <div class="tags">
              {exocortexTags.map((tg) => <span class="tag">{tg}</span>)}
            </div>
          </a>

        </div>
      </div>
    </section>
  </main>
  <Footer />
  <RevealObserver />
</Base>
